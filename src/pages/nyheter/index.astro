---
import Layout from '../../layouts/Layout.astro';
import { posts, categories } from '../../data/news.js';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;

// Visa bara filter-kategorier som faktiskt finns bland artiklarna
const usedCats = new Set(posts.map((p) => p.cat));
const filters = categories.filter((c) => c.id === 'all' || usedCats.has(c.id));
---

<Layout
  title="Nyheter | Norrmalmstryckeriet"
  description="Nyheter och artiklar från Norrmalmstryckeriet — om tryck, hållbarhet, investeringar, nya kunder och varför trycksaker fortfarande gör skillnad."
>

  <!-- ═══ HERO (vänsterställd) ═══ -->
  <section class="page-section pb-[32px] sm:pb-[40px]">
    <div class="page-container">
      <p class="section-label">Nyheter</p>
      <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[920px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
        Tankar om tryck, teknik och trender.
      </h1>
      <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[720px]" style="text-wrap: pretty;">
        Djupdykningar om varför trycksaker fortfarande gör skillnad, om hållbar produktion, nya kunder och om vad som händer hos oss på Norrmalmstryckeriet.
      </p>
    </div>
  </section>

  <!-- ═══ FILTER + LISTA ═══ -->
  <section class="pb-[64px] sm:pb-[80px] md:pb-[100px]">
    <div class="page-container">
      <!-- Kategori-filter -->
      <div id="news-filter" class="flex flex-wrap gap-[8px] sm:gap-[10px] border-b border-[#E5E5E5] pb-[24px] sm:pb-[32px] mb-[8px]">
        {filters.map((f) => (
          <button
            data-filter={f.id}
            class={`news-chip px-[16px] py-[8px] rounded-full text-[13px] sm:text-[14px] font-medium transition-colors cursor-pointer ${f.id === 'all' ? 'is-active' : ''}`}
          >
            {f.label}
          </button>
        ))}
      </div>

      <!-- Lista — kort, 2 i bredd på sm+ -->
      <div id="news-list" class="grid sm:grid-cols-2 gap-x-[28px] md:gap-x-[40px] lg:gap-x-[56px] gap-y-[40px] sm:gap-y-[52px] md:gap-y-[64px] mt-[28px] sm:mt-[40px]">
        {posts.map((p) => (
          <a
            href={`/nyheter/${p.slug}`}
            data-cat={p.cat}
            class="news-row group block no-underline"
          >
            <div class="rounded-[16px] sm:rounded-[20px] overflow-hidden aspect-[16/10] bg-[#E5E5E5] mb-[18px] sm:mb-[22px]">
              <img src={p.image} alt={p.title} loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex items-center gap-[10px] mb-[10px] sm:mb-[14px] flex-wrap">
              <span class="text-[12px] sm:text-[13px] text-[#888] font-medium tabular-nums">{p.dotDate}</span>
              <span class="text-[#D5D5D5]">•</span>
              <span class="text-[11px] sm:text-[12px] uppercase text-[#D9222A] font-semibold" style="letter-spacing: 1px;">{p.catLabel}</span>
              <span class="text-[#D5D5D5]">•</span>
              <span class="text-[12px] sm:text-[13px] text-[#888]">{p.readMin} min</span>
            </div>
            <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[10px] sm:mb-[14px] group-hover:text-[#D9222A] transition-colors" style="font-size: clamp(1.375rem, 1.4vw + 0.6rem, 1.875rem); line-height: 1.12; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
              {p.title}
            </h2>
            <p class="text-[15px] sm:text-[16px] leading-relaxed text-[#555] mb-[16px]" style="text-wrap: pretty;">{p.excerpt}</p>
            <span class="inline-flex items-center text-[14px] sm:text-[15px] font-medium text-[#222] group-hover:text-[#D9222A] transition-colors">
              Läs artikeln<Fragment set:html={arrowSvg} />
            </span>
          </a>
        ))}
      </div>

      <p id="news-empty" class="hidden text-[15px] sm:text-[16px] text-[#888] py-[40px] text-center">Inga artiklar i den här kategorin ännu.</p>
    </div>
  </section>

  <!-- ═══ SLUT-CTA ═══ -->
  <section class="page-section pt-0">
    <div class="page-container max-w-[1300px]">
      <div class="bg-[#222] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] px-[24px] sm:px-[44px] md:px-[60px] lg:px-[80px] py-[48px] sm:py-[72px] md:py-[96px] grid lg:grid-cols-[1.3fr_1fr] gap-[32px] lg:gap-[60px] items-center">
        <div>
          <p class="section-label" style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Något på gång?</p>
          <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[24px]" style="font-size: clamp(1.75rem, 4vw, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
            Berätta vad du vill trycka — vi gör resten.
          </h2>
          <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed" style="text-wrap: pretty;">
            Skicka original eller en kort beskrivning så hjälper vi dig med format, papper, tryckmetod och en tydlig offert.
          </p>
        </div>
        <div class="flex flex-col gap-[12px]">
          <a href="/offert" class="btn-pill btn-red w-full justify-center">
            Begär offert<Fragment set:html={arrowSvg} />
          </a>
          <a href="/kontakta-oss" class="btn-pill w-full justify-center" style="background: white; color: #222;">
            Kontakta oss<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-container { width: 100%; max-width: 1440px; margin-left: auto; margin-right: auto; }
  .page-section { padding-top: 64px; padding-bottom: 64px; padding-left: 16px; padding-right: 16px; }
  @media (min-width: 640px) { .page-section { padding-top: 80px; padding-bottom: 80px; padding-left: 24px; padding-right: 24px; } }
  @media (min-width: 768px) { .page-section { padding-top: 100px; padding-bottom: 100px; } }
  @media (min-width: 1024px) { .page-section { padding-top: 120px; padding-bottom: 120px; padding-left: 44px; padding-right: 44px; } }
  .section-label {
    font-family: var(--font-body); font-size: 11px; line-height: 1; letter-spacing: 1.5px;
    text-transform: uppercase; font-weight: 500; color: #888; margin-bottom: 20px;
  }
  @media (min-width: 768px) { .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 24px; } }
  .news-chip { background: #F3F3F3; color: #555; }
  .news-chip:hover { background: #EAEAEA; color: #222; }
  .news-chip.is-active { background: #222; color: #fff; }
  .news-row.is-hidden { display: none; }
</style>

<script>
  function initNewsFilter() {
    const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.news-chip'));
    const rows = Array.from(document.querySelectorAll<HTMLElement>('.news-row'));
    const empty = document.getElementById('news-empty');
    if (!chips.length) return;
    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        const filter = chip.dataset.filter;
        chips.forEach((c) => c.classList.remove('is-active'));
        chip.classList.add('is-active');
        let visible = 0;
        rows.forEach((row) => {
          const show = filter === 'all' || row.dataset.cat === filter;
          row.classList.toggle('is-hidden', !show);
          if (show) visible++;
        });
        if (empty) empty.classList.toggle('hidden', visible !== 0);
      });
    });
  }
  initNewsFilter();
  document.addEventListener('astro:after-swap', initNewsFilter);
</script>
