---
import Layout from '../../layouts/Layout.astro';
import { posts } from '../../data/news.js';

export function getStaticPaths() {
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const others = posts.filter((p) => p.slug !== post.slug).slice(0, 2);

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout title={`${post.title.replace(/\.$/, '')} | Norrmalmstryckeriet`} description={post.excerpt}>

  <!-- ═══ HERO (centrerad) ═══ -->
  <section class="pt-[48px] sm:pt-[64px] md:pt-[80px] px-[16px] sm:px-[24px] md:px-[32px]">
    <div class="max-w-[820px] mx-auto text-center">
      <a href="/nyheter" class="inline-flex items-center text-[#888] hover:text-[#222] transition-colors text-[13px] sm:text-[14px] font-medium mb-[20px] sm:mb-[28px]">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="mr-[6px]"><path d="M15 18l-6-6 6-6"/></svg>
        Alla nyheter
      </a>
      <div class="flex items-center justify-center gap-[10px] mb-[20px] sm:mb-[24px] text-[12px] sm:text-[13px] flex-wrap">
        <span class="uppercase text-[#D9222A] font-semibold" style="letter-spacing: 1px;">{post.catLabel}</span>
        <span class="text-[#D5D5D5]">•</span>
        <span class="text-[#888] tabular-nums">{post.dateLabel}</span>
        <span class="text-[#D5D5D5]">•</span>
        <span class="text-[#888]">{post.readMin} min läsning</span>
      </div>
      <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[28px] sm:mb-[36px]" style="font-size: clamp(2rem, 4vw + 0.5rem, 4rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
        {post.title}
      </h1>
    </div>
  </section>

  <!-- ═══ FULLBREDDS HERO-BILD ═══ -->
  <section class="px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px]">
    <div class="max-w-[1100px] mx-auto">
      <div class="rounded-[20px] sm:rounded-[32px] lg:rounded-[40px] overflow-hidden bg-[#E5E5E5] aspect-[16/9]">
        <img src={post.image} alt={post.title} class="w-full h-full object-cover" loading="eager" decoding="async" />
      </div>
    </div>
  </section>

  <!-- ═══ ARTIKELTEXT (smal spalt) ═══ -->
  <article class="px-[16px] sm:px-[24px] md:px-[32px] pt-[40px] sm:pt-[56px] md:pt-[72px] pb-[16px]">
    <div class="max-w-[680px] mx-auto">
      <p class="text-[18px] sm:text-[20px] md:text-[22px] leading-[1.55] text-[#222] font-medium mb-[28px] sm:mb-[36px]" style="text-wrap: pretty;">
        {post.excerpt}
      </p>
      <div class="space-y-[20px] sm:space-y-[24px]">
        {post.body.map((block) => (
          block.t === 'h2' ? (
            <h2 class="font-[var(--font-heading)] !font-normal text-[#222] pt-[16px] sm:pt-[24px]" style="font-size: clamp(1.5rem, 2.5vw, 2.125rem); line-height: 1.15; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">{block.v}</h2>
          ) : block.t === 'quote' ? (
            <blockquote class="border-l-[3px] border-[#D9222A] pl-[24px] sm:pl-[32px] my-[8px]">
              <p class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.375rem, 2vw, 1.875rem); line-height: 1.3; text-wrap: balance;">&ldquo;{block.v}&rdquo;</p>
            </blockquote>
          ) : (
            <p class="text-[16px] sm:text-[17px] md:text-[19px] leading-[1.7] text-[#333]" style="text-wrap: pretty;">{block.v}</p>
          )
        ))}
      </div>
    </div>
  </article>

  <!-- ═══ CTA — "Vill du veta mer?" ═══ -->
  <section class="px-[16px] sm:px-[24px] md:px-[32px] py-[40px] sm:py-[56px]">
    <div class="max-w-[680px] mx-auto">
      <div class="bg-[#F3F3F3] rounded-[24px] sm:rounded-[32px] px-[28px] sm:px-[44px] py-[36px] sm:py-[48px] text-center">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.5rem, 3vw, 2.25rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
          Vill du veta mer?
        </h2>
        <p class="text-[15px] sm:text-[16px] leading-relaxed text-[#555] mb-[24px] sm:mb-[28px] max-w-[440px] mx-auto" style="text-wrap: pretty;">
          Berätta vad du vill trycka, så hjälper vi dig med format, papper, tryckmetod och en tydlig offert.
        </p>
        <div class="flex flex-col sm:flex-row gap-[10px] sm:gap-[12px] justify-center">
          <a href="/offert" class="btn-pill btn-red w-full sm:w-auto justify-center">
            Begär offert<Fragment set:html={arrowSvg} />
          </a>
          <a href="/kontakta-oss" class="btn-pill btn-dark w-full sm:w-auto justify-center">
            Kontakta oss<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ FLER NYHETER (grid) ═══ -->
  <section class="px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px] pb-[64px] sm:pb-[80px] md:pb-[100px]">
    <div class="max-w-[1440px] mx-auto">
      <p class="section-label" style="margin-bottom: 12px;">Fler nyheter</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[28px] sm:mb-[40px]" style="font-size: clamp(1.75rem, 4vw, 3rem); line-height: 1.05; letter-spacing: -0.025em;" lang="sv">
        Mer läsning.
      </h2>
      <div class="grid sm:grid-cols-2 gap-[24px] sm:gap-[28px]">
        {others.map((p) => (
          <a href={`/nyheter/${p.slug}`} class="block group no-underline">
            <div class="rounded-[20px] overflow-hidden aspect-[16/9] bg-[#E5E5E5] mb-[18px]">
              <img src={p.image} alt={p.title} loading="lazy" decoding="async" class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500" />
            </div>
            <div class="flex items-center gap-[10px] mb-[10px] text-[12px] flex-wrap">
              <span class="uppercase text-[#D9222A] font-semibold" style="letter-spacing: 1px;">{p.catLabel}</span>
              <span class="text-[#D5D5D5]">•</span>
              <span class="text-[#888] tabular-nums">{p.dateLabel}</span>
              <span class="text-[#D5D5D5]">•</span>
              <span class="text-[#888]">{p.readMin} min</span>
            </div>
            <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[22px] sm:text-[24px] leading-[1.15] group-hover:text-[#D9222A] transition-colors" style="letter-spacing: -0.02em; text-wrap: balance;">{p.title}</h3>
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .section-label {
    font-family: var(--font-body); font-size: 11px; line-height: 1; letter-spacing: 1.5px;
    text-transform: uppercase; font-weight: 500; color: #888; margin-bottom: 20px;
  }
  @media (min-width: 768px) { .section-label { font-size: 12px; letter-spacing: 1.8px; } }
</style>
