---
import Layout from '../../../layouts/Layout.astro';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
const downloadSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>`;

// "Vad du lär dig" — 8 steg från guiden, sidoscroll
const steps = [
  {
    no: '01',
    title: 'Börja med uppgiften',
    body: 'Vad ska bladet faktiskt göra? Skapa uppmärksamhet, förklara, driva kampanj, stödja försäljning? Det styr allt annat.',
  },
  {
    no: '02',
    title: 'Välj rätt format',
    body: 'A6 för snabbt, A5 för flexibelt, A4 för informativt eller eget format för att synas. Innehållet styr storleken.',
  },
  {
    no: '03',
    title: 'Välj papper efter känsla',
    body: 'Tunt eller kraftigt, bestruket eller obestruket, miljöanpassat — pappret är en del av budskapet, inte bara en specifikation.',
  },
  {
    no: '04',
    title: 'Digitaltryck eller offset',
    body: 'Mindre upplaga, versioner, snabbt? Digital. Större upplaga, stabil färg, lågt styckpris? Offset. Vi rekommenderar utifrån uppdraget.',
  },
  {
    no: '05',
    title: 'Gör budskapet tydligt',
    body: 'Stark rubrik, kort förklaring, bild som förstärker, en tydlig CTA. Bladet ska svara på frågan: "Varför är detta relevant för mig?"',
  },
  {
    no: '06',
    title: 'Lägg till efterbehandling',
    body: 'Perforering, stansning, prägling, foliering, lack eller laminering — när det har en funktion, inte bara som dekoration.',
  },
  {
    no: '07',
    title: 'Kontrollera originalet',
    body: 'Rätt slutformat, utfall på bilder, text inom säker marginal, bilder i tillräcklig upplösning, CMYK och tryckfärdig PDF.',
  },
  {
    no: '08',
    title: 'Beställ rätt',
    body: 'Skicka original, beskrivning av användning och önskad upplaga. Vi rekommenderar och offererar — innan du låser produktionen.',
  },
];

// Expertis-block — papper, tryck, efterbehandling (samma struktur som produktsidor)
const expertise = [
  {
    title: 'Pappersval',
    intro: 'Pappret är en del av budskapet. Mottagaren känner kvaliteten innan texten är färdigläst.',
    items: [
      ['Tunnare papper', 'Bra för stora utskick och enklare information där vikt påverkar portot.'],
      ['Kraftigare papper', 'Mer stabilitet, högre kvalitetskänsla och längre livslängd.'],
      ['Bestruket', 'Skarpa bilder, tydligare färgåtergivning. Bra för produktblad och kampanjer.'],
      ['Obestruket', 'Mjuk, naturlig och taktil känsla. Bra för information och textnära material.'],
      ['Miljöanpassat', 'Stödjer hållbar profil och ansvarsfull kommunikation.'],
    ],
  },
  {
    title: 'Tryckmetod',
    intro: 'Valet mellan digitaltryck och offsettryck beror på upplaga, kvalitet, material och om innehållet ska variera.',
    items: [
      ['Digitaltryck', 'Snabbt och flexibelt. Passar mindre upplagor, testserier och versionerat material.'],
      ['Offsettryck', 'Stabilt och kostnadseffektivt vid volym. Hög och jämn kvalitet över upplagan.'],
      ['Pantone', 'Exakt färgmatchning för varumärkesfärger.'],
      ['4+0 / 4+4', 'Fyrfärg på ena eller båda sidor. Vanligast för moderna reklamblad.'],
      ['Variabeltryck', 'Anpassa innehåll efter mottagare, område eller kampanjversion.'],
    ],
  },
  {
    title: 'Efterbehandling',
    intro: 'Små detaljer som gör stor skillnad. Rätt finish kan göra bladet tydligare, mer användbart eller mer minnesvärt.',
    items: [
      ['Perforering', 'Kuponger, svarstalonger och rivbara delar.'],
      ['Stansning', 'Egen form, rundade hörn eller särskild design.'],
      ['Prägling', 'Taktil känsla och premiumdetaljer på logotyp.'],
      ['Foliering', 'Exklusiva detaljer i guld, silver eller färgfolie.'],
      ['Lack / laminering', 'Skydd, glans eller matt effekt — och extra hållbarhet.'],
    ],
  },
];

// Tryck-termer
const tryckTermer = [
  ['4+0', 'Fyrfärgstryck på ena sidan, inget tryck på baksidan'],
  ['4+4', 'Fyrfärgstryck på båda sidor'],
  ['1+0', 'Enfärgstryck på ena sidan'],
  ['1+1', 'Enfärgstryck på båda sidor'],
];

// Format
const format = [
  ['A6', 'Flyers, kuponger, små erbjudanden, eventinformation'],
  ['A5', 'Reklamblad, säljblad, informationsblad, mässmaterial'],
  ['A4', 'Produktblad, instruktioner, prislistor, mer innehållstunga blad'],
  ['Kvadratiskt format', 'Kampanjer, premiumkänsla, särskiljning'],
  ['Eget format', 'Varumärkesbyggande material, lanseringar, särskilda utskick'],
];

// Original / tryckfil
const tryckfil = [
  ['Utfall', 'Lägg till utfall om färg, bild eller grafik går ända ut till kanten'],
  ['Skärmärken', 'Används för att visa slutformat vid skärning'],
  ['Bildkvalitet', 'Bilder bör ha tillräcklig upplösning för tryck'],
  ['Färger', 'Tryck produceras normalt i CMYK'],
  ['Marginaler', 'Text och viktiga detaljer bör ligga en bit från skärkanten'],
  ['PDF', 'Leverera helst tryckfärdig PDF enligt tryckeriets rekommendationer'],
];

// Beslutsfrågor
const beslut = [
  ['Vad ska mottagaren förstå?', 'Styr rubrik, budskap och innehåll'],
  ['Vad ska mottagaren göra?', 'Styr CTA och kontaktväg'],
  ['Var ska bladet användas?', 'Styr format, papper och efterbehandling'],
  ['Hur länge ska det leva?', 'Styr materialval och kvalitetsnivå'],
  ['Hur ska det distribueras?', 'Styr format, vikt och eventuell kuvertering'],
  ['Vilken känsla ska avsändaren förmedla?', 'Styr papper, bildval, färg och finish'],
];
---

<Layout
  title="Trycka blad och reklamblad – guide till format, papper och tryck | Norrmalmstryckeriet"
  description="Lär dig vad du bör tänka på när du ska trycka blad eller reklamblad. Guide till format, papper, digitaltryck, offsettryck, original och efterbehandling."
>

  <!-- ═══ HERO (samma mönster som /produkter/blad/infografik) ═══ -->
  <section class="page-section hero-pdf bg-[#F3F3F3]">
    <div class="page-container">
      <div class="grid lg:grid-cols-[1fr_auto] gap-[40px] md:gap-[60px] lg:gap-[80px] items-center lg:items-end">
        <!-- Vänster: Text -->
        <div>
          <p class="section-label">Guide • Norrmalmstryckeriet</p>
          <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[820px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
            Allt du behöver veta om blad och reklamblad.
          </h1>
          <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[680px] mb-[24px] sm:mb-[28px]" style="text-wrap: pretty;">
            Ett pappersark. Ett budskap. En tydlig avsändare. Den enkla trycksaken som fortfarande gör jobbet — när format, papper, tryckmetod och efterbehandling samspelar.
          </p>
          <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px]">
            <a href="/produkter/blad/infografik" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
            <a href="/offert" class="btn-pill w-full sm:w-auto justify-center" style="background: #222; color: #fff;">
              Begär offert<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>

        <!-- Höger: PDF-teaser (samma som landningssidan) -->
        <div class="pdf-teaser-wrap">
          <div class="pdf-teaser">
            <img
              src="/images/infografik/blad-guide-teaser.webp"
              alt="Förhandsvisning av guiden Så skapar du ett reklamblad som gör jobbet (PDF)"
              loading="eager"
              decoding="async"
            />
            <span class="pdf-badge">PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR LÄSA DEN HÄR GUIDEN?" — 2-kol intro (page-content/produkt-mönster) ═══ -->
  <section class="page-section form-section-cover">
    <div class="page-content">
      <p class="section-label">Varför läsa den här guiden?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          Ett blad kan verka enkelt. <em>Men rätt gjort blir det ett av dina mest användbara verktyg.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            Den här guiden hjälper dig fatta rätt beslut innan du trycker — så att bladet faktiskt gör det jobb det är till för.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Förstå när blad fungerar bättre än andra trycksaker</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Välj rätt format, papper och tryckmetod för uppdraget</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Få en beslutsmodell i 8 steg från idé till färdig trycksak</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Lär dig facktermerna: 4+0, CMYK, utfall, FOGRA, perforering, prägling</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="#beslutsmodell" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Till beslutsmodellen<Fragment set:html={arrowSvg} />
            </a>
            <a href="/produkter/blad/infografik" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VAD ÄR ETT BLAD? ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Definition</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
        Vad är ett blad?
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px] mb-[32px] sm:mb-[40px]" style="text-wrap: pretty;">
        <p>I tryckerisammanhang är ett blad en trycksak utan falsning, klammer eller limbindning — alltså ett löst ark i ett bestämt format. Vanliga format är A6, A5 och A4. Större format som 50×70 eller 70×100 brukar istället kallas <a href="/produkter/affischer" class="underline hover:text-[#222]">affisch</a>.</p>
        <p>Ett blad kan tryckas på en sida eller två. I trycktermer skrivs det så här:</p>
      </div>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Tryckterm</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Betyder</th>
            </tr>
          </thead>
          <tbody>
            {tryckTermer.map(([term, desc], i) => (
              <tr class={i < tryckTermer.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[15px] sm:text-[16px] text-[#222] font-mono">{term}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[14px] sm:text-[15px] text-[#444]">{desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] text-[#666] mt-[20px] italic">
        För de flesta moderna reklamblad används fyrfärgstryck (CMYK) — det ger fri tillgång till bilder, färgytor och grafik i fullfärg.
      </p>
    </div>
  </section>

  <!-- ═══ "8 BESLUT" — sidoscroll-kort (samma som produktsidornas scenarier) ═══ -->
  <section id="beslutsmodell" class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Beslutsmodell</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Så skapar du ett reklamblad som gör jobbet.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Åtta beslut som styr om bladet faktiskt landar hos mottagaren — från uppgift och format till tryck och efterbehandling.
      </p>
    </div>
    <div id="steps-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {steps.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[340px] sm:min-h-[380px]">
          <span class="font-[var(--font-heading)] text-[#D9222A] text-[36px] sm:text-[44px] leading-none mb-[16px] sm:mb-[20px]">{s.no}</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.625rem); line-height: 1.2;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444]">{s.body}</p>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="steps-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="steps-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ FORMAT-TABELL ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Format</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Välj storlek efter situationen.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Ett mindre format känns snabbt och lätt att dela ut. Ett större format ger mer plats för bilder och argument. Ett avvikande format skapar uppmärksamhet.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Format</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Passar ofta till</th>
            </tr>
          </thead>
          <tbody>
            {format.map(([f, d], i) => (
              <tr class={i < format.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{f}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk rundad — samma som produktsidor) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
          Papper, tryck och efterbehandling.
        </h2>
        <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] mb-[40px] sm:mb-[60px] md:mb-[80px] max-w-[720px]">
          Tre val som styr om bladet känns rätt i handen, syns i bruset och håller över tid.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px]">
          {expertise.map((e) => (
            <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[24px] sm:p-[28px] lg:p-[39px]">
              <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[14px] sm:mb-[20px]" style="font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem); line-height: 1.2;">{e.title}</h3>
              <p class="!text-white/70 text-[14px] sm:text-[15px] leading-relaxed mb-[18px] sm:mb-[24px]">{e.intro}</p>
              <div class="space-y-[12px] sm:space-y-[14px]">
                {e.items.map(([term, desc]) => (
                  <p class="text-[13px] sm:text-[14px] leading-relaxed !text-white/80">
                    <strong class="!text-white font-bold">{term}</strong> – {desc}
                  </p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ORIGINAL & TRYCKFIL ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Original</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Original och tryckfil — så blir resultatet bättre.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        För att ett blad ska bli bra i tryck behöver originalet vara rätt förberett. Det handlar bland annat om:
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Del</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Rekommendation</th>
            </tr>
          </thead>
          <tbody>
            {tryckfil.map(([d, r], i) => (
              <tr class={i < tryckfil.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{d}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{r}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        Norrmalmstryckeriet arbetar enligt europeisk standard för offsettryck och använder <strong class="text-[#222]">PSOcoated_v3 FOGRA51</strong> för bestruket papper och <strong class="text-[#222]">PSOuncoated_v3 FOGRA52</strong> för obestruket. Osäker? Fråga tidigt — vi kontrollerar gärna originalet innan jobbet går vidare.
      </p>
    </div>
  </section>

  <!-- ═══ NEDLADDNINGS-CTA (mitt i artikeln) ═══ -->
  <section class="pt-[16px] pb-[16px] sm:pt-[24px] sm:pb-[24px]">
    <div class="page-container max-w-[1140px] px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px]">
      <div class="bg-[#D9222A] rounded-[20px] sm:rounded-[28px] px-[24px] sm:px-[40px] md:px-[56px] py-[36px] sm:py-[48px] md:py-[56px] grid md:grid-cols-[1fr_auto] gap-[24px] md:gap-[40px] items-center">
        <div>
          <p class="!text-white/80 uppercase font-medium text-[10px] sm:text-[11px] mb-[10px]" style="letter-spacing: 1.5px;">Gratis nedladdning</p>
          <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[8px] sm:mb-[10px]" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.2; text-wrap: balance;">
            Vill du ha hela guiden som PDF?
          </h3>
          <p class="!text-white/90 text-[14px] sm:text-[15px] leading-relaxed max-w-[520px]">
            En beslutsmodell i 8 steg + checklista, tryckfacktermer, format, papper, efterbehandling och original — i ett enda paket.
          </p>
        </div>
        <a href="/produkter/blad/infografik" class="btn-pill w-full md:w-auto justify-center md:justify-start whitespace-nowrap" style="background: #fff; color: #222;">
          Ladda ner guiden<Fragment set:html={downloadSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ BESLUTSFRÅGOR ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Sex frågor</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Sex frågor att svara på innan layouten är klar.
      </h2>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Fråga</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Varför det spelar roll</th>
            </tr>
          </thead>
          <tbody>
            {beslut.map(([q, r], i) => (
              <tr class={i < beslut.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{q}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{r}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        Det bästa reklambladet är sällan det med mest information. Det är det som hjälper mottagaren att snabbt förstå <strong class="text-[#222]">varför budskapet är relevant.</strong>
      </p>
    </div>
  </section>

  <!-- ═══ SAMMANFATTNING ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[820px]">
      <p class="section-label">Sammanfattning</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Blad och reklamblad — på kort.
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px]" style="text-wrap: pretty;">
        <p>Ett blad är en enkel, flexibel och effektiv trycksak — reklamblad, informationsblad, säljblad, produktblad, menyblad, kupong eller flyer.</p>
        <p>Resultatet påverkas av format, papper, tryckmetod, färger, original och efterbehandling. Därför lönar det sig att tänka igenom syftet innan produktionen startar.</p>
        <p>Hos Norrmalmstryckeriet hjälper vi dig att välja rätt lösning från början — så att bladet känns rätt, fungerar praktiskt och representerar ditt budskap på bästa sätt.</p>
      </div>
    </div>
  </section>

  <!-- ═══ SLUT-CTA (mörk rundad) ═══ -->
  <section class="page-section pt-0">
    <div class="page-container max-w-[1300px]">
      <div class="bg-[#222] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] px-[24px] sm:px-[44px] md:px-[60px] lg:px-[80px] py-[48px] sm:py-[72px] md:py-[96px] grid lg:grid-cols-[1.3fr_1fr] gap-[32px] lg:gap-[60px] items-center">
        <div>
          <p class="section-label" style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Behöver du trycka blad?</p>
          <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[24px]" style="font-size: clamp(1.75rem, 4vw, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
            Berätta vad bladet ska göra — vi hjälper med resten.
          </h2>
          <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed" style="text-wrap: pretty;">
            Skicka original eller en kort beskrivning. Vi rekommenderar format, papper, tryckmetod och efterbehandling — och ger dig en tydlig offert.
          </p>
        </div>
        <div class="flex flex-col gap-[12px]">
          <a href="/offert" class="btn-pill btn-red w-full justify-center">
            Begär offert på blad<Fragment set:html={arrowSvg} />
          </a>
          <a href="/produkter/blad/infografik" class="btn-pill w-full justify-center" style="background: white; color: #222;">
            Ladda ner guiden (PDF)<Fragment set:html={downloadSvg} />
          </a>
          <a href="/produkter/blad" class="btn-pill w-full justify-center" style="background: rgba(255,255,255,0.10); color: #fff;">
            Se produktsidan<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-container {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-section {
    padding-top: 56px;
    padding-bottom: 56px;
    padding-left: 16px;
    padding-right: 16px;
  }
  @media (min-width: 640px) {
    .page-section { padding-top: 72px; padding-bottom: 72px; padding-left: 24px; padding-right: 24px; }
  }
  @media (min-width: 768px) {
    .page-section { padding-top: 88px; padding-bottom: 88px; }
  }
  @media (min-width: 1024px) {
    .page-section { padding-top: 112px; padding-bottom: 112px; padding-left: 44px; padding-right: 44px; }
  }

  .page-section-no-px {
    padding-top: 48px;
    padding-bottom: 48px;
  }
  @media (min-width: 640px) {
    .page-section-no-px { padding-top: 56px; padding-bottom: 56px; }
  }
  @media (min-width: 768px) {
    .page-section-no-px { padding-top: 72px; padding-bottom: 72px; }
  }
  @media (min-width: 1024px) {
    .page-section-no-px { padding-top: 88px; padding-bottom: 88px; }
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 500;
    color: #888;
    margin-bottom: 16px;
  }
  @media (min-width: 768px) {
    .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 20px; }
  }

  /* PDF-teaser i hero — kommer upp bakifrån, samma som landningssida */
  .hero-pdf {
    overflow: visible;
    position: relative;
    z-index: 1;
  }
  .form-section-cover {
    position: relative;
    z-index: 2;
    background: #fff;
  }

  .pdf-teaser-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    position: relative;
    margin-bottom: -210px;
  }

  .pdf-teaser {
    position: relative;
    width: 240px;
    max-width: 100%;
    aspect-ratio: 1833 / 2700;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.06),
      0 14px 28px rgba(0,0,0,0.10),
      0 40px 80px rgba(0,0,0,0.18);
    transform: rotate(3deg);
    transform-origin: top center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .pdf-teaser:hover { transform: rotate(3deg) translateY(-6px); }

  .pdf-teaser img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }
  .pdf-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    background: #D9222A;
    color: #fff;
    font-family: var(--font-heading);
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 1.2px;
    padding: 5px 9px;
    border-radius: 4px;
    text-transform: uppercase;
    z-index: 2;
  }

  @media (min-width: 640px) {
    .pdf-teaser-wrap { margin-bottom: -240px; }
    .pdf-teaser { width: 280px; }
  }
  @media (min-width: 1024px) {
    .pdf-teaser-wrap { align-self: end; margin-bottom: -300px; }
    .pdf-teaser { width: 360px; }
  }
  @media (min-width: 1440px) {
    .pdf-teaser-wrap { margin-bottom: -340px; }
    .pdf-teaser { width: 400px; }
  }
</style>

<script>
  function initGuide() {
    const carousel = document.getElementById('steps-carousel');
    const cardWidth = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('steps-prev')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
    });
    document.getElementById('steps-next')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' });
    });
  }
  initGuide();
  document.addEventListener('astro:after-swap', initGuide);
</script>
