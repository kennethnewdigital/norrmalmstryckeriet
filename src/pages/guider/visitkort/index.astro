---
import Layout from '../../../layouts/Layout.astro';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
const downloadSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>`;

// "Beslutsmodell" — sidoscroll-kort
const steps = [
  { no: '01', title: 'Börja med situationen', body: 'Var ska kortet användas — säljmöte, mässa, nätverk, premium? Det styr format, papper och finish.' },
  { no: '02', title: 'Välj format', body: '90×55, 85×55, stående, kvadratiskt, rundade hörn eller specialformat. Formatet ska kännas naturligt att lämna över.' },
  { no: '03', title: 'Välj papper eller kartong', body: '300–350 g för standard, 400 g+ för premium, obestruket för taktilt, bestruket för skarp färg. Mottagaren känner materialet direkt.' },
  { no: '04', title: 'Bestäm innehållet', body: 'Namn, titel, företag, logotyp, telefon, e-post, webb och ev. QR-kod. Tydlig hierarki ger ett professionellt intryck.' },
  { no: '05', title: 'Framsida & baksida', body: 'Framsidan bär namn och kontakt, baksidan logotyp, QR-kod, payoff eller webb. Två sidor ger mer luft och balans.' },
  { no: '06', title: 'Lägg till QR-kod med syfte', body: 'Digitalt kontaktkort, LinkedIn, bokning, webb eller portfolio. Ge koden luft omkring sig — och testa den innan tryck.' },
  { no: '07', title: 'Välj efterbehandling', body: 'Matt/blank/soft touch-laminering, partiell UV-lack, foliering, prägling, rundade hörn eller stansning — när det stärker känslan.' },
  { no: '08', title: 'Kontrollera originalet', body: 'Rätt slutformat, utfall, säkerhetsmarginal, tryckbar logotyp, korrekturläst text, testad QR-kod och tryckfärdig PDF.' },
];

// Expertis-block
const expertise = [
  {
    title: 'Format & papper',
    intro: 'Mottagaren känner materialet innan informationen är färdigläst. Papper och format är strategiska val.',
    items: [
      ['90 × 55 mm', 'Klassiskt och tydligt — passar de flesta företag.'],
      ['85 × 55 mm', 'Smidigt europeiskt format för konsulter och byråer.'],
      ['Stående / kvadratiskt', 'Mer personligt och profilerat — kreativa yrken och premium.'],
      ['300–400 g kartong', 'Stabil standard till premium med tyngd i handen.'],
      ['Obestruket / miljöpapper', 'Naturlig taktil känsla eller ansvarsfull profil.'],
    ],
  },
  {
    title: 'Tryck & QR',
    intro: 'Ett visitkort ger rätt information i rätt ordning — och en enkel väg vidare för mottagaren.',
    items: [
      ['4+0 / 4+4', 'Enkelsidigt rent och enkelt, eller dubbelsidigt med mer varumärkesyta.'],
      ['CMYK', 'Standard för fyrfärgstryck.'],
      ['Pantone / dekorfärg', 'Exakt kulör när varumärkesfärgen måste sitta.'],
      ['QR-kod', 'Kontaktkort, LinkedIn, bokning eller portfolio — testa alltid före tryck.'],
      ['Digital / offset', 'Digital för små serier och namnversioner, offset för volym.'],
    ],
  },
  {
    title: 'Efterbehandling',
    intro: 'Efterbehandling gör kortet mer taktilt, hållbart och minnesvärt — när den har en tydlig roll.',
    items: [
      ['Laminering', 'Matt, blank eller soft touch — skydd och rätt yta.'],
      ['Partiell UV-lack', 'Markerar logotyp, namn eller grafisk detalj.'],
      ['Foliering', 'Metallisk effekt i guld, silver eller färgfolie.'],
      ['Prägling', 'Upphöjd eller nedsänkt taktil känsla.'],
      ['Rundade hörn / stansning', 'Mjukare form eller en egen, särskiljande detalj.'],
    ],
  },
];

// Tryck-termer
const tryckTermer = [
  ['4+0', 'Fyrfärgstryck på ena sidan'],
  ['4+4', 'Fyrfärgstryck på båda sidor'],
  ['1+0', 'Enfärgstryck på ena sidan'],
  ['1+1', 'Enfärgstryck på båda sidor'],
  ['CMYK', 'Standard för fyrfärgstryck'],
  ['Pantone / dekorfärg', 'Särskild färg för exaktare kulör eller varumärkesfärg'],
];

// Innehåll på kortet
const innehall = [
  ['Namn', 'Ska vara lätt att hitta'],
  ['Titel / roll', 'Hjälper mottagaren förstå sammanhanget'],
  ['Företagsnamn', 'Kopplar personen till varumärket'],
  ['Logotyp', 'Skapar igenkänning'],
  ['Telefon & e-post', 'Direkta kontaktvägar och vanligaste uppföljningen'],
  ['Webbadress', 'Leder vidare'],
  ['QR-kod', 'Bra för bokning, kontaktkort, LinkedIn eller landningssida'],
  ['Adress', 'Relevant för lokala företag, butik och besök'],
];

// QR-mål
const qrMal = [
  ['Digitalt kontaktkort', 'Snabb sparning i mobilen'],
  ['LinkedIn-profil', 'Nätverkande och personlig profil'],
  ['Bokningssida', 'Konsulter, rådgivare, säljare'],
  ['Företagets webbplats', 'Allmän kontakt och varumärke'],
  ['Kampanjsida', 'Mässor, event och särskilda erbjudanden'],
  ['Portfolio / case', 'Kreativa yrken, byråer, produktion'],
];

// Original-checklista
const tryckfil = [
  ['Slutformat', 'Ange exakt färdigt format'],
  ['Utfall', 'Lägg till utfall om färg eller bild går till kant'],
  ['Säkerhetsmarginal', 'Placera text och logotyp en bit från skärkanten'],
  ['Bildkvalitet', 'Använd tryckbar upplösning'],
  ['Typsnitt', 'Bädda in eller skapa konturer vid behov'],
  ['QR-kod', 'Testa innan filen skickas'],
  ['PDF', 'Leverera tryckfärdig PDF enligt tryckeriets instruktioner'],
];
---

<Layout
  title="Trycka visitkort – guide till format, papper, design och finish | Norrmalmstryckeriet"
  description="Lär dig vad du bör tänka på när du ska trycka visitkort. Guide till format, papper, kartong, QR-kod, tryck, foliering, prägling och original."
>

  <!-- ═══ HERO ═══ -->
  <section class="page-section hero-pdf bg-[#F3F3F3]">
    <div class="page-container">
      <div class="grid lg:grid-cols-[1fr_auto] gap-[40px] md:gap-[60px] lg:gap-[80px] items-center lg:items-end">
        <div>
          <p class="section-label">Guide • Norrmalmstryckeriet</p>
          <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[820px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
            Allt du behöver veta om visitkort.
          </h1>
          <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[680px] mb-[24px] sm:mb-[28px]" style="text-wrap: pretty;">
            Den lilla trycksaken som bär ett stort intryck. Litet till formatet, men stort i betydelse — när papper, format, tryck, typografi och finish samspelar blir visitkortet en tydlig del av varumärket.
          </p>
          <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px]">
            <a href="/produkter/visitkort/infografik" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
            <a href="/offert" class="btn-pill w-full sm:w-auto justify-center" style="background: #222; color: #fff;">
              Begär offert<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>

        <div class="pdf-teaser-wrap">
          <div class="pdf-teaser">
            <img src="/images/infografik/visitkort-guide-teaser.webp" alt="Förhandsvisning av guiden Så skapar du ett visitkort som blir ihågkommet (PDF)" loading="eager" decoding="async" />
            <span class="pdf-badge">PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR LÄSA DEN HÄR GUIDEN?" ═══ -->
  <section class="page-section form-section-cover">
    <div class="page-content">
      <p class="section-label">Varför läsa den här guiden?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          Ett visitkort handlar om mer än kontaktuppgifter. <em>Det handlar om första intrycket.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            Visitkortet är ofta det sista du lämnar kvar efter ett möte. Det ska vara lätt att läsa, enkelt att spara och tydligt kopplat till ditt varumärke. Den här guiden hjälper dig fatta rätt beslut innan du trycker.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Välj format, papper och kartong efter varumärket</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Förstå när QR-kod, foliering och prägling gör nytta</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Få en beslutsmodell i 8 steg från idé till färdigt kort</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Lär dig facktermerna: 4+4, CMYK, dekorfärg, utfall, UV-lack</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="#beslutsmodell" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Till beslutsmodellen<Fragment set:html={arrowSvg} />
            </a>
            <a href="/produkter/visitkort/infografik" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VAD ÄR ETT VISITKORT? ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Definition</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
        Vad är ett visitkort?
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px] mb-[32px] sm:mb-[40px]" style="text-wrap: pretty;">
        <p>En liten trycksak med person- och företagsinformation — namn, titel, företag, logotyp, telefon, e-post, webb och ibland QR-kod. Vanliga format är 90 × 55 mm eller 85 × 55 mm, men kortet kan också göras kvadratiskt, stående eller med rundade hörn.</p>
        <p>Visitkort trycks ofta på kraftigare papper eller kartong för att kännas stabila i handen, på en eller båda sidor:</p>
      </div>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Tryckterm</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Betyder</th>
            </tr>
          </thead>
          <tbody>
            {tryckTermer.map(([term, desc], i) => (
              <tr class={i < tryckTermer.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{term}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[14px] sm:text-[15px] text-[#444]">{desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] text-[#666] mt-[20px] italic">
        4+4 är ofta ett bra val — framsidan bär namn och kontakt medan baksidan kan användas för logotyp, QR-kod, payoff eller ett kort budskap.
      </p>
    </div>
  </section>

  <!-- ═══ "8 BESLUT" — sidoscroll-kort ═══ -->
  <section id="beslutsmodell" class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Beslutsmodell</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Så skapar du ett visitkort som blir ihågkommet.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Åtta beslut som styr om kortet känns professionellt och leder mottagaren vidare — från situation och format till finish och original.
      </p>
    </div>
    <div id="steps-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {steps.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[340px] sm:min-h-[380px]">
          <span class="font-[var(--font-heading)] text-[#D9222A] text-[36px] sm:text-[44px] leading-none mb-[16px] sm:mb-[20px]">{s.no}</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.625rem); line-height: 1.2;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444]">{s.body}</p>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="steps-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="steps-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ INNEHÅLL PÅ KORTET ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Innehåll</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Tydlighet före mängd.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Ett visitkort har begränsat utrymme — varje detalj behöver förtjäna sin plats. Kortet ska vara lätt att läsa på några sekunder.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Innehåll</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Kommentar</th>
            </tr>
          </thead>
          <tbody>
            {innehall.map(([c, k], i) => (
              <tr class={i < innehall.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{c}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{k}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk rundad) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
          Format, papper, tryck och finish.
        </h2>
        <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] mb-[40px] sm:mb-[60px] md:mb-[80px] max-w-[720px]">
          Fyra val som styr om visitkortet känns rätt i handen, är lätt att läsa och representerar varumärket.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px]">
          {expertise.map((e) => (
            <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[24px] sm:p-[28px] lg:p-[39px]">
              <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[14px] sm:mb-[20px]" style="font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem); line-height: 1.2;">{e.title}</h3>
              <p class="!text-white/70 text-[14px] sm:text-[15px] leading-relaxed mb-[18px] sm:mb-[24px]">{e.intro}</p>
              <div class="space-y-[12px] sm:space-y-[14px]">
                {e.items.map(([term, desc]) => (
                  <p class="text-[13px] sm:text-[14px] leading-relaxed !text-white/80">
                    <strong class="!text-white font-bold">{term}</strong> – {desc}
                  </p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ QR-KOD ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">QR-kod</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Koppla det fysiska kortet till en digital kontaktväg.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        En QR-kod gör nästa steg enklare. Placera den så att den har luft omkring sig och går att scanna — och <strong class="text-[#222]">testa alltid koden innan tryck</strong>.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">QR-koden leder till</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">När det passar</th>
            </tr>
          </thead>
          <tbody>
            {qrMal.map(([m, n], i) => (
              <tr class={i < qrMal.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{m}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{n}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ NEDLADDNINGS-CTA ═══ -->
  <section class="pt-[16px] pb-[16px] sm:pt-[24px] sm:pb-[24px]">
    <div class="page-container max-w-[1140px] px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px]">
      <div class="bg-[#D9222A] rounded-[20px] sm:rounded-[28px] px-[24px] sm:px-[40px] md:px-[56px] py-[36px] sm:py-[48px] md:py-[56px] grid md:grid-cols-[1fr_auto] gap-[24px] md:gap-[40px] items-center">
        <div>
          <p class="!text-white/80 uppercase font-medium text-[10px] sm:text-[11px] mb-[10px]" style="letter-spacing: 1.5px;">Gratis nedladdning</p>
          <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[8px] sm:mb-[10px]" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.2; text-wrap: balance;">
            Vill du ha hela guiden som PDF?
          </h3>
          <p class="!text-white/90 text-[14px] sm:text-[15px] leading-relaxed max-w-[520px]">
            Beslutsmodell i steg, format, papper, QR-kod, efterbehandling och en originalchecklista — i ett enda paket.
          </p>
        </div>
        <a href="/produkter/visitkort/infografik" class="btn-pill w-full md:w-auto justify-center md:justify-start whitespace-nowrap" style="background: #fff; color: #222;">
          Ladda ner guiden<Fragment set:html={downloadSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ ORIGINAL ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Original</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Original till visitkort.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Visitkort innehåller få uppgifter — därför syns varje detalj tydligt. Kontrollera namn, titel, telefon, e-post och webbadress extra noggrant.
      </p>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Kontrollpunkt</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Rekommendation</th>
            </tr>
          </thead>
          <tbody>
            {tryckfil.map(([d, r], i) => (
              <tr class={i < tryckfil.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{d}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{r}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        Norrmalmstryckeriet arbetar enligt <strong class="text-[#222]">ISO 12647-2:2013</strong> och använder <strong class="text-[#222]">PSOcoated_v3 FOGRA51</strong> för bestruket och <strong class="text-[#222]">PSOuncoated_v3 FOGRA52</strong> för obestruket papper. Vi hjälper gärna till med profiler, joboptions och kontroll av materialet innan produktion.
      </p>
    </div>
  </section>

  <!-- ═══ SLUT-CTA (mörk rundad) ═══ -->
  <section class="page-section pt-0">
    <div class="page-container max-w-[1300px]">
      <div class="bg-[#222] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] px-[24px] sm:px-[44px] md:px-[60px] lg:px-[80px] py-[48px] sm:py-[72px] md:py-[96px] grid lg:grid-cols-[1.3fr_1fr] gap-[32px] lg:gap-[60px] items-center">
        <div>
          <p class="section-label" style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Behöver du trycka visitkort?</p>
          <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[24px]" style="font-size: clamp(1.75rem, 4vw, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
            Skicka din logotyp eller profil — vi hjälper med resten.
          </h2>
          <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed" style="text-wrap: pretty;">
            Skicka din grafiska profil eller ett färdigt original. Vi hjälper dig med format, papper, tryckmetod, efterbehandling och upplaga — och ger dig en tydlig offert.
          </p>
        </div>
        <div class="flex flex-col gap-[12px]">
          <a href="/offert" class="btn-pill btn-red w-full justify-center">
            Begär offert på visitkort<Fragment set:html={arrowSvg} />
          </a>
          <a href="/produkter/visitkort/infografik" class="btn-pill w-full justify-center" style="background: white; color: #222;">
            Ladda ner guiden (PDF)<Fragment set:html={downloadSvg} />
          </a>
          <a href="/produkter/visitkort" class="btn-pill w-full justify-center" style="background: rgba(255,255,255,0.10); color: #fff;">
            Se produktsidan<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-container {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-section {
    padding-top: 56px;
    padding-bottom: 56px;
    padding-left: 16px;
    padding-right: 16px;
  }
  @media (min-width: 640px) {
    .page-section { padding-top: 72px; padding-bottom: 72px; padding-left: 24px; padding-right: 24px; }
  }
  @media (min-width: 768px) {
    .page-section { padding-top: 88px; padding-bottom: 88px; }
  }
  @media (min-width: 1024px) {
    .page-section { padding-top: 112px; padding-bottom: 112px; padding-left: 44px; padding-right: 44px; }
  }

  .page-section-no-px {
    padding-top: 48px;
    padding-bottom: 48px;
  }
  @media (min-width: 640px) {
    .page-section-no-px { padding-top: 56px; padding-bottom: 56px; }
  }
  @media (min-width: 768px) {
    .page-section-no-px { padding-top: 72px; padding-bottom: 72px; }
  }
  @media (min-width: 1024px) {
    .page-section-no-px { padding-top: 88px; padding-bottom: 88px; }
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 500;
    color: #888;
    margin-bottom: 16px;
  }
  @media (min-width: 768px) {
    .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 20px; }
  }

  /* PDF-teaser i hero — kommer upp bakifrån */
  .hero-pdf { overflow: visible; position: relative; z-index: 1; }
  .form-section-cover { position: relative; z-index: 2; background: #fff; }

  .pdf-teaser-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    position: relative;
    margin-bottom: -210px;
  }
  .pdf-teaser {
    position: relative;
    width: 240px;
    max-width: 100%;
    aspect-ratio: 1833 / 2700;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.06),
      0 14px 28px rgba(0,0,0,0.10),
      0 40px 80px rgba(0,0,0,0.18);
    transform: rotate(3deg);
    transform-origin: top center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .pdf-teaser:hover { transform: rotate(3deg) translateY(-6px); }
  .pdf-teaser img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .pdf-badge {
    position: absolute; top: 12px; right: 12px;
    background: #D9222A; color: #fff;
    font-family: var(--font-heading);
    font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
    padding: 5px 9px; border-radius: 4px;
    text-transform: uppercase; z-index: 2;
  }
  @media (min-width: 640px) { .pdf-teaser-wrap { margin-bottom: -240px; } .pdf-teaser { width: 280px; } }
  @media (min-width: 1024px) { .pdf-teaser-wrap { align-self: end; margin-bottom: -300px; } .pdf-teaser { width: 360px; } }
  @media (min-width: 1440px) { .pdf-teaser-wrap { margin-bottom: -340px; } .pdf-teaser { width: 400px; } }
</style>

<script>
  function initGuide() {
    const carousel = document.getElementById('steps-carousel');
    const cardWidth = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('steps-prev')?.addEventListener('click', () => { carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' }); });
    document.getElementById('steps-next')?.addEventListener('click', () => { carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' }); });
  }
  initGuide();
  document.addEventListener('astro:after-swap', initGuide);
</script>
