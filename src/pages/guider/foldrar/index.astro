---
import Layout from '../../../layouts/Layout.astro';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
const downloadSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>`;

// "Beslutsmodell" — sidoscroll-kort
const steps = [
  { no: '01', title: 'Börja med uppgiften', body: 'Vad ska foldern hjälpa mottagaren att göra? Presentera, förklara, visa produkt eller guida — det styr format och falsning.' },
  { no: '02', title: 'Välj rätt foldertyp', body: '4-sidig A5, 6-sidig DL, Z-fals, rullfals, portfals eller kartfals. Vikningen påverkar hur mottagaren läser.' },
  { no: '03', title: 'Planoformat & färdigformat', body: 'Det öppna formatet styr layouten, det vikta styr hur foldern känns i handen och hur den distribueras.' },
  { no: '04', title: 'Gör en dummy', body: 'Vik en provfolder för hand och kontrollera sidordning, framsida, baksida och läsriktning innan original.' },
  { no: '05', title: 'Anpassa panelerna', body: 'Vid rullfals behöver den invikta panelen vara något smalare — annars spänner och buktar foldern.' },
  { no: '06', title: 'Välj papper efter funktion', body: 'Tunnare för många veck och utskick, kraftigare för premiumkänsla. Bigning vid tjockare papper.' },
  { no: '07', title: 'Välj tryckmetod', body: 'Digitaltryck för mindre upplagor och versioner, offsettryck för volym med jämn färg och lågt styckpris.' },
  { no: '08', title: 'Bygg som en berättelse', body: 'Framsida väcker intresse, öppningen ger sammanhang, insidorna förklarar, sista sidan leder vidare.' },
];

// Expertis-block (samma struktur som produktsidor)
const expertise = [
  {
    title: 'Format & falsning',
    intro: 'Falsningen gör en folder till en folder — och styr hur mottagaren läser innehållet.',
    items: [
      ['4-sidig A5', 'Tydlig och stabil. Företagspresentation, produktblad, tjänsteinformation.'],
      ['6-sidig DL', 'Smidig och klassisk. Kampanj, mässa, utskick — 99 × 210 mm.'],
      ['Z-fals', 'Pedagogisk steg-för-steg-struktur för program och process.'],
      ['Rullfals', 'Sidorna viks in i varandra — sammanhållen säljfolder.'],
      ['Portfals / kartfals', 'Inbjudan och premium, eller kartor, guider och instruktioner.'],
    ],
  },
  {
    title: 'Papper',
    intro: 'Pappret påverkar både känslan och falsningen. En folder med många veck kräver ett mer följsamt papper.',
    items: [
      ['Tunnare papper', 'Smidigt vid många veck och stora utskick.'],
      ['Mellantjockt', 'Bra balans för vanliga företagsfoldrar och mässmaterial.'],
      ['Kraftigare papper', 'Mer stabilitet och högre kvalitetskänsla.'],
      ['Bestruket', 'Skarpare bilder och tydligare färger för kampanjmaterial.'],
      ['Obestruket / bigning', 'Naturlig taktil känsla — bigning ger renare vikning på tjockt papper.'],
    ],
  },
  {
    title: 'Tryck & original',
    intro: 'Folder kräver lite mer planering — originalet måste stämma med falsschemat och panelbredderna.',
    items: [
      ['Digitaltryck', 'Mindre upplagor, snabb produktion och versionerade foldrar.'],
      ['Offsettryck', 'Större upplagor, jämn färg och lågt styckpris i volym.'],
      ['Falsschema', 'Bestämmer hur foldern viks och vilka paneler som hamnar inåt.'],
      ['Panelbredder', 'Invikta paneler justeras någon mm för att foldern ska stänga snyggt.'],
      ['Utfall & PDF', 'Utfall där bild går till kant, tryckfärdig PDF enligt instruktion.'],
    ],
  },
];

// Folder-termer
const folderTermer = [
  ['Planoformat', 'Det öppna, ovikta formatet före falsning'],
  ['Färdigformat', 'Det slutliga formatet när foldern är vikt'],
  ['Falsning', 'Själva vikningen av arket'],
  ['Falsschema', 'Planen för hur arket ska vikas'],
  ['Dummy', 'Ett fysiskt prov där man viker foldern för att kontrollera sidordning'],
  ['Bigning', 'En förpressad viklinje som hjälper tjockare papper att vikas snyggt'],
];

// Falsningar
const falsningar = [
  ['Enkel fals', 'Ett veck, t.ex. A4 → 4-sidig A5 — tydliga presentationer'],
  ['Rullfals', 'Sidorna viks in i varandra — 6-sidiga foldrar, kampanjer, utskick'],
  ['Z-fals', 'Arket viks som ett Z — steg-för-steg-information, program'],
  ['Portfals', 'Två sidor viks in mot mitten — inbjudningar, premiumkänsla'],
  ['Korsfals', 'Vikningar åt två håll — kartor, instruktioner, större ytor'],
  ['Kartfals', 'Flera veck som fälls ut till större yta — guider, turism'],
];

// Original / tryckfil
const tryckfil = [
  ['Planoformat', 'Utgå från det öppna formatet'],
  ['Falsschema', 'Bestäm hur foldern ska vikas innan layout'],
  ['Panelbredder', 'Anpassa invikta paneler vid behov'],
  ['Utfall', 'Lägg utfall där färg eller bild går till kant'],
  ['Säker marginal', 'Placera viktig text en bit från fals och skärkant'],
  ['Dummy', 'Skicka gärna med bild eller skiss på hur foldern ska vikas'],
];
---

<Layout
  title="Trycka foldrar – guide till format, falsning, papper och original | Norrmalmstryckeriet"
  description="Lär dig vad du bör tänka på när du ska trycka foldrar. Guide till format, falsning, planoformat, papper, digitaltryck, offsettryck och original."
>

  <!-- ═══ HERO (samma mönster som nedladdningssidan) ═══ -->
  <section class="page-section hero-pdf bg-[#F3F3F3]">
    <div class="page-container">
      <div class="grid lg:grid-cols-[1fr_auto] gap-[40px] md:gap-[60px] lg:gap-[80px] items-center lg:items-end">
        <div>
          <p class="section-label">Guide • Norrmalmstryckeriet</p>
          <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[820px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
            Allt du behöver veta om foldrar.
          </h1>
          <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[680px] mb-[24px] sm:mb-[28px]" style="text-wrap: pretty;">
            Trycksaken som växer när mottagaren öppnar den. Ett ark, en vikning — och plötsligt flera ytor och en tydligare berättelse. När format, falsning, papper och budskap samspelar leder foldern mottagaren rätt.
          </p>
          <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px]">
            <a href="/produkter/foldrar/infografik" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
            <a href="/offert" class="btn-pill w-full sm:w-auto justify-center" style="background: #222; color: #fff;">
              Begär offert<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>

        <div class="pdf-teaser-wrap">
          <div class="pdf-teaser">
            <img src="/images/infografik/foldrar-guide-teaser.webp" alt="Förhandsvisning av guiden Så skapar du en folder som leder mottagaren rätt (PDF)" loading="eager" decoding="async" />
            <span class="pdf-badge">PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR LÄSA DEN HÄR GUIDEN?" ═══ -->
  <section class="page-section form-section-cover">
    <div class="page-content">
      <p class="section-label">Varför läsa den här guiden?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          En folder är mer än ett vikt ark. <em>Den är en liten berättelse i tryckt form.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            Framsidan väcker intresse. Vikningen skapar ordning. Insidorna förklarar. Baksidan leder vidare. Den här guiden hjälper dig fatta rätt beslut innan du trycker.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Förstå skillnaden mellan folder och broschyr</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Välj rätt falsning och format för ditt budskap</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Få en beslutsmodell i 8 steg från idé till färdig folder</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Lär dig facktermerna: planoformat, falsschema, dummy, bigning</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="#beslutsmodell" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Till beslutsmodellen<Fragment set:html={arrowSvg} />
            </a>
            <a href="/produkter/foldrar/infografik" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VAD ÄR EN FOLDER? ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Definition</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
        Vad är en folder?
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px] mb-[32px] sm:mb-[40px]" style="text-wrap: pretty;">
        <p>En folder är en flersidig trycksak som skapas genom att ett ark falsas — alltså viks. Till skillnad från en <a href="/produkter/broschyrer" class="underline hover:text-[#222]">broschyr</a> hålls foldern ihop av själva vikningen. Ingen klammer, ingen limbindning — sidorna skapas av falsningen.</p>
        <p>Ett A4-ark vikt en gång ger en 4-sidig A5-folder. Ett A4-ark falsat två gånger ger en 6-sidig folder i 99 × 210 mm (DL). Vanliga tryckeritermer:</p>
      </div>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Term</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Betydelse</th>
            </tr>
          </thead>
          <tbody>
            {folderTermer.map(([term, desc], i) => (
              <tr class={i < folderTermer.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{term}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[14px] sm:text-[15px] text-[#444]">{desc}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ "8 BESLUT" — sidoscroll-kort ═══ -->
  <section id="beslutsmodell" class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Beslutsmodell</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Så skapar du en folder som leder mottagaren rätt.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Åtta beslut som styr hur väl foldern guidar mottagaren — från uppgift och falsning till papper och tryck.
      </p>
    </div>
    <div id="steps-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {steps.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[340px] sm:min-h-[380px]">
          <span class="font-[var(--font-heading)] text-[#D9222A] text-[36px] sm:text-[44px] leading-none mb-[16px] sm:mb-[20px]">{s.no}</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.625rem); line-height: 1.2;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444]">{s.body}</p>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="steps-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="steps-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ FALSNINGAR-TABELL ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Falsning</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Falsningen är folderns viktigaste konstruktion.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Varje vikning skapar en ny yta, en ny sekvens och en ny möjlighet att styra läsningen. Tänk på foldern som en liten berättelse: framsida, öppning, fördjupning och avslut.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Falsning</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Beskrivning & användning</th>
            </tr>
          </thead>
          <tbody>
            {falsningar.map(([f, d], i) => (
              <tr class={i < falsningar.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{f}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        <strong class="text-[#222]">Tips:</strong> Vid rullfals och andra invikta konstruktioner behöver den invikta panelen vara <strong class="text-[#222]">någon millimeter smalare</strong> — annars spänner, buktar eller stänger foldern sämre. Rätt panelbredder gör att foldern känns renare och mer professionell i handen.
      </p>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk rundad) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
          Format, falsning, papper och tryck.
        </h2>
        <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] mb-[40px] sm:mb-[60px] md:mb-[80px] max-w-[720px]">
          Fyra val som styr om foldern öppnas snyggt, leder läsaren rätt och känns genomtänkt i handen.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px]">
          {expertise.map((e) => (
            <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[24px] sm:p-[28px] lg:p-[39px]">
              <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[14px] sm:mb-[20px]" style="font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem); line-height: 1.2;">{e.title}</h3>
              <p class="!text-white/70 text-[14px] sm:text-[15px] leading-relaxed mb-[18px] sm:mb-[24px]">{e.intro}</p>
              <div class="space-y-[12px] sm:space-y-[14px]">
                {e.items.map(([term, desc]) => (
                  <p class="text-[13px] sm:text-[14px] leading-relaxed !text-white/80">
                    <strong class="!text-white font-bold">{term}</strong> – {desc}
                  </p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ORIGINAL & DUMMY ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Original</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Original till folder — tänk på sidordning och falsning.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Eftersom sidorna skapas genom vikningen behöver originalet stämma med falsschemat. Gör gärna en <strong class="text-[#222]">dummy</strong> — ett enkelt fysiskt prov där du viker foldern för hand och kontrollerar sidordning, framsida, baksida och läsriktning innan produktion.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Del</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Rekommendation</th>
            </tr>
          </thead>
          <tbody>
            {tryckfil.map(([d, r], i) => (
              <tr class={i < tryckfil.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{d}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{r}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        Norrmalmstryckeriet arbetar enligt europeisk standard för offsettryck och hjälper dig gärna att kontrollera format, falsning, panelbredder och tryckmetod innan produktion.
      </p>
    </div>
  </section>

  <!-- ═══ NEDLADDNINGS-CTA ═══ -->
  <section class="pt-[16px] pb-[16px] sm:pt-[24px] sm:pb-[24px]">
    <div class="page-container max-w-[1140px] px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px]">
      <div class="bg-[#D9222A] rounded-[20px] sm:rounded-[28px] px-[24px] sm:px-[40px] md:px-[56px] py-[36px] sm:py-[48px] md:py-[56px] grid md:grid-cols-[1fr_auto] gap-[24px] md:gap-[40px] items-center">
        <div>
          <p class="!text-white/80 uppercase font-medium text-[10px] sm:text-[11px] mb-[10px]" style="letter-spacing: 1.5px;">Gratis nedladdning</p>
          <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[8px] sm:mb-[10px]" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.2; text-wrap: balance;">
            Vill du ha hela guiden som PDF?
          </h3>
          <p class="!text-white/90 text-[14px] sm:text-[15px] leading-relaxed max-w-[520px]">
            Beslutsmodell i steg, foldertyper, falsningar, dummy-checklista, papper, tryck och originalchecklista — i ett enda paket.
          </p>
        </div>
        <a href="/produkter/foldrar/infografik" class="btn-pill w-full md:w-auto justify-center md:justify-start whitespace-nowrap" style="background: #fff; color: #222;">
          Ladda ner guiden<Fragment set:html={downloadSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ BYGG SOM EN BERÄTTELSE ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Läsordning</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Bygg foldern som en berättelse.
      </h2>
      <div class="grid sm:grid-cols-2 gap-[16px] sm:gap-[20px]">
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Framsida</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Väcker intresse och lovar värde.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Första öppning</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Förklarar vad mottagaren får och ger sammanhang.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Insidor</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Utvecklar argument, visar exempel och skapar förståelse.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Sista sida</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Ger kontaktväg, CTA och praktisk information.</p>
        </div>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        Se inte foldern som sex separata små annonser — se den som en <strong class="text-[#222]">sammanhängande berättelse</strong>. När mottagaren öppnar den ska nästa steg kännas självklart.
      </p>
    </div>
  </section>

  <!-- ═══ SLUT-CTA (mörk rundad) ═══ -->
  <section class="page-section pt-0">
    <div class="page-container max-w-[1300px]">
      <div class="bg-[#222] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] px-[24px] sm:px-[44px] md:px-[60px] lg:px-[80px] py-[48px] sm:py-[72px] md:py-[96px] grid lg:grid-cols-[1.3fr_1fr] gap-[32px] lg:gap-[60px] items-center">
        <div>
          <p class="section-label" style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Behöver du trycka foldrar?</p>
          <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[24px]" style="font-size: clamp(1.75rem, 4vw, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
            Berätta hur foldern ska användas — vi hjälper med resten.
          </h2>
          <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed" style="text-wrap: pretty;">
            Skicka din idé, skiss eller färdiga PDF. Vi kontrollerar format, falsning, papper, panelbredder och tryckmetod innan produktion — och ger dig en tydlig offert.
          </p>
        </div>
        <div class="flex flex-col gap-[12px]">
          <a href="/offert" class="btn-pill btn-red w-full justify-center">
            Begär offert på foldrar<Fragment set:html={arrowSvg} />
          </a>
          <a href="/produkter/foldrar/infografik" class="btn-pill w-full justify-center" style="background: white; color: #222;">
            Ladda ner guiden (PDF)<Fragment set:html={downloadSvg} />
          </a>
          <a href="/produkter/foldrar" class="btn-pill w-full justify-center" style="background: rgba(255,255,255,0.10); color: #fff;">
            Se produktsidan<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-container {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }

  .page-section {
    padding-top: 56px;
    padding-bottom: 56px;
    padding-left: 16px;
    padding-right: 16px;
  }
  @media (min-width: 640px) {
    .page-section { padding-top: 72px; padding-bottom: 72px; padding-left: 24px; padding-right: 24px; }
  }
  @media (min-width: 768px) {
    .page-section { padding-top: 88px; padding-bottom: 88px; }
  }
  @media (min-width: 1024px) {
    .page-section { padding-top: 112px; padding-bottom: 112px; padding-left: 44px; padding-right: 44px; }
  }

  .page-section-no-px {
    padding-top: 48px;
    padding-bottom: 48px;
  }
  @media (min-width: 640px) {
    .page-section-no-px { padding-top: 56px; padding-bottom: 56px; }
  }
  @media (min-width: 768px) {
    .page-section-no-px { padding-top: 72px; padding-bottom: 72px; }
  }
  @media (min-width: 1024px) {
    .page-section-no-px { padding-top: 88px; padding-bottom: 88px; }
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 500;
    color: #888;
    margin-bottom: 16px;
  }
  @media (min-width: 768px) {
    .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 20px; }
  }

  /* PDF-teaser i hero — kommer upp bakifrån */
  .hero-pdf { overflow: visible; position: relative; z-index: 1; }
  .form-section-cover { position: relative; z-index: 2; background: #fff; }

  .pdf-teaser-wrap {
    display: flex;
    justify-content: center;
    align-items: flex-end;
    position: relative;
    margin-bottom: -210px;
  }
  .pdf-teaser {
    position: relative;
    width: 240px;
    max-width: 100%;
    aspect-ratio: 1833 / 2700;
    border-radius: 10px;
    overflow: hidden;
    background: #fff;
    box-shadow:
      0 1px 2px rgba(0,0,0,0.06),
      0 14px 28px rgba(0,0,0,0.10),
      0 40px 80px rgba(0,0,0,0.18);
    transform: rotate(3deg);
    transform-origin: top center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }
  .pdf-teaser:hover { transform: rotate(3deg) translateY(-6px); }
  .pdf-teaser img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .pdf-badge {
    position: absolute; top: 12px; right: 12px;
    background: #D9222A; color: #fff;
    font-family: var(--font-heading);
    font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
    padding: 5px 9px; border-radius: 4px;
    text-transform: uppercase; z-index: 2;
  }
  @media (min-width: 640px) { .pdf-teaser-wrap { margin-bottom: -240px; } .pdf-teaser { width: 280px; } }
  @media (min-width: 1024px) { .pdf-teaser-wrap { align-self: end; margin-bottom: -300px; } .pdf-teaser { width: 360px; } }
  @media (min-width: 1440px) { .pdf-teaser-wrap { margin-bottom: -340px; } .pdf-teaser { width: 400px; } }
</style>

<script>
  function initGuide() {
    const carousel = document.getElementById('steps-carousel');
    const cardWidth = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('steps-prev')?.addEventListener('click', () => { carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' }); });
    document.getElementById('steps-next')?.addEventListener('click', () => { carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' }); });
  }
  initGuide();
  document.addEventListener('astro:after-swap', initGuide);
</script>
