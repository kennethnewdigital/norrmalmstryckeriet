---
import Layout from '../../../layouts/Layout.astro';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
const downloadSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>`;

// Beslutsmodell — sidoscroll-kort (8 steg)
const steps = [
  { no: '01', title: 'Börja med syftet', body: 'Vad ska trycksaken göra? Vem ska ta emot den? Ska den läsas snabbt, sparas länge, skickas, vikas eller hanteras mycket? Syftet styr pappersvalet.' },
  { no: '02', title: 'Bestruket eller obestruket', body: 'Bestruket lyfter bild och färg. Obestruket lyfter känsla och läsbarhet. Mattbestruket är balansen. Blankbestruket ger mest glans.' },
  { no: '03', title: 'Välj gramvikt', body: '80–130 g för inlagor och utskick. 130–170 g för reklamblad och foldrar. 170–250 g för omslag. 250–350 g för visitkort och mappar. 350 g+ för premium.' },
  { no: '04', title: 'Tänk på bulk och opacitet', body: 'Bulk ger volym utan vikt — viktigt i böcker. Opacitet styr om trycket lyser igenom — viktigt vid dubbelsidigt tryck och tunnare papper.' },
  { no: '05', title: 'Yta och känsla', body: 'Blank för bild. Matt för läsbarhet. Silk för balans. Obestruket för taktilt. Strukturerat eller färgat papper för exklusiv identitet.' },
  { no: '06', title: 'Papper möter tryckmetod', body: 'Digitaltryck och offsettryck ställer olika krav. Storformat och planprint styrs av miljö och yta. Pappret ska fungera i hela kedjan.' },
  { no: '07', title: 'Papper möter efterbehandling', body: 'Falsning, bigning, klammerhäftning, limbindning, stansning, prägling, foliering, laminering — papper väljs alltid tillsammans med efterbehandlingen.' },
  { no: '08', title: 'Prov, dummy & rådgivning', body: 'Pappersprov, dummy, provtryck och materialtest — ju viktigare trycksaken är, desto mer värdefullt att testa innan produktion.' },
];

// Expertis-block
const expertise = [
  {
    title: 'Yta & känsla',
    intro: 'Ytan styr hur trycksaken känns och uppfattas — taktil, dämpad eller glansig.',
    items: [
      ['Bestruket', 'Slätare yta, skarpare bildåtergivning och mer intensiva färger.'],
      ['Obestruket', 'Mer öppen och taktil yta — naturlig och lugn känsla.'],
      ['Mattbestruket', 'Dämpat uttryck men bildvänligt — bra för rapporter och profilmaterial.'],
      ['Silk / halvmatt', 'Balansen mellan färgåtergivning och lugn yta.'],
      ['Strukturerat & färgat', 'Stark identitet och mer känslomässig karaktär.'],
    ],
  },
  {
    title: 'Vikt, bulk & opacitet',
    intro: 'Gramvikt är utgångspunkten. Bulk och opacitet avgör hur pappret faktiskt fungerar i handen och vid tryck.',
    items: [
      ['Gramvikt (g/m²)', 'Vikt per kvadratmeter — påverkar stabilitet, vikt och porto.'],
      ['Bulk', 'Tjocklek i förhållande till vikten — viktigt i böcker.'],
      ['Opacitet', 'Hur mycket trycket lyser igenom — viktigt vid dubbelsidigt och tunna papper.'],
      ['Ryggbredd', 'Påverkas av sidantal och bulk vid limbundna produkter.'],
      ['Miljöanpassat papper', 'Ansvarsfull profil från ansvarsfullt skogsbruk.'],
    ],
  },
  {
    title: 'Papper möter produktion',
    intro: 'Papper väljs aldrig isolerat — det ska samspela med tryckmetod, efterbehandling och slutformat.',
    items: [
      ['Digitaltryck', 'Pappret behöver fungera i digitalpress och efterbehandling.'],
      ['Offsettryck', 'Brett pappersval och god färgstabilitet vid volym.'],
      ['Falsning & bigning', 'Tjockare papper kan kräva bigning för ren vikning.'],
      ['Klammerhäftning', 'Sidantal, tjocklek och kryp planeras tillsammans.'],
      ['Laminering & prägling', 'Yta och tjocklek påverkar resultatet.'],
    ],
  },
];

// Termer
const termer = [
  ['Gramvikt (g/m²)', 'Pappers vikt per kvadratmeter'],
  ['Bulk', 'Pappers tjocklek i förhållande till vikten'],
  ['Opacitet', 'Hur täckande eller genomskinligt pappret är'],
  ['Bestruket', 'Papper med behandlad yta för skarpare tryck'],
  ['Obestruket', 'Papper med öppen, naturlig och taktil yta'],
  ['Silk / mattbestruket', 'Bestruket papper med dämpad yta'],
  ['Färgrymd / färgprofil', 'Anpassning av färger efter papper och tryckmetod'],
];

// Gramvikt-tabell
const gramvikt = [
  ['80–100 g/m²', 'Brev, enklare informationsblad, bokinlagor'],
  ['100–130 g/m²', 'Utskick, foldrar och enklare broschyrinlagor'],
  ['130–170 g/m²', 'Reklamblad, foldrar och broschyrer'],
  ['170–250 g/m²', 'Omslag, kraftigare foldrar, vykort och presentationer'],
  ['250–350 g/m²', 'Visitkort, mappar och stabilare trycksaker'],
  ['350 g/m² och uppåt', 'Premiumkort och specialproduktioner'],
];

// Vanliga misstag
const misstag = [
  ['För tjockt papper till folder', 'Svår falsning och risk för sprickor — bigning krävs ofta'],
  ['För tunt papper till dubbelsidigt', 'Genomlysning och sämre läsbarhet'],
  ['Fel papper till bildrikt material', 'Bilderna får inte rätt skärpa eller färg'],
  ['För tungt papper till utskick', 'Högre porto och tyngre hantering'],
  ['För lätt material till mapp', 'Mappen tappar stabilitet'],
  ['Fel yta för efterbehandling', 'Laminering, prägling eller foliering fungerar sämre'],
  ['Pappersval efter pris först', 'Trycksaken får fel känsla eller funktion'],
];

// Produkt → papper
const produktPapper = [
  ['Reklamblad', 'Vikt och färg styr — bestruket för bild, lättare papper för stora utskick'],
  ['Folder', 'Falsning och bigning styr — papper som viks snyggt'],
  ['Broschyr', 'Omslag kraftigare än inlaga — bilder bestämmer ofta yta'],
  ['Årsredovisning', 'Matt eller obestruket för läsbarhet — god opacitet för text och tabeller'],
  ['Visitkort', '300–400 g/m² kartong — yta efter önskad känsla'],
  ['Mappar', 'Kraftig kartong — stabilitet för stansning och fickor'],
  ['Böcker', 'Boktypen styr — text, bild eller jubileum'],
  ['Storformat', 'Material efter miljö och montering — PP, vinyl, Kapa, Re-board'],
];
---

<Layout
  title="Välja papper till tryck – guide till gramvikt, yta och material | Norrmalmstryckeriet"
  description="Lär dig välja rätt papper till trycksaker. Guide till bestruket, obestruket, gramvikt, bulk, opacitet, färg, tryckmetod och efterbehandling."
>

  <!-- ═══ HERO ═══ -->
  <section class="page-section hero-pdf bg-[#F3F3F3]">
    <div class="page-container">
      <div class="grid lg:grid-cols-[1fr_auto] gap-[40px] md:gap-[60px] lg:gap-[80px] items-center lg:items-end">
        <div>
          <p class="section-label">Guide • Norrmalmstryckeriet</p>
          <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[820px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
            Allt du behöver veta om papper och materialval.
          </h1>
          <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[680px] mb-[24px] sm:mb-[28px]" style="text-wrap: pretty;">
            Pappret är inte bara underlaget — det är en del av budskapet. Det påverkar känslan, färgåtergivningen, läsbarheten, hållbarheten, vikten och vilket intryck mottagaren får. När pappersval, tryckmetod och efterbehandling planeras tillsammans gör trycksaken sitt jobb.
          </p>
          <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px]">
            <a href="/infografik/papper" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
            <a href="/offert" class="btn-pill w-full sm:w-auto justify-center" style="background: #222; color: #fff;">
              Begär offert<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>

        <div class="pdf-teaser-wrap">
          <div class="pdf-teaser">
            <img src="/images/infografik/papper-guide-teaser.webp" alt="Förhandsvisning av guiden Så väljer du rätt papper till din trycksak (PDF)" loading="eager" decoding="async" />
            <span class="pdf-badge">PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR LÄSA GUIDEN? ═══ -->
  <section class="page-section form-section-cover">
    <div class="page-content">
      <p class="section-label">Varför läsa den här guiden?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          Pappret är en del av budskapet. <em>Inte bara en teknisk specifikation.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            Ett reklamblad, en folder, en broschyr, en årsredovisning, ett visitkort, en mapp, en bok och ett storformat har olika krav. Guiden hjälper dig välja papper som passar både kommunikationen och produktionen.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Förstå skillnaden mellan bestruket och obestruket — och när vart passar</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Lär dig gramvikt, bulk och opacitet — och varför de spelar roll</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Beslutsmodell i 8 steg från syfte till rätt papper</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Undvik de vanligaste pappers-misstagen</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="#beslutsmodell" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Till beslutsmodellen<Fragment set:html={arrowSvg} />
            </a>
            <a href="/infografik/papper" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DEFINITION & TERMER ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Definition</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
        Termer som styr pappersvalet.
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px] mb-[32px] sm:mb-[40px]" style="text-wrap: pretty;">
        <p>Pappret påverkar hur trycksaken känns, hur färgerna återges, hur lätt den är att läsa, hur länge den håller och vilket intryck avsändaren lämnar. För att kunna prata om papper med tryckeriet är några grundtermer värdefulla.</p>
      </div>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Term</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Betydelse</th>
            </tr>
          </thead>
          <tbody>
            {termer.map(([t, d], i) => (
              <tr class={i < termer.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{t}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[14px] sm:text-[15px] text-[#444]">{d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ BESLUTSMODELL ═══ -->
  <section id="beslutsmodell" class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Beslutsmodell</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Så väljer du rätt papper till din trycksak.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Åtta beslut som styr hur väl pappret stödjer trycksakens funktion, känsla och produktion — från syfte och yta till efterbehandling och prov.
      </p>
    </div>
    <div id="steps-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {steps.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[340px] sm:min-h-[380px]">
          <span class="font-[var(--font-heading)] text-[#D9222A] text-[36px] sm:text-[44px] leading-none mb-[16px] sm:mb-[20px]">{s.no}</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.625rem); line-height: 1.2;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444]">{s.body}</p>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="steps-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="steps-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ BESTRUKET vs OBESTRUKET ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Bestruket eller obestruket?</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Två ytor med olika styrkor.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Valet handlar inte om rätt eller fel — det handlar om vilken känsla och funktion trycksaken ska ha.
      </p>
      <div class="grid sm:grid-cols-2 gap-[16px] sm:gap-[20px]">
        <div class="bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Bestruket papper</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555] mb-[12px]">Slätare yta som ger jämn tryckyta, tydligare bildåtergivning och ofta mer intensiva färger.</p>
          <p class="text-[13px] sm:text-[14px] text-[#888]"><strong class="text-[#222]">Passar:</strong> Broschyrer, kataloger, reklamblad, affischer och bildrikt material.</p>
        </div>
        <div class="bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Obestruket papper</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555] mb-[12px]">Mer öppen och naturlig yta — taktil, mjuk och återhållsam. Färgen sugs in i ytan och ger ett dämpat uttryck.</p>
          <p class="text-[13px] sm:text-[14px] text-[#888]"><strong class="text-[#222]">Passar:</strong> Årsredovisningar, böcker, brev, rapporter, inbjudningar.</p>
        </div>
        <div class="bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Mattbestruket</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555] mb-[12px]">Dämpat uttryck men fortfarande bildvänligt — bra för rapporter och profilmaterial.</p>
        </div>
        <div class="bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Blankbestruket</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555] mb-[12px]">Hög glans och starka färger — bra för bildrika kampanjer och kataloger.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ GRAMVIKT-TABELL ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Gramvikt</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Vad betyder g/m²?
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Gramvikt anger hur mycket pappret väger per kvadratmeter. Det är en bra utgångspunkt, men säger inte allt — bulk, yta och fiber spelar också roll.
      </p>
      <div class="bg-white rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Gramvikt</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Passar ofta till</th>
            </tr>
          </thead>
          <tbody>
            {gramvikt.map(([a, b], i) => (
              <tr class={i < gramvikt.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{a}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        <strong class="text-[#222]">Tips:</strong> Två papper med samma gramvikt kan kännas helt olika beroende på bulk, fiber och yta. Vid kritiska val är pappersprov värdefullt.
      </p>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
          Yta, vikt och produktion.
        </h2>
        <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] mb-[40px] sm:mb-[60px] md:mb-[80px] max-w-[720px]">
          Vi hjälper dig välja papper som passar både kommunikationen och produktionen — från reklamblad och foldrar till böcker, mappar och storformat.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px]">
          {expertise.map((e) => (
            <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[24px] sm:p-[28px] lg:p-[39px]">
              <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[14px] sm:mb-[20px]" style="font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem); line-height: 1.2;">{e.title}</h3>
              <p class="!text-white/70 text-[14px] sm:text-[15px] leading-relaxed mb-[18px] sm:mb-[24px]">{e.intro}</p>
              <div class="space-y-[12px] sm:space-y-[14px]">
                {e.items.map(([term, desc]) => (
                  <p class="text-[13px] sm:text-[14px] leading-relaxed !text-white/80">
                    <strong class="!text-white font-bold">{term}</strong> – {desc}
                  </p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ PRODUKT → PAPPER ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Produkt → pappersval</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Varje trycksak har sina egna materialkrav.
      </h2>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Produkt</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Vad pappret bör stödja</th>
            </tr>
          </thead>
          <tbody>
            {produktPapper.map(([a, b], i) => (
              <tr class={i < produktPapper.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{a}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ VANLIGA MISSTAG ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Vanliga misstag</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Många problem kan undvikas om pappret diskuteras tidigt.
      </h2>
      <div class="bg-white rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Misstag</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Konsekvens</th>
            </tr>
          </thead>
          <tbody>
            {misstag.map(([a, b], i) => (
              <tr class={i < misstag.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{a}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ NEDLADDNINGS-CTA ═══ -->
  <section class="pt-[16px] pb-[16px] sm:pt-[24px] sm:pb-[24px]">
    <div class="page-container max-w-[1140px] px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px]">
      <div class="bg-[#D9222A] rounded-[20px] sm:rounded-[28px] px-[24px] sm:px-[40px] md:px-[56px] py-[36px] sm:py-[48px] md:py-[56px] grid md:grid-cols-[1fr_auto] gap-[24px] md:gap-[40px] items-center">
        <div>
          <p class="!text-white/80 uppercase font-medium text-[10px] sm:text-[11px] mb-[10px]" style="letter-spacing: 1.5px;">Gratis nedladdning</p>
          <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[8px] sm:mb-[10px]" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.2; text-wrap: balance;">
            Vill du ha hela guiden som PDF?
          </h3>
          <p class="!text-white/90 text-[14px] sm:text-[15px] leading-relaxed max-w-[520px]">
            Beslutsmodell, gramvikt, yta, opacitet, produktval och pappers-misstag — i ett paket.
          </p>
        </div>
        <a href="/infografik/papper" class="btn-pill w-full md:w-auto justify-center md:justify-start whitespace-nowrap" style="background: #fff; color: #222;">
          Ladda ner guiden<Fragment set:html={downloadSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ PROV, DUMMY & RÅDGIVNING ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Prov, dummy & rådgivning</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Papper behöver ibland kännas.
      </h2>
      <div class="grid sm:grid-cols-2 gap-[16px] sm:gap-[20px]">
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Pappersprov</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">När känslan är viktig — visar yta, styvhet, färgton och taktilitet.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Dummy</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Vid foldrar, mappar, böcker och broschyrer — visar hur pappret beter sig vid vikning, bindning eller stansning.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Provtryck</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Vid kritiska bilder eller färger — visar hur färgerna återges på det specifika pappret.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Materialtest</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Vid storformat och planprint — visar vidhäftning, täckning och slutintryck på rätt material.</p>
        </div>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        Ju viktigare trycksaken är, desto mer värdefullt är det att testa innan produktion.
      </p>
    </div>
  </section>

  <!-- ═══ SLUT-CTA ═══ -->
  <section class="page-section pt-0">
    <div class="page-container max-w-[1300px]">
      <div class="bg-[#222] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] px-[24px] sm:px-[44px] md:px-[60px] lg:px-[80px] py-[48px] sm:py-[72px] md:py-[96px] grid lg:grid-cols-[1.3fr_1fr] gap-[32px] lg:gap-[60px] items-center">
        <div>
          <p class="section-label" style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Behöver du hjälp att välja papper?</p>
          <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[24px]" style="font-size: clamp(1.75rem, 4vw, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
            Berätta vad du vill trycka — vi rekommenderar materialet.
          </h2>
          <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed" style="text-wrap: pretty;">
            Skicka din idé, skiss eller färdiga PDF. Vi går igenom papper, format, tryckmetod, efterbehandling och en tydlig offert.
          </p>
        </div>
        <div class="flex flex-col gap-[12px]">
          <a href="/offert" class="btn-pill btn-red w-full justify-center">
            Begär offert<Fragment set:html={arrowSvg} />
          </a>
          <a href="/infografik/papper" class="btn-pill w-full justify-center" style="background: white; color: #222;">
            Ladda ner guiden (PDF)<Fragment set:html={downloadSvg} />
          </a>
          <a href="/kontakta-oss" class="btn-pill w-full justify-center" style="background: rgba(255,255,255,0.10); color: #fff;">
            Kontakta oss<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-container { width: 100%; max-width: 1440px; margin-left: auto; margin-right: auto; }

  .page-section { padding-top: 56px; padding-bottom: 56px; padding-left: 16px; padding-right: 16px; }
  @media (min-width: 640px) { .page-section { padding-top: 72px; padding-bottom: 72px; padding-left: 24px; padding-right: 24px; } }
  @media (min-width: 768px) { .page-section { padding-top: 88px; padding-bottom: 88px; } }
  @media (min-width: 1024px) { .page-section { padding-top: 112px; padding-bottom: 112px; padding-left: 44px; padding-right: 44px; } }

  .page-section-no-px { padding-top: 48px; padding-bottom: 48px; }
  @media (min-width: 640px) { .page-section-no-px { padding-top: 56px; padding-bottom: 56px; } }
  @media (min-width: 768px) { .page-section-no-px { padding-top: 72px; padding-bottom: 72px; } }
  @media (min-width: 1024px) { .page-section-no-px { padding-top: 88px; padding-bottom: 88px; } }

  .section-label { font-family: var(--font-body); font-size: 11px; line-height: 1; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 500; color: #888; margin-bottom: 16px; }
  @media (min-width: 768px) { .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 20px; } }

  .hero-pdf { overflow: visible; position: relative; z-index: 1; }
  .form-section-cover { position: relative; z-index: 2; background: #fff; }
  .pdf-teaser-wrap { display: flex; justify-content: center; align-items: flex-end; position: relative; margin-bottom: -210px; }
  .pdf-teaser {
    position: relative; width: 240px; max-width: 100%;
    aspect-ratio: 1833 / 2700; border-radius: 10px; overflow: hidden; background: #fff;
    box-shadow: 0 1px 2px rgba(0,0,0,0.06), 0 14px 28px rgba(0,0,0,0.10), 0 40px 80px rgba(0,0,0,0.18);
    transform: rotate(3deg); transform-origin: top center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1); will-change: transform;
  }
  .pdf-teaser:hover { transform: rotate(3deg) translateY(-6px); }
  .pdf-teaser img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .pdf-badge {
    position: absolute; top: 12px; right: 12px;
    background: #D9222A; color: #fff;
    font-family: var(--font-heading); font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
    padding: 5px 9px; border-radius: 4px; text-transform: uppercase; z-index: 2;
  }
  @media (min-width: 640px) { .pdf-teaser-wrap { margin-bottom: -240px; } .pdf-teaser { width: 280px; } }
  @media (min-width: 1024px) { .pdf-teaser-wrap { align-self: end; margin-bottom: -300px; } .pdf-teaser { width: 360px; } }
  @media (min-width: 1440px) { .pdf-teaser-wrap { margin-bottom: -340px; } .pdf-teaser { width: 400px; } }
</style>

<script>
  function initGuide() {
    const carousel = document.getElementById('steps-carousel');
    const cardWidth = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('steps-prev')?.addEventListener('click', () => { carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' }); });
    document.getElementById('steps-next')?.addEventListener('click', () => { carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' }); });
  }
  initGuide();
  document.addEventListener('astro:after-swap', initGuide);
</script>
