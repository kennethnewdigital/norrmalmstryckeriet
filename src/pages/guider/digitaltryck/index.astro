---
import Layout from '../../../layouts/Layout.astro';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
const downloadSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>`;

// Beslutsmodell — sidoscroll-kort (8 steg)
const steps = [
  { no: '01', title: 'Börja med behovet', body: 'Vad ska trycksaken göra? Hur många exemplar behövs? När ska materialet vara klart? Ska det finnas flera versioner eller variabeldata?' },
  { no: '02', title: 'Välj digitaltryck när flexibilitet är viktig', body: 'Mindre upplaga, kort tidsplan, innehåll som ändras, flera versioner eller personanpassning — digitaltryck är ofta rätt val när materialet ska vara aktuellt.' },
  { no: '03', title: 'Planera versionering', body: 'Olika språk, kontor, målgrupper, kontaktpersoner, QR-koder eller datum — samma grundmaterial i flera varianter, varje i rätt antal.' },
  { no: '04', title: 'Planera variabeldata', body: 'Namn, adress, QR-kod, kundnummer, medlemsnummer eller personlig bild — varje exemplar kan vara unikt utan att produktionen stoppas.' },
  { no: '05', title: 'Välj papper', body: 'Bestruket för bild och färg, obestruket för naturlig känsla, kraftigare för premium, tunnare för utskick. Papper, färgtäckning och efterbehandling planeras tillsammans.' },
  { no: '06', title: 'Planera efterbehandling', body: 'Skärning, falsning, bigning, klammerhäftning, limbindning, perforering, laminering — bigning är särskilt viktig vid vikta material med hög färgtäckning.' },
  { no: '07', title: 'Kontrollera originalet', body: 'Tryckfärdig PDF med slutformat, utfall, säker marginal, CMYK, inbäddade typsnitt och sidvis ordning. Vid variabeldata — kontrollera datafilen.' },
  { no: '08', title: 'Tänk på leveransen', body: 'Hämtning, utskick, packning per mottagare, distribution till event — digitaltryck blir bäst när hela kedjan från PDF till mottagare planeras tillsammans.' },
];

// Expertis-block
const expertise = [
  {
    title: 'Mindre upplagor & tid',
    intro: 'Digitaltryck har kort startsträcka. Det gör mindre upplagor och tidsstyrda produktioner kostnadseffektiva.',
    items: [
      ['Inga tryckplåtar', 'Tryckbilden går direkt från digital fil till digitalpressen.'],
      ['Kort startsträcka', 'Från tryckfärdig PDF till färdigt material — snabbt.'],
      ['Mindre lagerbehov', 'Producera rätt antal exemplar nära användningstillfället.'],
      ['Testupplaga', 'Bra för prov, möten och utvärdering.'],
      ['Aktuellt material', 'Texter, siffror och datum kan uppdateras sent i processen.'],
    ],
  },
  {
    title: 'Versionering & variabeldata',
    intro: 'Samma grundmaterial i flera varianter — eller varje exemplar unikt. Digitaltryck gör trycksaken relevant för mottagaren.',
    items: [
      ['Versionering', 'Olika språk, kontor, målgrupper, kontaktpersoner eller datum.'],
      ['Variabeldata', 'Namn, adress, QR-kod, kundnummer eller personligt budskap.'],
      ['Adressering', 'Integreras i produktionen — bra för medlemsutskick och DR.'],
      ['Sortering', 'Material kan delas upp per mottagargrupp eller område.'],
      ['QR-koder', 'Individuella länkar för spårning, bokning eller kampanj.'],
    ],
  },
  {
    title: 'Papper & efterbehandling',
    intro: 'Digitaltryck fungerar med många papper — men toner ligger mer på ytan, vilket gör bigning extra viktig vid vikta material.',
    items: [
      ['Bestruket & obestruket', 'Bestruket för bild, obestruket för text och taktil känsla.'],
      ['Kraftigare papper', 'Visitkort, omslag och premiumkänsla.'],
      ['Bigning', 'Pressad viklinje — minskar risk för sprickor i färg över falsen.'],
      ['Klammerhäftning & limbindning', 'För broschyrer, häften, manualer och rapporter.'],
      ['Laminering & perforering', 'För skydd, finish, kuponger och svarstalonger.'],
    ],
  },
];

// Termer
const termer = [
  ['Digitaltryck', 'Tryckmetod där bilden går direkt från digital fil till press — inga plåtar'],
  ['Digitalpress', 'Maskinen som trycker direkt från digital fil — oftast tonerbaserad'],
  ['Variabeldata', 'Innehåll som varierar från exemplar till exemplar utan att stoppa produktionen'],
  ['Versionering', 'Samma grundmaterial i flera varianter — språk, kontor eller målgrupp'],
  ['Adressering', 'Mottagaradress trycks direkt i produktionen'],
  ['Bigning', 'Pressad viklinje i materialet innan falsning — renare vikning'],
  ['CMYK', 'Standardfärgmodell för tryckproduktion — cyan, magenta, gul och svart'],
];

// Digitaltryck vs offset
const digitalVsOffset = [
  ['Mindre & medelstora upplagor', 'Digitaltryck'],
  ['Större upplagor', 'Offsettryck'],
  ['Snabb produktion / korta serier', 'Digitaltryck'],
  ['Effektiv produktion vid många exemplar', 'Offsettryck'],
  ['Flera versioner / variabeldata', 'Digitaltryck'],
  ['Jämn kvalitet över hela upplagan', 'Offsettryck'],
  ['Mindre lagerbehov / aktuellt material', 'Digitaltryck'],
  ['Bättre styckpris vid volym', 'Offsettryck'],
];

// Vanliga trycksaker
const vanligaTrycksaker = [
  ['Visitkort', 'Smidigt för nya medarbetare och flera namnversioner'],
  ['Foldrar', 'Mindre upplagor och kampanjer — versionerade vid behov'],
  ['Broschyrer', 'Presentationer, rapporter och eventmaterial'],
  ['Reklamblad', 'Lokala kampanjer och kortare serier'],
  ['Årsredovisningar', 'BRF:er, föreningar och mindre organisationer'],
  ['Produktblad', 'Enkelt att uppdatera och versionera'],
  ['Inbjudningar', 'Smidigt vid event och kundträffar'],
  ['Personliga utskick', 'Variabeldata och adressering — kallelser, kampanj och DR'],
];

// Original-checklista
const originalChecklista = [
  ['Slutformat', 'Ange exakt färdigt format på PDF:en'],
  ['Utfall', 'Lägg till utfall där bild eller färg går till kant'],
  ['Säker marginal', 'Håll text och viktiga detaljer från skärkant'],
  ['Bilder', 'Använd tryckbar upplösning'],
  ['Färger', 'Anpassa till CMYK och rätt färgprofil för digitaltryck'],
  ['Typsnitt', 'Bädda in typsnitt eller skapa konturer vid behov'],
  ['Sidordning', 'Leverera flersidiga dokument i läsordning'],
  ['Variabeldata', 'Leverera datafil enligt överenskommen struktur'],
  ['QR-koder', 'Testa funktion och storlek i slutformat'],
  ['PDF', 'Exportera enligt tryckeriets instruktioner'],
];
---

<Layout
  title="Digitaltryck – guide till mindre upplagor, snabb produktion och versionering | Norrmalmstryckeriet"
  description="Lär dig när digitaltryck passar bäst. Guide till mindre upplagor, papper, original, versionering, variabeldata, efterbehandling och tryck."
>

  <!-- ═══ HERO ═══ -->
  <section class="page-section hero-pdf bg-[#F3F3F3]">
    <div class="page-container">
      <div class="grid lg:grid-cols-[1fr_auto] gap-[40px] md:gap-[60px] lg:gap-[80px] items-center lg:items-end">
        <div>
          <p class="section-label">Guide • Norrmalmstryckeriet</p>
          <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[820px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
            Allt du behöver veta om digitaltryck.
          </h1>
          <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[680px] mb-[24px] sm:mb-[28px]" style="text-wrap: pretty;">
            Tryckmetoden för material som ska vara aktuellt. När upplagan är mindre, när tiden är knapp, när flera versioner behövs eller när varje exemplar ska vara unikt — digitaltryck gör det möjligt att producera rätt antal vid rätt tillfälle.
          </p>
          <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px]">
            <a href="/infografik/digitaltryck" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
            <a href="/offert" class="btn-pill w-full sm:w-auto justify-center" style="background: #222; color: #fff;">
              Begär offert<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>

        <div class="pdf-teaser-wrap">
          <div class="pdf-teaser">
            <img src="/images/infografik/digitaltryck-guide-teaser.webp" alt="Förhandsvisning av guiden Så planerar du digitaltryck för mindre upplagor och smartare produktion (PDF)" loading="eager" decoding="async" />
            <span class="pdf-badge">PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR LÄSA GUIDEN? ═══ -->
  <section class="page-section form-section-cover">
    <div class="page-content">
      <p class="section-label">Varför läsa den här guiden?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          Digitaltryck är frihet. <em>Rätt mängd, rätt innehåll, vid rätt tillfälle.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            Mindre upplaga, flera versioner, variabeldata, personliga utskick eller material som uppdateras ofta — guiden hjälper dig planera produktionen så att den blir både flexibel och professionell.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Förstå när digitaltryck är rätt val — och när offsettryck passar bättre</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Lär dig versionering, variabeldata och adressering</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Beslutsmodell i 8 steg från behov till tryckklar PDF</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Originalchecklista och tips för bigning, vikning och efterbehandling</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="#beslutsmodell" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Till beslutsmodellen<Fragment set:html={arrowSvg} />
            </a>
            <a href="/infografik/digitaltryck" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DEFINITION ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Definition</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
        Vad är digitaltryck?
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px] mb-[32px] sm:mb-[40px]" style="text-wrap: pretty;">
        <p>Digitaltryck innebär att tryckbilden går direkt från en digital fil till digitalpressen. Till skillnad från <a href="/guider/offsettryck" class="underline hover:text-[#222]">offsettryck</a> krävs inga tryckplåtar — vilket gör startsträckan kortare och produktionen smidigare vid mindre upplagor, versionerade material och trycksaker där innehållet kan variera.</p>
        <p>Norrmalmstryckeriet kör en <strong class="text-[#222]">Konica C12000</strong> som ger hög färgkvalitet, snabb produktion och flexibilitet för både kortare serier och versionerat material.</p>
      </div>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Term</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Betydelse</th>
            </tr>
          </thead>
          <tbody>
            {termer.map(([t, d], i) => (
              <tr class={i < termer.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{t}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[14px] sm:text-[15px] text-[#444]">{d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ BESLUTSMODELL ═══ -->
  <section id="beslutsmodell" class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Beslutsmodell</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Så planerar du digitaltryck för mindre upplagor och smartare produktion.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Åtta beslut som styr hur väl produktionen möter behovet — från upplaga och versionering till papper, original, efterbehandling och leverans.
      </p>
    </div>
    <div id="steps-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {steps.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[340px] sm:min-h-[380px]">
          <span class="font-[var(--font-heading)] text-[#D9222A] text-[36px] sm:text-[44px] leading-none mb-[16px] sm:mb-[20px]">{s.no}</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.625rem); line-height: 1.2;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444]">{s.body}</p>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="steps-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="steps-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ DIGITAL VS OFFSET ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Digitaltryck eller offsettryck?</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Två metoder med olika styrkor.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Det bästa valet beror på trycksakens syfte, upplaga, papper, tidsplan, färgkrav, efterbehandling och hur materialet ska användas. Här är en enkel översikt.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Behov</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Passar ofta bäst</th>
            </tr>
          </thead>
          <tbody>
            {digitalVsOffset.map(([a, b], i) => (
              <tr class={i < digitalVsOffset.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{a}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        <strong class="text-[#222]">Tips:</strong> Det finns ingen exakt gräns för när digitaltryck slutar vara bäst och offsettryck tar över. Det beror på format, sidantal, papper, färgtäckning och tidsplan. Be om totalekonomin, inte bara styckpriset.
      </p>
    </div>
  </section>

  <!-- ═══ VERSIONERING & VARIABELDATA ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Versionering & variabeldata</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        När materialet ska tala till rätt mottagare.
      </h2>
      <div class="grid sm:grid-cols-2 gap-[16px] sm:gap-[20px]">
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <span class="text-[10px] sm:text-[11px] uppercase text-[#D9222A] font-semibold block mb-[6px]" style="letter-spacing: 1.2px;">Versionering</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Samma grund, flera varianter</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Olika språk, kontor, kontaktpersoner, målgrupper, datum eller QR-koder — samma layout men anpassat innehåll per upplaga.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <span class="text-[10px] sm:text-[11px] uppercase text-[#D9222A] font-semibold block mb-[6px]" style="letter-spacing: 1.2px;">Variabeldata</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Varje exemplar unikt</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Namn, adress, QR-kod, kundnummer, medlemsnummer eller personligt budskap — utan att produktionen behöver stoppas mellan exemplar.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <span class="text-[10px] sm:text-[11px] uppercase text-[#D9222A] font-semibold block mb-[6px]" style="letter-spacing: 1.2px;">Adressering</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Direktutskick & DR</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Mottagaradresser trycks direkt i produktionen — bra för medlemsbrev, BRF-utskick, kallelser, fakturor och kampanj.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <span class="text-[10px] sm:text-[11px] uppercase text-[#D9222A] font-semibold block mb-[6px]" style="letter-spacing: 1.2px;">Sortering</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Per mottagargrupp</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Material kan delas upp per säljare, region, distrikt eller mottagarlista — gör hela utskicket smidigare.</p>
        </div>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        <strong class="text-[#222]">Tips:</strong> Variabeldata kräver ordning i både original och datafil. Kontrollera alltid några exempelposter innan full produktion.
      </p>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
          Upplaga, versionering och original.
        </h2>
        <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] mb-[40px] sm:mb-[60px] md:mb-[80px] max-w-[720px]">
          Vi kör Konica C12000 digitalpress och hjälper dig planera hela kedjan — från behovsanalys och original till versionering, variabeldata, efterbehandling och leverans.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px]">
          {expertise.map((e) => (
            <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[24px] sm:p-[28px] lg:p-[39px]">
              <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[14px] sm:mb-[20px]" style="font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem); line-height: 1.2;">{e.title}</h3>
              <p class="!text-white/70 text-[14px] sm:text-[15px] leading-relaxed mb-[18px] sm:mb-[24px]">{e.intro}</p>
              <div class="space-y-[12px] sm:space-y-[14px]">
                {e.items.map(([term, desc]) => (
                  <p class="text-[13px] sm:text-[14px] leading-relaxed !text-white/80">
                    <strong class="!text-white font-bold">{term}</strong> – {desc}
                  </p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VANLIGA TRYCKSAKER ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Vanliga trycksaker i digitaltryck</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        När digitaltryck är rätt val.
      </h2>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Trycksak</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Varför digitaltryck passar</th>
            </tr>
          </thead>
          <tbody>
            {vanligaTrycksaker.map(([a, b], i) => (
              <tr class={i < vanligaTrycksaker.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{a}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ ORIGINAL & CHECKLISTA ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Original</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Originalchecklista — kort startsträcka, viktigare kontroll.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Digitaltryck har kort väg från PDF till färdigt material. Det gör originalkontrollen extra viktig — en tryckfärdig PDF gör produktionen smidigare och slutresultatet bättre. Vid variabeldata behöver också datafilens struktur kontrolleras.
      </p>
      <div class="bg-white rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Del</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Rekommendation</th>
            </tr>
          </thead>
          <tbody>
            {originalChecklista.map(([d, r], i) => (
              <tr class={i < originalChecklista.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{d}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{r}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ NEDLADDNINGS-CTA ═══ -->
  <section class="pt-[16px] pb-[16px] sm:pt-[24px] sm:pb-[24px]">
    <div class="page-container max-w-[1140px] px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px]">
      <div class="bg-[#D9222A] rounded-[20px] sm:rounded-[28px] px-[24px] sm:px-[40px] md:px-[56px] py-[36px] sm:py-[48px] md:py-[56px] grid md:grid-cols-[1fr_auto] gap-[24px] md:gap-[40px] items-center">
        <div>
          <p class="!text-white/80 uppercase font-medium text-[10px] sm:text-[11px] mb-[10px]" style="letter-spacing: 1.5px;">Gratis nedladdning</p>
          <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[8px] sm:mb-[10px]" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.2; text-wrap: balance;">
            Vill du ha hela guiden som PDF?
          </h3>
          <p class="!text-white/90 text-[14px] sm:text-[15px] leading-relaxed max-w-[520px]">
            Beslutsmodell, digital vs offset, versionering, variabeldata, papper, efterbehandling och originalchecklista — i ett paket.
          </p>
        </div>
        <a href="/infografik/digitaltryck" class="btn-pill w-full md:w-auto justify-center md:justify-start whitespace-nowrap" style="background: #fff; color: #222;">
          Ladda ner guiden<Fragment set:html={downloadSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ BIGNING & TONER ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Bigning, vikning & toner</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Toner ligger på ytan — vikta material behöver bigning.
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px] mb-[28px] sm:mb-[36px]" style="text-wrap: pretty;">
        <p>Många digitalpressar använder tonerbaserad teknik. Det innebär förenklat att färgen ligger mer på ytan av pappret än vid traditionellt offsettryck. Det ger snabb och flexibel produktion, men gör vissa efterbehandlingar mer beroende av rätt förberedelser — särskilt vid vikta material med mycket färg över viklinjen.</p>
        <p><strong class="text-[#222]">Bigning</strong> innebär att man pressar en viklinje i materialet innan falsning. Det hjälper trycksaken att vikas renare och minskar risken för sprickor i färg eller papper.</p>
      </div>
      <div class="grid sm:grid-cols-2 gap-[16px] sm:gap-[20px]">
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Foldrar & inbjudningar</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Ger snyggare vikning och mer bearbetad känsla — särskilt vid kraftigare papper.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Broschyromslag</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Hjälper omslaget att öppnas bättre — minimerar sprickor över ryggens kant.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Kort</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Ger renare vikning på vikta kort i kraftigare papper.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Material med mycket färg</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Skyddar uttrycket över falsen — viktigt när färgyta möter viklinje.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SLUT-CTA ═══ -->
  <section class="page-section pt-0">
    <div class="page-container max-w-[1300px]">
      <div class="bg-[#222] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] px-[24px] sm:px-[44px] md:px-[60px] lg:px-[80px] py-[48px] sm:py-[72px] md:py-[96px] grid lg:grid-cols-[1.3fr_1fr] gap-[32px] lg:gap-[60px] items-center">
        <div>
          <p class="section-label" style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Behöver du trycka en mindre upplaga eller flera versioner?</p>
          <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[24px]" style="font-size: clamp(1.75rem, 4vw, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
            Berätta vad du vill trycka — vi hjälper med resten.
          </h2>
          <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed" style="text-wrap: pretty;">
            Skicka din idé, skiss eller färdiga PDF. Vi går igenom format, papper, upplaga, versionering, variabeldata, efterbehandling och en tydlig offert.
          </p>
        </div>
        <div class="flex flex-col gap-[12px]">
          <a href="/offert" class="btn-pill btn-red w-full justify-center">
            Begär offert på digitaltryck<Fragment set:html={arrowSvg} />
          </a>
          <a href="/infografik/digitaltryck" class="btn-pill w-full justify-center" style="background: white; color: #222;">
            Ladda ner guiden (PDF)<Fragment set:html={downloadSvg} />
          </a>
          <a href="/kontakta-oss" class="btn-pill w-full justify-center" style="background: rgba(255,255,255,0.10); color: #fff;">
            Kontakta oss<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-container { width: 100%; max-width: 1440px; margin-left: auto; margin-right: auto; }

  .page-section { padding-top: 56px; padding-bottom: 56px; padding-left: 16px; padding-right: 16px; }
  @media (min-width: 640px) { .page-section { padding-top: 72px; padding-bottom: 72px; padding-left: 24px; padding-right: 24px; } }
  @media (min-width: 768px) { .page-section { padding-top: 88px; padding-bottom: 88px; } }
  @media (min-width: 1024px) { .page-section { padding-top: 112px; padding-bottom: 112px; padding-left: 44px; padding-right: 44px; } }

  .page-section-no-px { padding-top: 48px; padding-bottom: 48px; }
  @media (min-width: 640px) { .page-section-no-px { padding-top: 56px; padding-bottom: 56px; } }
  @media (min-width: 768px) { .page-section-no-px { padding-top: 72px; padding-bottom: 72px; } }
  @media (min-width: 1024px) { .page-section-no-px { padding-top: 88px; padding-bottom: 88px; } }

  .section-label { font-family: var(--font-body); font-size: 11px; line-height: 1; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 500; color: #888; margin-bottom: 16px; }
  @media (min-width: 768px) { .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 20px; } }

  .hero-pdf { overflow: visible; position: relative; z-index: 1; }
  .form-section-cover { position: relative; z-index: 2; background: #fff; }
  .pdf-teaser-wrap { display: flex; justify-content: center; align-items: flex-end; position: relative; margin-bottom: -210px; }
  .pdf-teaser {
    position: relative; width: 240px; max-width: 100%;
    aspect-ratio: 1833 / 2700; border-radius: 10px; overflow: hidden; background: #fff;
    box-shadow: 0 1px 2px rgba(0,0,0,0.06), 0 14px 28px rgba(0,0,0,0.10), 0 40px 80px rgba(0,0,0,0.18);
    transform: rotate(3deg); transform-origin: top center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1); will-change: transform;
  }
  .pdf-teaser:hover { transform: rotate(3deg) translateY(-6px); }
  .pdf-teaser img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .pdf-badge {
    position: absolute; top: 12px; right: 12px;
    background: #D9222A; color: #fff;
    font-family: var(--font-heading); font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
    padding: 5px 9px; border-radius: 4px; text-transform: uppercase; z-index: 2;
  }
  @media (min-width: 640px) { .pdf-teaser-wrap { margin-bottom: -240px; } .pdf-teaser { width: 280px; } }
  @media (min-width: 1024px) { .pdf-teaser-wrap { align-self: end; margin-bottom: -300px; } .pdf-teaser { width: 360px; } }
  @media (min-width: 1440px) { .pdf-teaser-wrap { margin-bottom: -340px; } .pdf-teaser { width: 400px; } }
</style>

<script>
  function initGuide() {
    const carousel = document.getElementById('steps-carousel');
    const cardWidth = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('steps-prev')?.addEventListener('click', () => { carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' }); });
    document.getElementById('steps-next')?.addEventListener('click', () => { carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' }); });
  }
  initGuide();
  document.addEventListener('astro:after-swap', initGuide);
</script>
