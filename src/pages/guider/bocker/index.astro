---
import Layout from '../../../layouts/Layout.astro';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
const downloadSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>`;

// Beslutsmodell — sidoscroll-kort (8 steg)
const steps = [
  { no: '01', title: 'Börja med bokens uppgift', body: 'En jubileumsbok, manual, fotobok eller rapport ser olika ut — för att de gör olika saker. Börja med vad boken ska användas till, och vilken känsla den ska bära.' },
  { no: '02', title: 'Välj format', body: 'A5 för manualer och text. 170×240 för faktaböcker. 210×210 för fotoböcker. A4 för utbildningsmaterial. Eget format för profilböcker.' },
  { no: '03', title: 'Bestäm sidantal & papper', body: 'Sidantal och papperstjocklek styr ryggbredd, vikt och känsla. Två böcker med samma sidantal kan kännas helt olika beroende på pappersval.' },
  { no: '04', title: 'Välj bindning', body: 'Klammerhäftning för tunnare häften. Limbindning för mjukband. Trådbindning för hållbarhet. Hårdband när boken ska kännas påkostad. Wire-O för manualer som ska ligga plant.' },
  { no: '05', title: 'Planera omslaget', body: 'Mjukt omslag eller hård pärm. Matt eller blank laminering, soft touch, prägling, foliering eller skyddsomslag — omslaget bär bokens första intryck.' },
  { no: '06', title: 'Inlaga — papper, färg, bilder', body: 'Obestruket för textböcker, bestruket för bilder. Svartvit eller fyrfärg — eller fyrfärgsomslag och svartvit inlaga. Bildupplösning anpassas för formatet.' },
  { no: '07', title: 'Välj tryckmetod', body: 'Digitaltryck för mindre upplagor, provupplagor och versionerat material. Offsettryck för större upplagor, jämn kvalitet och bättre styckkostnad.' },
  { no: '08', title: 'ISBN, ryggbredd & korrektur', body: 'Beräkna ryggbredd. Avgör om boken behöver ISBN och streckkod. Läs korrekturet som en färdig bok — kapitel, paginering, innehållsförteckning och bildtexter.' },
];

// Expertis-block
const expertise = [
  {
    title: 'Format & papper',
    intro: 'Bokens känsla börjar i bläddringen. Format och papper styr läsbarhet, vikt och bildåtergivning.',
    items: [
      ['A5 & 148 × 210 mm', 'Smidiga textformat — romaner, rapporter, manualer.'],
      ['170 × 240 mm', 'Faktaböcker och mer premiumkänsla.'],
      ['210 × 210 mm', 'Fotoböcker och jubileumsböcker.'],
      ['Obestruket papper', 'Textböcker, naturlig och taktil känsla.'],
      ['Bestruket papper', 'Fotoböcker och bildrika böcker — skarpare återgivning.'],
    ],
  },
  {
    title: 'Bindning & omslag',
    intro: 'Bindningen avgör hur boken öppnas, sparas och håller över tid. Omslaget bär första intrycket.',
    items: [
      ['Klammerhäftning', 'Tunnare häften, program och rapporter.'],
      ['Limbindning', 'Mjukband, romaner, rapporter och kataloger.'],
      ['Trådbindning', 'Längre livslängd och bättre öppning.'],
      ['Hårdband', 'Jubileumsböcker, fotoböcker och premiumproduktion.'],
      ['Wire-O / spiral', 'Manualer och utbildningsmaterial som ska ligga plant.'],
    ],
  },
  {
    title: 'Tryck & original',
    intro: 'Böcker innehåller många detaljer som samverkar — papper, färg, ryggbredd, paginering, kapitel och korrektur.',
    items: [
      ['Digitaltryck', 'Mindre upplagor, provupplagor och uppdaterade versioner.'],
      ['Offsettryck', 'Större upplagor och stabil kvalitet över volym.'],
      ['Sidvis PDF', 'Inlaga i läsordning — tryckeriet sköter utskjutningen.'],
      ['Ryggbredd', 'Beräknas efter sidantal och papperets tjocklek.'],
      ['ISBN & streckkod', 'Vid försäljning eller bred distribution — planeras på baksidan.'],
    ],
  },
];

// Termer
const termer = [
  ['Inlaga', 'Bokens sidor — det som ligger mellan pärmarna'],
  ['Omslag', 'Bokens framsida, rygg och baksida'],
  ['Ryggbredd', 'Bredden på bokens rygg — beräknas av sidantal och papperets tjocklek'],
  ['Mjukband', 'Limbunden bok med kraftigare omslag i kartong'],
  ['Hårdband', 'Bok med hård pärm — ofta överdragen med klot, papper eller skyddsomslag'],
  ['Sidvis PDF', 'PDF med en sida per sida i läsordning — standard för bokinlagor'],
  ['Utskjutning', 'Placering av sidor på tryckarket inför tryck och bindning'],
  ['ISBN', 'Internationellt standardnummer som identifierar en specifik bokutgåva'],
];

// Boktyper
const boktyper = [
  ['Jubileumsbok', 'Samlar historia, bilder och berättelser i en värdig form'],
  ['Fotobok', 'Ger bilder en fysisk och mer bestående presentation'],
  ['Rapport', 'Gör omfattande innehåll mer läsbart och lätt att spara'],
  ['Manual', 'Praktiskt material som ska användas över tid'],
  ['Utbildningsmaterial', 'Instruktioner, övningar och referenser i en form'],
  ['Föreningshistorik', 'Bevarar minnen, personer och utveckling'],
  ['Verksamhetsbok', 'Presenterar projekt, resultat och identitet'],
  ['Roman & faktabok', 'Ger texten en färdig publicerad form'],
];

// Original-checklista
const originalChecklista = [
  ['Sidvis PDF', 'Leverera inlaga som sidvis PDF i läsordning'],
  ['Blanka sidor', 'Lägg in dem där de ska finnas'],
  ['Sidnummer', 'Kontrollera paginering noggrant'],
  ['Kapitelstarter', 'Säkerställ att de börjar på rätt sida'],
  ['Innehållsförteckning', 'Kontrollera mot sidnumren'],
  ['Bilder', 'Tryckbar upplösning, korrekt färgrymd och beskärning'],
  ['Omslagsfil', 'Levereras med framsida, rygg, baksida och utfall'],
  ['Ryggbredd', 'Beräknas efter slutligt sidantal och papper'],
  ['ISBN & streckkod', 'Placeras på baksidan om boken ska säljas eller distribueras'],
];
---

<Layout
  title="Trycka böcker – guide till boktryck, papper, bindning och omslag | Norrmalmstryckeriet"
  description="Lär dig vad du bör tänka på när du ska trycka böcker. Guide till format, sidantal, papper, mjukband, hårdband, omslag, original och tryckmetod."
>

  <!-- ═══ HERO ═══ -->
  <section class="page-section hero-pdf bg-[#F3F3F3]">
    <div class="page-container">
      <div class="grid lg:grid-cols-[1fr_auto] gap-[40px] md:gap-[60px] lg:gap-[80px] items-center lg:items-end">
        <div>
          <p class="section-label">Guide • Norrmalmstryckeriet</p>
          <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[820px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
            Allt du behöver veta om att trycka böcker.
          </h1>
          <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[680px] mb-[24px] sm:mb-[28px]" style="text-wrap: pretty;">
            En bok är en trycksak med särskild tyngd. Den samlar kunskap, berättelser, bilder, rapporter eller historia i en form som är gjord för att sparas, bläddras i och återvändas till. När format, papper, bindning, omslag och tryckmetod samspelar blir boken mer än sidor i ordning.
          </p>
          <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px]">
            <a href="/produkter/bocker/infografik" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
            <a href="/offert" class="btn-pill w-full sm:w-auto justify-center" style="background: #222; color: #fff;">
              Begär offert<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>

        <div class="pdf-teaser-wrap">
          <div class="pdf-teaser">
            <img src="/images/infografik/bocker-guide-teaser.webp" alt="Förhandsvisning av guiden Så planerar du en bokproduktion (PDF)" loading="eager" decoding="async" />
            <span class="pdf-badge">PDF</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TERMNOTERING ═══ -->
  <section class="page-section form-section-cover">
    <div class="page-content max-w-[920px]">
      <div class="bg-[#FFF8E1] border-l-[4px] border-[#D9222A] rounded-r-[12px] p-[20px] sm:p-[28px] md:p-[32px]">
        <p class="section-label" style="margin-bottom: 10px; color: #B8860B;">Om termen "boktryck"</p>
        <p class="text-[15px] sm:text-[16px] md:text-[17px] leading-[1.7] text-[#444]" style="text-wrap: pretty;">
          <strong class="text-[#222]">Boktryck</strong> kan historiskt avse högtryck eller letterpress — den äldre trycktekniken där typer och klichéer trycker direkt mot pappret. I den här guiden använder vi ordet i sin moderna, vardagliga betydelse: <strong class="text-[#222]">att trycka böcker.</strong> Det vill säga modern bokproduktion med digital- eller offsettryck, modern bindning och efterbehandling.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR LÄSA GUIDEN?" ═══ -->
  <section class="page-section">
    <div class="page-content">
      <p class="section-label">Varför läsa den här guiden?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          En bok är en form som ska hålla. <em>Inte bara sidor i ordning.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            Jubileum, manual, rapport, fotobok eller roman — varje bok har olika krav på format, papper, bindning och omslag. Guiden hjälper dig välja rätt lösning innan tryck.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Förstå skillnaden mellan mjukband, hårdband och häfte</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Välj rätt papper för text, bild eller blandat innehåll</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Beslutsmodell i 8 steg från idé till tryckklar bok</span>
            </li>
            <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
              <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span>Lär dig ryggbredd, ISBN, sidvis PDF och korrektur som bok</span>
            </li>
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="#beslutsmodell" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Till beslutsmodellen<Fragment set:html={arrowSvg} />
            </a>
            <a href="/produkter/bocker/infografik" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Ladda ner som PDF<Fragment set:html={downloadSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ DEFINITION & TERMER ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Definition</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.75rem, 4vw, 3.25rem); line-height: 1.1; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
        När passar en tryckt bok?
      </h2>
      <div class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] space-y-[16px] mb-[32px] sm:mb-[40px]" style="text-wrap: pretty;">
        <p>En tryckt bok passar när innehållet behöver en mer varaktig form — material som ska läsas noggrant, sparas, delas ut, säljas, arkiveras eller användas många gånger.</p>
        <p>Bokformatet passar särskilt bra när innehållet har ett värde även efter första läsningen.</p>
      </div>
      <div class="bg-white rounded-[16px] overflow-hidden border border-[#E5E5E5]">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Term</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Betydelse</th>
            </tr>
          </thead>
          <tbody>
            {termer.map(([t, d], i) => (
              <tr class={i < termer.length - 1 ? 'border-b border-[#F0F0F0]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{t}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[14px] sm:text-[15px] text-[#444]">{d}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ BESLUTSMODELL ═══ -->
  <section id="beslutsmodell" class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Beslutsmodell</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Så planerar du en bokproduktion som känns rätt från första till sista sida.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Åtta beslut som styr hur väl boken bär ditt innehåll — från uppgift och format till bindning, original och korrektur.
      </p>
    </div>
    <div id="steps-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {steps.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[340px] sm:min-h-[380px]">
          <span class="font-[var(--font-heading)] text-[#D9222A] text-[36px] sm:text-[44px] leading-none mb-[16px] sm:mb-[20px]">{s.no}</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.625rem); line-height: 1.2;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444]">{s.body}</p>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="steps-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="steps-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ BOKTYPER ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Boktyper</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Vanliga böcker vi producerar.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        En bok ska produceras för sitt användningsområde, inte bara för sitt sidantal. Här är några vanliga utgångspunkter.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Boktyp</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Vad bokformatet ger</th>
            </tr>
          </thead>
          <tbody>
            {boktyper.map(([a, b], i) => (
              <tr class={i < boktyper.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{a}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{b}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ MJUKBAND vs HÅRDBAND ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Mjukband eller hårdband?</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Bindningen avgör hur boken känns, öppnas och håller.
      </h2>
      <div class="grid sm:grid-cols-2 gap-[16px] sm:gap-[20px]">
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Mjukband</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Limbunden bok med kraftigare omslag i kartong. Smidigt, kostnadseffektivt och bra för rapporter, romaner, manualer och föreningsböcker.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Hårdband</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Bok med hård pärm — ofta överdragen med klot, papper eller skyddsomslag. Passar jubileumsböcker, fotoböcker och presentböcker.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Klammerhäftning</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Tunnare häften, program, manualer och rapporter. Enklare bokkänsla där sidantalet är begränsat.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Wire-O & spiral</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Manualer, utbildningsmaterial och böcker som ska ligga uppslagna och plant under användning.</p>
        </div>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        <strong class="text-[#222]">Tips:</strong> En bok som ska läsas från pärm till pärm har andra krav än en manual som ska ligga uppslagen på ett bord. Välj bindning efter användning, inte bara efter känsla.
      </p>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
          Format, bindning, papper och original.
        </h2>
        <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] mb-[40px] sm:mb-[60px] md:mb-[80px] max-w-[720px]">
          Bokproduktion är hantverk där många detaljer samverkar — vi hjälper dig från idé och original till färdig bok i hand.
        </p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px]">
          {expertise.map((e) => (
            <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[24px] sm:p-[28px] lg:p-[39px]">
              <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[14px] sm:mb-[20px]" style="font-size: clamp(1.5rem, 2vw + 0.5rem, 2rem); line-height: 1.2;">{e.title}</h3>
              <p class="!text-white/70 text-[14px] sm:text-[15px] leading-relaxed mb-[18px] sm:mb-[24px]">{e.intro}</p>
              <div class="space-y-[12px] sm:space-y-[14px]">
                {e.items.map(([term, desc]) => (
                  <p class="text-[13px] sm:text-[14px] leading-relaxed !text-white/80">
                    <strong class="!text-white font-bold">{term}</strong> – {desc}
                  </p>
                ))}
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ ORIGINAL & CHECKLISTA ═══ -->
  <section class="page-section">
    <div class="page-container max-w-[920px]">
      <p class="section-label">Original</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Originalchecklista — läs korrekturet som en bok.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[18px] leading-[1.7] text-[#333] mb-[28px] sm:mb-[36px]">
        Böcker innehåller många detaljer som samverkar — sidor, kapitel, paginering, bilder, bildtexter, innehållsförteckning och omslag. Läs korrekturet som en färdig bok, inte som lösa sidor.
      </p>
      <div class="bg-[#F5F5F5] rounded-[16px] overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="border-b border-[#E5E5E5]">
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Del</th>
              <th class="text-left px-[16px] sm:px-[24px] py-[14px] sm:py-[16px] font-bold text-[13px] sm:text-[14px] uppercase text-[#222]" style="letter-spacing: 0.8px;">Rekommendation</th>
            </tr>
          </thead>
          <tbody>
            {originalChecklista.map(([d, r], i) => (
              <tr class={i < originalChecklista.length - 1 ? 'border-b border-[#E8E8E8]' : ''}>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] font-bold text-[14px] sm:text-[15px] text-[#222]">{d}</td>
                <td class="px-[16px] sm:px-[24px] py-[12px] sm:py-[14px] text-[13px] sm:text-[14px] text-[#555]">{r}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- ═══ NEDLADDNINGS-CTA ═══ -->
  <section class="pt-[16px] pb-[16px] sm:pt-[24px] sm:pb-[24px]">
    <div class="page-container max-w-[1140px] px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px]">
      <div class="bg-[#D9222A] rounded-[20px] sm:rounded-[28px] px-[24px] sm:px-[40px] md:px-[56px] py-[36px] sm:py-[48px] md:py-[56px] grid md:grid-cols-[1fr_auto] gap-[24px] md:gap-[40px] items-center">
        <div>
          <p class="!text-white/80 uppercase font-medium text-[10px] sm:text-[11px] mb-[10px]" style="letter-spacing: 1.5px;">Gratis nedladdning</p>
          <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[8px] sm:mb-[10px]" style="font-size: clamp(1.25rem, 2.5vw, 1.75rem); line-height: 1.2; text-wrap: balance;">
            Vill du ha hela guiden som PDF?
          </h3>
          <p class="!text-white/90 text-[14px] sm:text-[15px] leading-relaxed max-w-[520px]">
            Beslutsmodell, formatval, pappersguide, mjukband vs hårdband, omslag, ryggbredd, original och korrektur — i ett paket.
          </p>
        </div>
        <a href="/produkter/bocker/infografik" class="btn-pill w-full md:w-auto justify-center md:justify-start whitespace-nowrap" style="background: #fff; color: #222;">
          Ladda ner guiden<Fragment set:html={downloadSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ ISBN & RYGGBREDD ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[920px]">
      <p class="section-label">ISBN, ryggbredd & omslagsfil</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px]" style="font-size: clamp(1.5rem, 3.5vw, 2.5rem); line-height: 1.1; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
        Detaljerna som ofta avgör om boken känns färdig.
      </h2>
      <div class="grid sm:grid-cols-2 gap-[16px] sm:gap-[20px]">
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Ryggbredd</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Beräknas av slutligt sidantal och papperets tjocklek. Stäm av med tryckeriet innan omslagsfilen låses.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Omslagsfil</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Bygg som en sammanhängande fil med framsida, rygg, baksida, utfall och eventuella biglinjer.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">ISBN</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Internationellt standardnummer som identifierar en specifik bokutgåva. Behövs ofta vid försäljning eller distribution via bokhandel.</p>
        </div>
        <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] mb-[8px]">Streckkod</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Kombineras ofta med ISBN på baksidan. Planeras tillsammans med omslaget när boken ska säljas.</p>
        </div>
      </div>
      <p class="text-[14px] sm:text-[15px] md:text-[16px] text-[#333] mt-[24px] sm:mt-[32px] leading-[1.7]">
        För interna böcker, jubileumsböcker, föreningsmaterial, rapporter eller manualer behövs ISBN inte alltid. Om du är osäker — ta upp det med oss innan omslaget färdigställs.
      </p>
    </div>
  </section>

  <!-- ═══ SLUT-CTA ═══ -->
  <section class="page-section pt-0">
    <div class="page-container max-w-[1300px]">
      <div class="bg-[#222] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] px-[24px] sm:px-[44px] md:px-[60px] lg:px-[80px] py-[48px] sm:py-[72px] md:py-[96px] grid lg:grid-cols-[1.3fr_1fr] gap-[32px] lg:gap-[60px] items-center">
        <div>
          <p class="section-label" style="color: rgba(255,255,255,0.6); margin-bottom: 16px;">Behöver du trycka en bok?</p>
          <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[16px] sm:mb-[24px]" style="font-size: clamp(1.75rem, 4vw, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
            Berätta vad boken ska bli — vi hjälper med resten.
          </h2>
          <p class="!text-white/70 text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed" style="text-wrap: pretty;">
            Jubileumsbok, manual, rapport, fotobok eller roman. Skicka din idé, skiss eller färdiga PDF — vi går igenom format, papper, bindning, omslag, original, tryckmetod och en tydlig offert.
          </p>
        </div>
        <div class="flex flex-col gap-[12px]">
          <a href="/offert" class="btn-pill btn-red w-full justify-center">
            Begär offert på boktryck<Fragment set:html={arrowSvg} />
          </a>
          <a href="/produkter/bocker/infografik" class="btn-pill w-full justify-center" style="background: white; color: #222;">
            Ladda ner guiden (PDF)<Fragment set:html={downloadSvg} />
          </a>
          <a href="/produkter/bocker" class="btn-pill w-full justify-center" style="background: rgba(255,255,255,0.10); color: #fff;">
            Se produktsidan<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-container { width: 100%; max-width: 1440px; margin-left: auto; margin-right: auto; }

  .page-section { padding-top: 56px; padding-bottom: 56px; padding-left: 16px; padding-right: 16px; }
  @media (min-width: 640px) { .page-section { padding-top: 72px; padding-bottom: 72px; padding-left: 24px; padding-right: 24px; } }
  @media (min-width: 768px) { .page-section { padding-top: 88px; padding-bottom: 88px; } }
  @media (min-width: 1024px) { .page-section { padding-top: 112px; padding-bottom: 112px; padding-left: 44px; padding-right: 44px; } }

  .page-section-no-px { padding-top: 48px; padding-bottom: 48px; }
  @media (min-width: 640px) { .page-section-no-px { padding-top: 56px; padding-bottom: 56px; } }
  @media (min-width: 768px) { .page-section-no-px { padding-top: 72px; padding-bottom: 72px; } }
  @media (min-width: 1024px) { .page-section-no-px { padding-top: 88px; padding-bottom: 88px; } }

  .section-label { font-family: var(--font-body); font-size: 11px; line-height: 1; letter-spacing: 1.5px; text-transform: uppercase; font-weight: 500; color: #888; margin-bottom: 16px; }
  @media (min-width: 768px) { .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 20px; } }

  .hero-pdf { overflow: visible; position: relative; z-index: 1; }
  .form-section-cover { position: relative; z-index: 2; background: #fff; }
  .pdf-teaser-wrap { display: flex; justify-content: center; align-items: flex-end; position: relative; margin-bottom: -210px; }
  .pdf-teaser {
    position: relative; width: 240px; max-width: 100%;
    aspect-ratio: 1833 / 2700; border-radius: 10px; overflow: hidden; background: #fff;
    box-shadow: 0 1px 2px rgba(0,0,0,0.06), 0 14px 28px rgba(0,0,0,0.10), 0 40px 80px rgba(0,0,0,0.18);
    transform: rotate(3deg); transform-origin: top center;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1); will-change: transform;
  }
  .pdf-teaser:hover { transform: rotate(3deg) translateY(-6px); }
  .pdf-teaser img { width: 100%; height: 100%; object-fit: cover; object-position: top; display: block; }
  .pdf-badge {
    position: absolute; top: 12px; right: 12px;
    background: #D9222A; color: #fff;
    font-family: var(--font-heading); font-size: 10px; font-weight: 600; letter-spacing: 1.2px;
    padding: 5px 9px; border-radius: 4px; text-transform: uppercase; z-index: 2;
  }
  @media (min-width: 640px) { .pdf-teaser-wrap { margin-bottom: -240px; } .pdf-teaser { width: 280px; } }
  @media (min-width: 1024px) { .pdf-teaser-wrap { align-self: end; margin-bottom: -300px; } .pdf-teaser { width: 360px; } }
  @media (min-width: 1440px) { .pdf-teaser-wrap { margin-bottom: -340px; } .pdf-teaser { width: 400px; } }
</style>

<script>
  function initGuide() {
    const carousel = document.getElementById('steps-carousel');
    const cardWidth = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('steps-prev')?.addEventListener('click', () => { carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' }); });
    document.getElementById('steps-next')?.addEventListener('click', () => { carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' }); });
  }
  initGuide();
  document.addEventListener('astro:after-swap', initGuide);
</script>
