  <!-- ═══ FAQ ═══ -->
  <section class="page-section">
    <div class="max-w-[1140px] mx-auto">
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
