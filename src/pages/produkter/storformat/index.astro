            Berätta om ditt projekt.
          </h3>
          <p class="text-[15px] sm:text-[16px] leading-relaxed text-[#444] mb-[24px] sm:mb-[36px] max-w-[480px]">
            Vill du trycka roll up, banderoll, affisch eller annat storformat? Berätta var det ska synas, så rekommenderar vi material, format och lösning.
          </p>
          <div class="space-y-[8px] text-[14px] sm:text-[15px] text-[#222]">
            <p><strong class="font-bold">Telefon:</strong> 08-96 01 35</p>
            <p><strong class="font-bold">E-post:</strong> <a href="mailto:tryckeri@norrmalmstryckeriet.se" class="text-[#D9222A] hover:underline break-all">tryckeri@norrmalmstryckeriet.se</a></p>
            <p><strong class="font-bold">Besök:</strong> Hammarbacken 4A, Sollentuna (15 min från city)</p>
          </div>
        </div>
        <div>
          <form class="space-y-[10px] sm:space-y-[12px]" action="#" method="post">
            <input type="text" name="name" placeholder="Ditt namn" required class="form-input" />
            <input type="text" name="company" placeholder="Företagsnamn" class="form-input" />
            <input type="email" name="email" placeholder="E-post" required class="form-input" />
            <input type="tel" name="phone" placeholder="Telefon" class="form-input" />
            <textarea name="message" placeholder="Berätta kort om ditt projekt..." rows="5" class="form-input resize-none"></textarea>
            <button type="submit" class="btn-pill mt-[8px] w-full sm:w-auto justify-center" style="background: white; color: #222;">
              Skicka meddelande
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
  .hero-box {
    aspect-ratio: 1.4 / 1;
    min-height: 560px;
    max-height: 92vh;
    background: #161a2e;
  }
  @media (min-width: 1024px) {
    .hero-box { aspect-ratio: 1.75 / 1; min-height: 680px; max-height: 90vh; }
  }
  @media (min-width: 1440px) {
    .hero-box { aspect-ratio: 2 / 1; max-height: 88vh; }
  }
  @media (min-width: 1920px) {
    .hero-box { aspect-ratio: 2.2 / 1; max-height: 90vh; }
  }

  .page-section-no-px {
    padding-top: 48px;
    padding-bottom: 48px;
  }
  @media (min-width: 640px) {
    .page-section-no-px { padding-top: 56px; padding-bottom: 56px; }
  }
  @media (min-width: 768px) {
    .page-section-no-px { padding-top: 72px; padding-bottom: 72px; }
  }
  @media (min-width: 1024px) {
    .page-section-no-px { padding-top: 88px; padding-bottom: 88px; }
  }
</style>

<script>
  function initStorformat() {
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const plusIcon = btn.querySelector('.faq-plus') as HTMLElement;
        const minusIcon = btn.querySelector('.faq-minus') as HTMLElement;
        const isOpen = answer.classList.contains('is-open');
        document.querySelectorAll('.faq-answer').forEach((a) => {
          (a as HTMLElement).style.maxHeight = '0';
          a.classList.remove('is-open');
        });
        document.querySelectorAll('.faq-plus').forEach((p) => p.classList.remove('hidden'));
        document.querySelectorAll('.faq-minus').forEach((m) => m.classList.add('hidden'));
        if (!isOpen) {
          answer.classList.add('is-open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          plusIcon.classList.add('hidden');
          minusIcon.classList.remove('hidden');
        }
      });
    });

    const carousel = document.getElementById('scenario-carousel');
    const cardWidth = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('scenario-prev')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: -cardWidth, behavior: 'smooth' });
    });
    document.getElementById('scenario-next')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: cardWidth, behavior: 'smooth' });
    });
  }

  initStorformat();
  document.addEventListener('astro:after-swap', initStorformat);
</script>
