  <!-- ═══ HJÄLP? + FORMULÄR ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container max-w-[1300px]">
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px]">
