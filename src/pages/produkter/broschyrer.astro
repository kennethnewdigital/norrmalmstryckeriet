---
import Layout from '../../layouts/Layout.astro';

// 8 use case scenarios — exact copy from template
const scenarios = [
  {
    title: 'Mässa eller event?',
    body: 'Besökarna träffar 50 utställare på en dag. De tar med sig 5 broschyrer hem. Din ska vara en av dem – och den som faktiskt läses.',
    rec: 'A5 eller kvadratiskt format, 170-200g, matt laminering. Står ut i högen.',
  },
  {
    title: 'Företagspresentation?',
    body: 'Första intrycket sätts inom sekunder. En gedigen broschyr signalerar att ni tar er själva på allvar — och därmed kunden.',
    rec: 'A4 eller liggande format, limbunden, premiumpapper. Professionellt och hållbart.',
  },
  {
    title: 'Produktkatalog?',
    body: 'Dina kunder ska kunna bläddra, jämföra, drömma. En fysisk katalog gör det möjligt på ett sätt som en webbshop aldrig kan.',
    rec: 'A4 häftad eller limbunden, bestruket papper för skarpa produktbilder.',
  },
  {
    title: 'Säljmaterial för möten?',
    body: 'Du lämnar broschyren kvar efter mötet. Den fortsätter sälja när du gått. Den ska representera dig när du inte är där.',
    rec: 'Kompakt format, 12-16 sidor, folietryck på loggan. Premium men portabel.',
  },
  {
    title: 'Årsredovisning?',
    body: 'En årsredovisning är mer än siffror. Det är er historia, ert varumärke, ert ansikte utåt mot aktieägare och partners.',
    rec: 'A4 limbunden, obestruket premiumpapper, diskret foliedetaljer. Seriöst och hållbart.',
  },
  {
    title: 'Utbildningsmaterial?',
    body: 'Kursdeltagare behöver material som håller, som går att anteckna i, som tål att bläddras i hundra gånger.',
    rec: 'A4 spiralbunden, 100-120g obestruket, ligger plant för anteckningar.',
  },
  {
    title: 'Jubileumsskrift?',
    body: '50 år, 100 år, eller bara ett viktigt kapitel. En jubileumsbok ska kännas som den milstolpe den representerar.',
    rec: 'Trådhäftning eller limbunden, 150g obestruket, textilomslag. En bok att spara.',
  },
  {
    title: 'Direktutskick?',
    body: 'Brevlådan är inte död — den är mindre trängd. En broschyr som dimper ner hos rätt person vid rätt tid kan öppna dörrar.',
    rec: 'DL eller A5, självhäftande, 170g. Kompakt, personlig, direkt.',
  },
];

// Expertise items
const formats = [
  'A4 stående – Klassiskt. Passar produktkataloger och presentationer.',
  'A4 liggande – Visar bilder bättre. Perfekt för portföljer.',
  'A5 – Kompakt och portabelt. Mässfavorit.',
  'Kvadratiskt – Sticker ut. Modernt och annorlunda.',
  'DL/tredjedels A4 – Passar i kuvert och broschyrställ.',
];

const bindings = [
  'Häftning (klammer) – Upp till 64 sidor. Ekonomiskt, klassiskt.',
  'Limbindning – Från 40 sidor. Ligger plant, håller länge.',
  'Spiralbindning – Ligger helt plant. Bra för manualer.',
  'Wire-o – Dubbelspirar. Premium och funktionellt.',
  'Trådshäftning – Exklusivt. För jubileumspublikationer.',
];

const papers = [
  'Bestruket – Skarpa bilder, livfulla färger. Produktfokus.',
  'Obestruket – Naturlig känsla. Hållbarhet och värme.',
  '130-170g inlaga – Standard. Bra balans vikt/kvalitet.',
  '250-350g omslag – Stabilt omslag. Skyddar och imponerar.',
  'Matt/silk laminering – Skyddar och lyfter omslaget.',
];

// Customer quotes
const testimonials = [
  { quote: 'Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser.', author: 'Björn Jansson', role: 'Projektledare, Repro 8' },
  { quote: 'De har en suverän förmåga att hitta tryckekonomiska lösningar på våra kreativa idéer.', author: 'Susanne Fridolfsson', role: 'VD Gomorron Reklambyrå' },
  { quote: 'De visar gång på gång en service- och kvalitetsförmåga som passar våra höga krav.', author: 'Jesper Odelius', role: 'COO Set Up AB' },
  { quote: 'Norrmalms tryckeriet är en trygg och professionell partner. Trycket håller alltid absoluta världsklass och kommer på utlovad tid. Med andra ord, helt perfekt.', author: 'Patrick Kämpe', role: 'Jajja Media Group AB' },
];

// FAQ — exact from template
const faqs = [
  { q: 'Hur många sidor kan en broschyr ha?', a: 'Det beror på bindningen. Häftade broschyrer fungerar bäst med 8-64 sidor (sidantalet måste vara delbart med 4). Limbundna broschyrer kan ha från ca 40 sidor och uppåt — egentligen obegränsat. Vi hjälper dig anpassa innehållet till rätt format.' },
  { q: 'Vad är skillnaden mellan häftning och limbindning?', a: 'Häftning (klammerhäftning) är snabbare och billigare — arken viks och häftas i ryggen. Limbindning ger en "bok-känsla" med plan rygg och mer professionellt intryck. Limbundna broschyrer ligger också mer plant när de öppnas. Tumregeln: häftning upp till 64 sidor, limbindning från 40 sidor.' },
  { q: 'Vilken papperstjocklek rekommenderar ni för broschyrer?', a: 'För inlagan rekommenderar vi 130-170g bestruket eller obestruket beroende på bildinnehåll. För omslaget 250-350g, gärna med matt eller silk laminering för skydd och känsla. Vid många sidor kan tunnare papper (115g) vara smart för att hålla nere vikten.' },
  { q: 'Hur snabbt kan ni leverera broschyrer?', a: 'Standardleverans är 7-10 arbetsdagar för häftade broschyrer, något längre för limbundna. Express kan vi ofta lösa på 4-5 dagar. Har du bråttom? Ring oss — vi har löst många "omöjliga" deadlines genom åren.' },
  { q: 'Vad kostar det att trycka broschyrer?', a: 'Priset beror på format, sidantal, papper, bindning och upplaga. Som riktmärke: 100 st 16-sidiga A5 häftade från ca 2500 kr, 500 st från ca 4500 kr. Men varje projekt är unikt — kontakta oss för en exakt offert utan förbindelser.' },
  { q: 'Kan ni hjälpa till med design?', a: 'Vi har inte egen designavdelning, men vi samarbetar med duktiga grafiska formgivare som vi kan rekommendera. Vi ger också alltid feedback på original — upplösning, färgprofiler, utfall, säkerhetszoner. Skicka det du har så återkommer vi med synpunkter.' },
  { q: 'Är ni miljöcertifierade?', a: 'Ja, vi är Svanenmärkta. Det innebär miljöcertifierade papper, vattenbaserade lacker och ansvarsfull produktion. Du får trycksaker du kan vara stolt över — både för kvaliteten och för miljöavtrycket.' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka broschyrer i Stockholm | Norrmalmstryckeriet"
  description="Broschyrer som bygger förtroende. Vi hjälper dig välja format, sidantal, papper, bindning och tryckmetod efter syftet."
>

  <!-- ═══ HERO (samma form som startsidan) ═══ -->
  <section class="relative">
    <div class="mx-[34px] mt-[51px] rounded-[50px] overflow-hidden relative" style="aspect-ratio:1.75/1; max-height:85vh; background:#000;">
      <img
        src="/images/hero/hero-tryckpress.webp"
        alt="Tryckpress på Norrmalmstryckeriet"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none"></div>
      <div class="absolute bottom-[40px] left-[40px] right-[40px] md:bottom-[60px] md:left-[60px] md:right-[60px] z-10">
        <p class="!text-white/80 text-[14px] md:text-[16px] mb-[12px] tracking-wide uppercase">Varför broschyr?</p>
        <h1 class="typo-hero !text-white">
          Broschyrer.
        </h1>
        <p class="!text-white/90 max-w-[640px] mt-[20px] text-[16px] md:text-[18px] leading-relaxed">
          När du behöver en broschyr — vi hjälper dig välja format, sidantal, papper och bindning efter syftet.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP — "1000+" ═══ -->
  <section class="py-[40px] mx-[34px] overflow-hidden">
    <div class="flex flex-wrap justify-center items-center gap-[40px] md:gap-[80px] py-[10px]">
      <div class="flex items-center gap-[12px]">
        <span class="font-[var(--font-heading)] text-[#D9222A] text-[44px] md:text-[56px] leading-none">1000+</span>
        <span class="font-[var(--font-body)] text-[16px] text-[#222] opacity-80 max-w-[120px]">tryckta broschyrer årligen</span>
      </div>
      <div class="flex items-center gap-[10px]">
        <span class="w-[8px] h-[8px] rounded-full bg-[#D9222A]"></span>
        <span class="font-[var(--font-body)] text-[18px] text-[#222] opacity-80">100+ år</span>
      </div>
      <div class="flex items-center gap-[10px]">
        <span class="w-[8px] h-[8px] rounded-full bg-[#D9222A]"></span>
        <span class="font-[var(--font-body)] text-[18px] text-[#222] opacity-80">Svanenmärkt</span>
      </div>
    </div>
  </section>

  <!-- ═══ INTRO QUOTE ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-quote">
        En broschyr stannar kvar. <em>En PDF klickas lätt bort.</em>
      </h2>
      <p class="mt-[40px] max-w-[720px] text-[18px] leading-relaxed text-[#444]">
        En broschyr kan vara 8 eller 64 sidor. Det viktiga är att den gör jobbet. Berätta vad du vill uppnå – vi rekommenderar formatet.
      </p>
      <div class="mt-[40px] flex flex-wrap items-center gap-[16px]">
        <a href="/begar-offert" class="btn-pill btn-red">
          Offertförfrågan<Fragment set:html={arrowSvg} />
        </a>
        <a href="/wp-content/uploads/broschyr-infografik.pdf" class="font-[var(--font-body)] font-medium text-[#222] inline-flex items-center hover:underline">
          Ladda ner infografik<Fragment set:html={arrowSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ "Det handlar inte om sidor. Det handlar om syfte." — sidoscroll-kort ═══ -->
  <section class="pt-[80px] pb-[80px] bg-[#F3F3F3]">
    <div class="ml-[34px] mb-[40px] max-w-[1140px]">
      <h2 class="text-[#222] mb-[20px]">
        Det handlar inte om sidor. Det handlar om syfte.
      </h2>
      <p class="text-[#444] text-[18px] max-w-[720px]">
        En broschyr kan vara 8 eller 64 sidor. Det viktiga är att den gör jobbet. Berätta vad du vill uppnå – vi rekommenderar formatet.
      </p>
    </div>
    <div id="scenario-carousel" class="flex gap-[20px] overflow-x-auto scrollbar-hide ml-[34px] pr-[34px]">
      {scenarios.map((s) => (
        <div class="shrink-0 w-[420px] bg-white rounded-[16px] p-[34px] flex flex-col">
          <h3 class="typo-process-sub mb-[20px]">{s.title}</h3>
          <p class="text-[16px] leading-relaxed text-[#444] mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[20px] border-t border-[#D5D8DC]">
            <span class="block font-bold text-[#222] mb-[8px] text-[13px] uppercase tracking-wider">Vår rekommendation</span>
            <p class="text-[15px] leading-relaxed text-[#222]">{s.rec}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="flex justify-end gap-2 mt-4 mr-[34px]">
      <button id="scenario-prev" class="w-[44px] h-[44px] rounded-full bg-white flex items-center justify-center text-gray-300 hover:text-[#222] transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[44px] h-[44px] rounded-full bg-white flex items-center justify-center text-[#222] hover:bg-[#E5E5E5] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR — "Broschyrer kräver lite mer planering." ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <p class="!text-[#D9222A] text-[14px] md:text-[16px] mb-[20px] tracking-wide uppercase font-medium">Hur vi jobbar</p>
      <h2 class="typo-section-title text-[#222] mb-[60px] md:mb-[80px]">
        Broschyrer kräver lite mer planering.
      </h2>
      <div class="grid md:grid-cols-3 gap-[20px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h3 class="typo-process-sub mb-[16px]">Du berättar vad du vill uppnå</h3>
          <p>Du beskriver syfte, upplaga, målgrupp och hur broschyren ska användas. Vi lyssnar och ställer frågor.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h3 class="typo-process-sub mb-[16px]">Vi rekommenderar en lösning</h3>
          <p>Vi föreslår format, sidantal, papper, tryckmetod, bindning och eventuell efterbehandling — anpassat efter ditt syfte.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h3 class="typo-process-sub mb-[16px]">Du godkänner – vi producerar</h3>
          <p>Du får ett tydligt förslag och godkänner innan broschyren går till tryck. Sen sköter vi resten.</p>
        </div>
      </div>
      <div class="mt-[40px]">
        <a href="/begar-offert" class="btn-pill btn-red">
          Offertförfrågan<Fragment set:html={arrowSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP — "Broschyrer är ingen standardlösning." ═══ -->
  <section class="bg-[#F3F3F3]">
    <div class="max-w-[1140px] mx-auto px-[34px] py-[80px] md:py-[120px]">
      <p class="!text-[#D9222A] text-[14px] md:text-[16px] mb-[20px] tracking-wide uppercase font-medium">Varför vi inte har en webbshop</p>
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start">
        <div>
          <h2 class="text-[#222]">
            Broschyrer är ingen standardlösning.
          </h2>
        </div>
        <div>
          <p class="mb-6 leading-relaxed">
            Broschyrer är för komplexa för att vara en enkel standardlösning. Fel papper, fel bindning eller fel format kan förstöra hela intrycket.
          </p>
          <p class="mb-6 leading-relaxed">
            Hos webbtryckerier väljer du ur en meny. Hos oss får du rådgivning. Vi ställer frågor, ifrågasätter antaganden och föreslår alternativ du inte visste fanns.
          </p>
          <p class="mb-8 leading-relaxed font-medium text-[#222]">
            Resultatet? En broschyr som faktiskt fungerar — inte bara en som kostade minst.
          </p>
          <ul class="space-y-5 mt-8">
            <li>
              <strong class="block text-[#222] mb-1">Bindningen påverkar allt</strong>
              <span class="text-[#444]">Häftning, limbindning, spiralbindning — valet påverkar hur broschyren öppnas, ligger plant och upplevs. Vi hjälper dig välja rätt.</span>
            </li>
            <li>
              <strong class="block text-[#222] mb-1">Sidantal är inte bara matte</strong>
              <span class="text-[#444]">Häftade broschyrer måste ha sidantal delbara med 4. Limbundna har andra regler. Vi ser till att din design passar formatet.</span>
            </li>
            <li>
              <strong class="block text-[#222] mb-1">Provtryck sparar pengar</strong>
              <span class="text-[#444]">Vid större upplagor eller känsliga färger rekommenderar vi provtryck. Bättre att justera innan än att ångra efter.</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS — "Format, papper, bindning – vi kan det." ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <p class="!text-[#D9222A] text-[14px] md:text-[16px] mb-[20px] tracking-wide uppercase font-medium">Vår expertis</p>
      <h2 class="typo-section-title text-[#222] mb-[60px] md:mb-[80px]">
        Format, papper, bindning – vi kan det.
      </h2>
      <div class="grid md:grid-cols-3 gap-[40px]">
        <div>
          <h3 class="typo-process-sub mb-[16px]">Format</h3>
          <p class="mb-[20px] text-[16px] text-[#444]">Formatet påverkar hur broschyren upplevs och används. Olika situationer kräver olika format.</p>
          <ul class="space-y-3">
            {formats.map((f) => (
              <li class="flex items-start gap-2 text-[15px] text-[#222]">
                <span class="shrink-0 mt-[8px] w-[6px] h-[6px] rounded-full bg-[#D9222A]"></span>
                <span>{f}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="typo-process-sub mb-[16px]">Bindning</h3>
          <p class="mb-[20px] text-[16px] text-[#444]">Bindningen avgör hur broschyren beter sig. Välj rätt för ditt syfte.</p>
          <ul class="space-y-3">
            {bindings.map((b) => (
              <li class="flex items-start gap-2 text-[15px] text-[#222]">
                <span class="shrink-0 mt-[8px] w-[6px] h-[6px] rounded-full bg-[#D9222A]"></span>
                <span>{b}</span>
              </li>
            ))}
          </ul>
        </div>
        <div>
          <h3 class="typo-process-sub mb-[16px]">Papper &amp; finish</h3>
          <p class="mb-[20px] text-[16px] text-[#444]">Pappret är halva upplevelsen. Rätt val förstärker ditt budskap.</p>
          <ul class="space-y-3">
            {papers.map((p) => (
              <li class="flex items-start gap-2 text-[15px] text-[#222]">
                <span class="shrink-0 mt-[8px] w-[6px] h-[6px] rounded-full bg-[#D9222A]"></span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KUNDCITAT-CAROUSEL ═══ -->
  <section class="py-[80px] md:py-[120px] bg-[#222]">
    <div id="testimonials-carousel" class="flex gap-[20px] overflow-x-auto scrollbar-hide ml-[34px] pr-[34px] pl-0">
      {testimonials.map((t) => (
        <div class="shrink-0 w-[460px] md:w-[600px] bg-[#222] flex flex-col px-[34px]">
          <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="mb-[24px] text-white/30 shrink-0">
            <path d="M9.4 7.5C5.6 9.4 3 12.7 3 17.3c0 1.1.5 2 1.5 2.5.7.4 1.6.5 2.4.3.8-.2 1.5-.7 1.9-1.4.4-.7.5-1.5.3-2.3-.2-.8-.7-1.5-1.4-1.9-.7-.4-1.5-.5-2.3-.3.5-1.5 1.6-2.7 3.1-3.4.3-.2.6-.4.8-.7l-.9-2.6zm10 0c-3.8 1.9-6.4 5.2-6.4 9.8 0 1.1.5 2 1.5 2.5.7.4 1.6.5 2.4.3.8-.2 1.5-.7 1.9-1.4.4-.7.5-1.5.3-2.3-.2-.8-.7-1.5-1.4-1.9-.7-.4-1.5-.5-2.3-.3.5-1.5 1.6-2.7 3.1-3.4.3-.2.6-.4.8-.7l-.9-2.6z"/>
          </svg>
          <h3 class="typo-feature-heading !text-white mb-[24px]">"{t.quote}"</h3>
          <cite class="!text-white/70 text-[16px] not-italic">— {t.author}, {t.role}</cite>
        </div>
      ))}
    </div>
    <div class="flex justify-end gap-2 mt-[40px] mr-[34px]">
      <button id="testimonials-prev" class="w-[44px] h-[44px] rounded-full bg-white/10 flex items-center justify-center text-white/40 hover:bg-white/20 hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="testimonials-next" class="w-[44px] h-[44px] rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-white/20 transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ FAQ — "Vanliga frågor om broschyrer." ═══ -->
  <section class="max-w-[1140px] mx-auto px-[34px] py-[80px] md:py-[120px]">
    <h2 class="typo-section-title text-[#222] mb-[40px] md:mb-[60px]">
      Vanliga frågor om broschyrer.
    </h2>
    <div id="faq-list">
      {faqs.map((item) => (
        <div class="border-b border-[#D5D8DC]">
          <button class="faq-toggle w-full flex justify-between items-center py-[20px] px-[10px] text-left cursor-pointer">
            <span class="font-[var(--font-body)] text-[18px] text-[#222] pr-4">{item.q}</span>
            <span class="faq-icon shrink-0 w-[25px] h-[25px] flex items-center justify-center text-[#222]">
              <svg class="faq-plus" width="25" height="25" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
              <svg class="faq-minus hidden" width="25" height="25" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12H124c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h264c6.6 0 12 5.4 12 12v56z"/></svg>
