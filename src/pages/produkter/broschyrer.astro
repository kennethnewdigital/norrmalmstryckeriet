---
import Layout from '../../layouts/Layout.astro';

const stats = [
  { number: '3x', suffix: '', label: 'Längre engagemang', body: 'Fysiska broschyrer ger 8 gånger längre uppmärksamhet än digitala dokument enligt neurovetenskapliga studier.' },
  { number: '35', suffix: '%', label: 'Bättre minneseffekt', body: 'Fysiska material skapar starkare emotionella kopplingar och ökar chansen att mottagaren minns ditt budskap.' },
  { number: '17', suffix: '%', label: 'Högre respons', body: 'Kampanjer med fysiska broschyrer ger högre respons än enbart digitala kampanjer.' },
];

const scenarios = [
  { title: 'Mässa eller event?', body: 'Besökarna träffar 50 utställare på en dag. De tar med sig 5 broschyrer hem. Din ska vara en av dem – och den som faktiskt läses.', rec: 'A5 eller kvadratiskt format, 170-200g, matt laminering. Står ut i högen.' },
  { title: 'Företagspresentation?', body: 'Första intrycket sätts inom sekunder. En gedigen broschyr signalerar att ni tar er själva på allvar — och därmed kunden.', rec: 'A4 eller liggande format, limbunden, premiumpapper. Professionellt och hållbart.' },
  { title: 'Produktkatalog?', body: 'Dina kunder ska kunna bläddra, jämföra, drömma. En fysisk katalog gör det möjligt på ett sätt som en webbshop aldrig kan.', rec: 'A4 häftad eller limbunden, bestruket papper för skarpa produktbilder.' },
  { title: 'Säljmaterial för möten?', body: 'Du lämnar broschyren kvar efter mötet. Den fortsätter sälja när du gått. Den ska representera dig när du inte är där.', rec: 'Kompakt format, 12-16 sidor, folietryck på loggan. Premium men portabel.' },
  { title: 'Årsredovisning?', body: 'En årsredovisning är mer än siffror. Det är er historia, ert varumärke, ert ansikte utåt mot aktieägare och partners.', rec: 'A4 limbunden, obestruket premiumpapper, diskret foliedetaljer. Seriöst och hållbart.' },
  { title: 'Utbildningsmaterial?', body: 'Kursdeltagare behöver material som håller, som går att anteckna i, som tål att bläddras i hundra gånger.', rec: 'A4 spiralbunden, 100-120g obestruket, ligger plant för anteckningar.' },
  { title: 'Jubileumsskrift?', body: '50 år, 100 år, eller bara ett viktigt kapitel. En jubileumsbok ska kännas som den milstolpe den representerar.', rec: 'Trådhäftning eller limbunden, 150g obestruket, textilomslag. En bok att spara.' },
  { title: 'Direktutskick?', body: 'Brevlådan är inte död — den är mindre trängd. En broschyr som dimper ner hos rätt person vid rätt tid kan öppna dörrar.', rec: 'DL eller A5, självhäftande, 170g. Kompakt, personlig, direkt.' },
];

const expertTips = [
  { title: 'Bindningen påverkar allt', body: 'Häftning, limbindning, spiralbindning — valet påverkar hur broschyren öppnas, ligger plant och upplevs. Vi hjälper dig välja rätt.' },
  { title: 'Sidantal är inte bara matte', body: 'Häftade broschyrer måste ha sidantal delbara med 4. Limbundna har andra regler. Vi ser till att din design passar formatet.' },
  { title: 'Provtryck sparar pengar', body: 'Vid större upplagor eller känsliga färger rekommenderar vi provtryck. Bättre att justera innan än att ångra efter.' },
];

const expertise = [
  {
    title: 'Format',
    intro: 'Formatet påverkar hur broschyren upplevs och används. Olika situationer kräver olika format.',
    items: [
      ['A4 stående', 'Klassiskt. Passar produktkataloger och presentationer.'],
      ['A4 liggande', 'Visar bilder bättre. Perfekt för portföljer.'],
      ['A5', 'Kompakt och portabelt. Mässfavorit.'],
      ['Kvadratiskt', 'Sticker ut. Modernt och annorlunda.'],
      ['DL/tredjedels A4', 'Passar i kuvert och broschyrställ.'],
    ],
  },
  {
    title: 'Bindning',
    intro: 'Bindningen avgör hur broschyren beter sig. Välj rätt för ditt syfte.',
    items: [
      ['Häftning (klammer)', 'Upp till 64 sidor. Ekonomiskt, klassiskt.'],
      ['Limbindning', 'Från 40 sidor. Ligger plant, håller länge.'],
      ['Spiralbindning', 'Ligger helt plant. Bra för manualer.'],
      ['Wire-o', 'Dubbelspirar. Premium och funktionellt.'],
      ['Trådshäftning', 'Exklusivt. För jubileumspublikationer.'],
    ],
  },
  {
    title: 'Papper & finish',
    intro: 'Pappret är halva upplevelsen. Rätt val förstärker ditt budskap.',
    items: [
      ['Bestruket', 'Skarpa bilder, livfulla färger. Produktfokus.'],
      ['Obestruket', 'Naturlig känsla. Hållbarhet och värme.'],
      ['130-170g inlaga', 'Standard. Bra balans vikt/kvalitet.'],
      ['250-350g omslag', 'Stabilt omslag. Skyddar och imponerar.'],
      ['Matt/silk laminering', 'Skyddar och lyfter omslaget.'],
    ],
  },
];

const testimonials = [
  { quote: 'Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser.', author: 'Björn Jansson', role: 'Projektledare, Repro 8' },
  { quote: 'De har en suverän förmåga att hitta tryckekonomiska lösningar på våra kreativa idéer.', author: 'Susanne Fridolfsson', role: 'VD Gomorron Reklambyrå' },
  { quote: 'De visar gång på gång en service- och kvalitetsförmåga som passar våra höga krav.', author: 'Jesper Odelius', role: 'COO Set Up AB' },
  { quote: 'Norrmalms tryckeriet är en trygg och professionell partner. Trycket håller alltid absoluta världsklass och kommer på utlovad tid. Med andra ord, helt perfekt.', author: 'Patrick Kämpe', role: 'Jajja Media Group AB' },
];

const faqs = [
  { q: 'Hur många sidor kan en broschyr ha?', a: 'Det beror på bindningen. Häftade broschyrer fungerar bäst med 8-64 sidor (sidantalet måste vara delbart med 4). Limbundna broschyrer kan ha från ca 40 sidor och uppåt — egentligen obegränsat. Vi hjälper dig anpassa innehållet till rätt format.' },
  { q: 'Vad är skillnaden mellan häftning och limbindning?', a: 'Häftning (klammerhäftning) är snabbare och billigare — arken viks och häftas i ryggen. Limbindning ger en "bok-känsla" med plan rygg och mer professionellt intryck. Limbundna broschyrer ligger också mer plant när de öppnas. Tumregeln: häftning upp till 64 sidor, limbindning från 40 sidor.' },
  { q: 'Vilken papperstjocklek rekommenderar ni för broschyrer?', a: 'För inlagan rekommenderar vi 130-170g bestruket eller obestruket beroende på bildinnehåll. För omslaget 250-350g, gärna med matt eller silk laminering för skydd och känsla. Vid många sidor kan tunnare papper (115g) vara smart för att hålla nere vikten.' },
  { q: 'Hur snabbt kan ni leverera broschyrer?', a: 'Standardleverans är 7-10 arbetsdagar för häftade broschyrer, något längre för limbundna. Express kan vi ofta lösa på 4-5 dagar. Har du bråttom? Ring oss — vi har löst många "omöjliga" deadlines genom åren.' },
  { q: 'Vad kostar det att trycka broschyrer?', a: 'Priset beror på format, sidantal, papper, bindning och upplaga. Som riktmärke: 100 st 16-sidiga A5 häftade från ca 2500 kr, 500 st från ca 4500 kr. Men varje projekt är unikt — kontakta oss för en exakt offert utan förbindelser.' },
  { q: 'Kan ni hjälpa till med design?', a: 'Vi har inte egen designavdelning, men vi samarbetar med duktiga grafiska formgivare som vi kan rekommendera. Vi ger också alltid feedback på original — upplösning, färgprofiler, utfall, säkerhetszoner. Skicka det du har så återkommer vi med synpunkter.' },
  { q: 'Är ni miljöcertifierade?', a: 'Ja, vi är Svanenmärkta. Det innebär miljöcertifierade papper, vattenbaserade lacker och ansvarsfull produktion. Du får trycksaker du kan vara stolt över — både för kvaliteten och för miljöavtrycket.' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka broschyrer i Stockholm | Norrmalmstryckeriet"
  description="Broschyrer som bygger förtroende. Vi hjälper dig välja format, sidantal, papper, bindning och tryckmetod efter syftet."
>

  <!-- ═══ HERO (FULLBREDD med bakgrundsbild) ═══ -->
  <section class="relative w-full" style="background-image: url('/images/hero/hero-broschyr.webp'); background-size: cover; background-position: center; min-height: 700px;">
    <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>
    <div class="relative z-10 max-w-[1300px] mx-auto px-[34px] py-[100px] md:py-[140px]">
      <p class="!text-white/80 text-[12px] md:text-[13px] mb-[20px] tracking-[0.2em] uppercase font-medium">Tryckeri Stockholm • Sollentuna / Häggvik</p>
      <h1 class="typo-hero !text-white mb-[24px]">
        Broschyrer.
      </h1>
      <p class="!text-white/90 max-w-[560px] text-[16px] md:text-[18px] leading-relaxed mb-[40px]">
        En broschyr är ingen snabbfix. Det är ett säljverktyg som arbetar för dig — på mässan, i mötet, i brevlådan. Vi hjälper dig välja rätt format, papper och bindning så att resultatet motsvarar ambitionen.
      </p>
      <div class="flex flex-wrap items-center gap-[16px] mb-[60px]">
        <a href="/begar-offert" class="btn-pill btn-red">
          Offertförfrågan<Fragment set:html={arrowSvg} />
        </a>
        <a href="tel:+4686210090" class="inline-flex items-center font-[var(--font-body)] font-medium text-[15px] px-[28px] py-[14px] rounded-full border-2 border-white text-white hover:bg-white hover:text-[#222] transition-colors">
          Ring 08-96 01 35
        </a>
      </div>
      <div class="flex flex-wrap items-end gap-[40px] md:gap-[60px]">
        <div>
          <div class="!text-white font-[var(--font-heading)] text-[34px] md:text-[42px] leading-none">100+ år</div>
          <div class="!text-white/70 text-[11px] md:text-[12px] tracking-[0.15em] uppercase mt-[4px]">År av erfarenhet</div>
        </div>
        <div>
          <div class="!text-white font-[var(--font-heading)] text-[34px] md:text-[42px] leading-none">1000+</div>
          <div class="!text-white/70 text-[11px] md:text-[12px] tracking-[0.15em] uppercase mt-[4px]">Uppdrag årligen</div>
        </div>
        <div class="flex items-center gap-[12px]">
          <div class="w-[44px] h-[44px] rounded-full bg-[#7CB342] flex items-center justify-center">
            <span class="text-white text-[20px] font-bold">✓</span>
          </div>
          <div class="!text-white text-[12px] tracking-[0.15em] uppercase">Svanenmärkt</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR BROSCHYR?" - quote + stat cards ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="max-w-[1300px] mx-auto px-[34px]">
      <p class="text-[#888] text-[11px] md:text-[12px] mb-[24px] tracking-[0.2em] uppercase font-medium">Varför broschyr?</p>
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start mb-[80px]">
        <h2 class="typo-quote">
          En broschyr stannar kvar. <span class="block">En PDF klickas lätt bort.</span>
        </h2>
        <div class="md:pt-[20px]">
          <p class="text-[18px] leading-relaxed text-[#222] mb-[28px]">
            I en digital värld är det fysiska en konkurrensfördel. En välgjord broschyr kommunicerar kvalitet innan den ens öppnats.
          </p>
          <a href="/wp-content/uploads/broschyr-infografik.pdf" class="inline-flex items-center px-[28px] py-[14px] rounded-full bg-[#222] text-white text-[15px] font-medium hover:bg-[#000] transition-colors">
            Ladda ner infografik
          </a>
        </div>
      </div>
      <div class="grid md:grid-cols-3 gap-[20px] md:gap-[24px]">
        {stats.map((s) => (
          <div class="bg-[#EAEAEA] rounded-[20px] p-[40px] md:p-[50px] min-h-[280px] flex flex-col">
            <div class="font-[var(--font-heading)] text-[#222] leading-none mb-[16px]">
              <span class="text-[clamp(3.5rem,6vw,5.5rem)]">{s.number}</span><span class="text-[clamp(2rem,3.5vw,3rem)]">{s.suffix}</span>
            </div>
            <h3 class="text-[18px] md:text-[20px] text-[#222] font-[var(--font-body)] font-medium mb-[20px]">{s.label}</h3>
            <p class="text-[15px] leading-relaxed text-[#555]">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ "Det handlar inte om sidor. Det handlar om syfte." (sidoscroll-kort) ═══ -->
  <section class="pt-[80px] pb-[120px]">
    <div class="max-w-[1300px] mx-auto px-[34px] mb-[40px]">
      <p class="text-[#888] text-[11px] md:text-[12px] mb-[24px] tracking-[0.2em] uppercase font-medium">När du behöver en broschyr</p>
      <h2 class="typo-section-title text-[#222] mb-[20px]">
        Det handlar inte om sidor. Det handlar om syfte.
      </h2>
      <p class="text-[#555] text-[16px] md:text-[18px] max-w-[720px]">
        En broschyr kan vara 8 eller 64 sidor. Det viktiga är att den gör jobbet. Berätta vad du vill uppnå – vi rekommenderar formatet.
      </p>
    </div>
    <div id="scenario-carousel" class="flex gap-[20px] overflow-x-auto scrollbar-hide pl-[34px] pr-[34px]">
      {scenarios.map((s) => (
        <article class="shrink-0 w-[300px] bg-[#EAEAEA] rounded-[16px] p-[34px] flex flex-col min-h-[400px]">
          <h3 class="font-[var(--font-heading)] text-[24px] text-[#222] mb-[20px]">{s.title}</h3>
          <p class="text-[14px] leading-relaxed text-[#444] mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[20px]">
            <div class="border-t border-[#C8C8C8] pt-[20px]">
              <p class="text-[14px] leading-relaxed text-[#222]">
                <strong class="font-bold">Vår rekommendation:</strong> {s.rec}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
    <div class="max-w-[1300px] mx-auto px-[34px] flex justify-end gap-[8px] mt-[24px]">
      <button id="scenario-prev" class="w-[44px] h-[44px] rounded-full bg-[#EAEAEA] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[44px] h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR (centrerad, ingen bg) ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="max-w-[1140px] mx-auto px-[34px] text-center">
      <p class="text-[#888] text-[11px] md:text-[12px] mb-[24px] tracking-[0.2em] uppercase font-medium">Hur vi jobbar</p>
      <h2 class="typo-section-title text-[#222] mb-[20px]">
        Broschyrer kräver lite mer planering.
      </h2>
      <p class="text-[#555] text-[16px] md:text-[18px] mb-[80px]">
        Men processen behöver inte vara komplicerad.
      </p>
      <div class="grid md:grid-cols-3 gap-[40px] md:gap-[60px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h3 class="font-[var(--font-heading)] text-[22px] md:text-[26px] text-[#222] mb-[16px]">Du berättar vad du vill uppnå</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Mässa? Kundmöte? Direktutskick? Vi behöver förstå sammanhanget för att kunna rekommendera rätt format, papper och bindning.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h3 class="font-[var(--font-heading)] text-[22px] md:text-[26px] text-[#222] mb-[16px]">Vi rekommenderar en lösning</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Baserat på upplaga, budget och syfte föreslår vi den kombination som ger bäst resultat. Inte den dyraste — den rätta.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h3 class="font-[var(--font-heading)] text-[22px] md:text-[26px] text-[#222] mb-[16px]">Du godkänner – vi producerar</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Du får en tydlig offert och provtryck vid behov. När du säger ja sköter vi resten: tryck, bindning, leverans.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP (grå sektion, 2 kolumner) ═══ -->
  <section class="bg-[#EFEFEF]">
    <div class="max-w-[1300px] mx-auto px-[34px] py-[100px] md:py-[140px]">
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px]">
        <div>
          <p class="text-[#888] text-[11px] md:text-[12px] mb-[24px] tracking-[0.2em] uppercase font-medium">Varför vi inte har en webbshop</p>
          <h2 class="typo-section-title text-[#222] mb-[40px]">
            Broschyrer är ingen standardlösning.
          </h2>
          <div class="space-y-[20px] text-[16px] leading-relaxed text-[#444]">
            <p>Broschyrer är för komplexa för att vara en enkel standardlösning. Fel papper, fel bindning eller fel format kan förstöra hela intrycket.</p>
            <p>Hos webbtryckerier väljer du ur en meny. Hos oss får du rådgivning. Vi ställer frågor, ifrågasätter antaganden och föreslår alternativ du inte visste fanns.</p>
            <p class="text-[#222] font-medium">Resultatet? En broschyr som faktiskt fungerar — inte bara en som kostade minst.</p>
          </div>
        </div>
        <div>
          <div class="space-y-[32px]">
            {expertTips.map((t) => (
              <div>
                <h3 class="font-[var(--font-body)] font-bold text-[16px] md:text-[17px] text-[#222] mb-[8px]">{t.title}</h3>
                <p class="text-[15px] leading-relaxed text-[#555]">{t.body}</p>
              </div>
            ))}
            <div class="pt-[12px]">
              <a href="/kontakta-oss" class="inline-flex items-center text-[#222] font-medium hover:underline">
                Hjälp? Kontakta oss<Fragment set:html={arrowSvg} />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (MÖRK) ═══ -->
  <section class="bg-[#1F1F1F]">
    <div class="max-w-[1300px] mx-auto px-[34px] py-[100px] md:py-[140px]">
      <p class="!text-white/60 text-[11px] md:text-[12px] mb-[24px] tracking-[0.2em] uppercase font-medium">Vår expertis</p>
      <h2 class="typo-section-title !text-white mb-[20px]">
        Format, papper, bindning – vi kan det.
      </h2>
      <p class="!text-white/70 text-[16px] md:text-[18px] mb-[60px] md:mb-[80px] max-w-[720px]">
        Du behöver inte vara expert på broschyrer. Men vi är det. Här är grunderna.
      </p>
      <div class="grid md:grid-cols-3 gap-[24px]">
        {expertise.map((e) => (
          <div class="bg-[#2A2A2A] rounded-[16px] p-[40px]">
            <h3 class="font-[var(--font-heading)] text-[28px] md:text-[32px] !text-white mb-[20px]">{e.title}</h3>
            <p class="!text-white/70 text-[15px] leading-relaxed mb-[24px]">{e.intro}</p>
            <div class="space-y-[14px]">
              {e.items.map(([term, desc]) => (
                <p class="text-[14px] leading-relaxed !text-white/80">
                  <strong class="!text-white font-bold">{term}</strong> – {desc}
                </p>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ KUNDCITAT-CAROUSEL (vit bg, centrerat, dots) ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <div id="testimonials-track" class="relative overflow-hidden">
        <div id="testimonials-slides" class="flex transition-transform duration-500 ease-out">
          {testimonials.map((t) => (
            <div class="testimonial-slide shrink-0 w-full text-center px-[20px] md:px-[60px]">
              <p class="font-[var(--font-heading)] text-[clamp(1.5rem,2.8vw,2.5rem)] leading-[1.3] text-[#222] mb-[40px]">
                &ldquo;{t.quote}&rdquo;
              </p>
              <div class="text-[15px]">
                <span class="font-bold text-[#222]">{t.author}</span>
                <span class="text-[#666]"> – {t.role}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="flex justify-center gap-[10px] mt-[40px]" id="testimonials-dots">
        {testimonials.map((_, i) => (
          <button class="testimonial-dot w-[8px] h-[8px] rounded-full bg-[#D5D8DC] transition-colors" data-index={i} aria-label={`Citat ${i + 1}`}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="max-w-[1140px] mx-auto px-[34px] py-[80px] md:py-[120px]">
    <h2 class="typo-section-title text-[#222] mb-[20px]">
      Vanliga frågor om broschyrer.
    </h2>
    <p class="text-[15px] text-[#555] mb-[40px] md:mb-[60px]">
      Har du fler frågor? Ring oss på <strong class="text-[#222]">08-96 01 35</strong> – vi svarar gärna.
    </p>
    <div id="faq-list">
      {faqs.map((item) => (
        <div class="border-b border-[#D5D8DC]">
          <button class="faq-toggle w-full flex justify-between items-center py-[20px] px-[10px] text-left cursor-pointer">
            <span class="font-[var(--font-body)] font-bold text-[16px] md:text-[18px] text-[#222] pr-4">{item.q}</span>
            <span class="faq-icon shrink-0 w-[28px] h-[28px] flex items-center justify-center text-[#D9222A]">
              <svg class="faq-plus" width="28" height="28" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
              <svg class="faq-minus hidden" width="28" height="28" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12H124c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h264c6.6 0 12 5.4 12 12v56z"/></svg>
            </span>
          </button>
          <div class="faq-answer text-[16px] leading-[1.7] pb-[20px] px-[10px] text-[#444]">
            <p>{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ HJÄLP? (kontaktformulär) ═══ -->
  <section class="bg-[#EFEFEF] mt-[40px]">
