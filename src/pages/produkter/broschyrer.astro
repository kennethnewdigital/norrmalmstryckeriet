---
import Layout from '../../layouts/Layout.astro';

const effects = [
  'Mer plats för förklaring och bild',
  'Tydlig läsordning över flera sidor',
  'Rätt känsla för företag, produkt och varumärke',
  'Möjlighet till häftning, limbindning och finish',
];

const scenarios = [
  {
    title: 'Du ska presentera företaget',
    body: 'Du behöver visa verksamhet, erbjudande, människor och kontaktvägar i en tydlig helhet. Konsekvensen blir att innehållet behöver en röd tråd över flera sidor.',
    rec: 'A5 eller A4, 8–12 sidor, fullfärg 4+4, silk eller obestruket papper och häftning eller limbindning efter sidantal.',
  },
  {
    title: 'Du ska göra en produktbroschyr',
    body: 'Du behöver visa bilder, funktioner, användning och fördelar utan att allt trängs på en sida. Konsekvensen blir att format och sidflöde behöver hjälpa kunden att jämföra och förstå.',
    rec: 'A4 vid mer information, fullfärg, papper med bra bildåtergivning och tydliga avsnitt för produkt, nytta och kontakt.',
  },
  {
    title: 'Du ska skapa en kampanjbroschyr',
    body: 'Du vill samla erbjudande, argument och nästa steg i ett material som känns mer genomarbetat än ett blad. Konsekvensen blir att första sidan behöver väcka intresse och insidorna bygga förtroende.',
    rec: 'A5, 8 sidor, digitaltryck vid mindre upplaga och offsettryck vid större upplaga.',
  },
  {
    title: 'Du ska ta fram utbildningsmaterial',
    body: 'Du behöver ett häfte som går att läsa i ordning, anteckna i och spara. Konsekvensen blir att läsbarhet, papper och bindning blir viktiga för användningen.',
    rec: 'A4 eller A5, obestruket papper, tydlig sidnumrering och häftning eller limbindning beroende på sidantal.',
  },
  {
    title: 'Du ska trycka till mässa',
    body: 'Du behöver ett material som ger mer fördjupning än ett reklamblad och som kan tas med vidare. Konsekvensen blir att broschyren behöver vara lätt att dela ut, lätt att bläddra i och tydlig i avslutet.',
    rec: 'A5, 8–12 sidor, fullfärg, kraftigare omslag och tydlig kontakt på baksidan.',
  },
  {
    title: 'Du vill skapa premiumkänsla',
    body: 'Du behöver en broschyr som speglar varumärket och känns genomarbetad i handen. Konsekvensen blir att papper, omslag och efterbehandling påverkar helhetsintrycket.',
    rec: 'Högre gramvikt på omslag, silk eller bestruket papper, laminering, prägling eller foliering där känslan ska förstärkas.',
  },
];

const testimonial = {
  quote: 'Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser.',
  author: 'Björn Jansson',
  role: 'Projektledare, Repro 8',
};

const faqs = [
  { q: 'Vad är skillnaden mellan folder och broschyr?', a: 'En folder är ofta ett vikt blad med färre ytor. En broschyr har flera sidor och passar när innehållet behöver mer struktur.' },
  { q: 'När passar en broschyr bäst?', a: 'Broschyrer passar företagspresentationer, produktinformation, kampanjer och utbildningsmaterial. De fungerar när mottagaren behöver läsa mer än ett kort budskap.' },
  { q: 'Vilket format ska jag välja?', a: 'A5 passar när broschyren ska vara lätt att dela ut och ta med. A4 passar när bilder, tabeller eller längre texter behöver mer utrymme.' },
  { q: 'Vad påverkar priset på en broschyr?', a: 'Sidantal, format, upplaga, papper, tryckmetod, bindning och efterbehandling påverkar priset. Vi rekommenderar val efter innehåll och användning.' },
  { q: 'När passar digitaltryck?', a: 'Digitaltryck passar ofta mindre upplagor och flexibla produktioner. Det är ett bra val när materialet ska tas fram i begränsad mängd.' },
  { q: 'När passar offsettryck?', a: 'Offsettryck passar ofta större upplagor. Det kan ge bra styckekonomi och jämn färgåtergivning vid volym.' },
  { q: 'Kan broschyren få en mer exklusiv känsla?', a: 'Ja. Omslag, gramvikt, laminering, prägling eller foliering kan göra broschyren mer bearbetad. Valet bör kopplas till varumärke, mottagare och användning.' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka broschyrer – format, papper och bindning | Norrmalmstryckeriet"
  description="Tryck broschyrer för företag, produkt, kampanj och utbildning. Vi hjälper dig välja format, sidantal, papper, tryckmetod och bindning."
>

  <!-- ═══ HERO (rundad mx-[44px], rounded-[50px]) ═══ -->
  <section class="relative">
    <div class="mx-[44px] mt-[66px] rounded-[50px] overflow-hidden relative" style="background-image: url('/images/hero/hero-broschyr.webp'); background-size: cover; background-position: center; min-height: 720px;">
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/35 to-transparent"></div>
      <div class="relative z-10 px-[60px] md:px-[88px] py-[80px] md:py-[120px]">
        <p class="!text-white mb-[20px] uppercase font-medium" style="font-size:12px; letter-spacing:1.8px; line-height:1;">Tryckeri Stockholm • Sollentuna / häggvik</p>
        <h1 class="font-[var(--font-heading)] !font-normal !text-white mb-[24px]" style="font-size: clamp(2.5rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.03em;">
          Mer att berätta
        </h1>
        <p class="!text-white/90 max-w-[600px] text-[16px] md:text-[18px] leading-relaxed mb-[40px]">
          När ett blad blir för kort ger broschyren plats för ordning, bilder och fördjupning. Vi hjälper dig välja format, sidantal, papper, tryck och bindning efter hur broschyren ska användas.
        </p>
        <div class="flex flex-wrap items-center gap-[16px] mb-[60px]">
          <a href="/begar-offert" class="btn-pill btn-red">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686210090" class="btn-pill border-2 border-white text-white hover:bg-white hover:text-[#222]" style="background: transparent;">
            Ring 08-96 01 35
          </a>
        </div>
        <!-- Trust strip — exakt som mallen: 3 lika breda kolumner -->
        <div class="flex flex-wrap items-center gap-[40px] md:gap-[60px]">
          <div>
            <div class="!text-white font-[var(--font-heading)] leading-none" style="font-size: clamp(2rem, 3vw, 2.625rem);">100+ år</div>
            <div class="!text-white/70 mt-[6px] font-medium uppercase" style="font-size: 11px; letter-spacing: 1.65px;">År av erfarenhet</div>
          </div>
          <div>
            <div class="!text-white font-[var(--font-heading)] leading-none" style="font-size: clamp(2rem, 3vw, 2.625rem);">1000+</div>
            <div class="!text-white/70 mt-[6px] font-medium uppercase" style="font-size: 11px; letter-spacing: 1.65px;">Uppdrag årligen</div>
          </div>
          <div class="flex items-center gap-[14px]">
            <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[40px] h-[41px]" />
            <div class="!text-white font-medium uppercase" style="font-size: 11px; letter-spacing: 1.65px;">Svanenmärkt</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR BROSCHYR?" — Quote ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="mx-[44px]">
      <p class="text-[#222] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Varför broschyr?</p>
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(2rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.03em;">
          En broschyr kan vara många sidor. <em>Eller en tydlig väg genom ett längre budskap.</em>
        </h2>
        <div class="md:pt-[20px]">
          <p class="text-[18px] leading-relaxed text-[#222] mb-[28px]">
            När struktur, papper och bindning samspelar blir innehållet lättare att följa.
          </p>
          <ul class="space-y-[10px] mb-[36px]">
            {effects.map((eff) => (
              <li class="flex items-start gap-[10px] text-[16px] leading-relaxed text-[#222]">
                <span class="shrink-0 mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
                <span>{eff}</span>
              </li>
            ))}
          </ul>
          <a href="/wp-content/uploads/broschyr-infografik.pdf" class="btn-pill btn-dark">
            Ladda ner infografik
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "Vad vill du uppnå?" — sidoscroll-kort, 380px breda, ml-[44px] ═══ -->
  <section class="pt-[80px] pb-[100px]">
    <div class="ml-[44px] mb-[40px]">
      <p class="text-[#222] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">När du behöver en broschyr</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
        Vad vill du uppnå?
      </h2>
      <p class="text-[#555] text-[16px] md:text-[18px] max-w-[720px]">
        Berätta situationen. Vi löser trycket.
      </p>
    </div>
    <div id="scenario-carousel" class="flex gap-[20px] overflow-x-auto scrollbar-hide pl-[44px] pr-[44px]">
      {scenarios.map((s) => (
        <article class="shrink-0 w-[380px] bg-[#F5F5F5] rounded-[16px] p-[43px] flex flex-col min-h-[482px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px]" style="font-size: 28px; line-height: 28px;">{s.title}</h3>
          <p class="text-[15px] leading-relaxed text-[#444] mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[20px] border-t border-[#C8C8C8]">
            <p class="text-[14px] leading-relaxed text-[#222]">
              <strong class="font-bold">Vår rekommendation:</strong> {s.rec}
            </p>
          </div>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[24px] mr-[44px]">
      <button id="scenario-prev" class="w-[44px] h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[44px] h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR (centrerat) ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="max-w-[1140px] mx-auto px-[44px] text-center">
      <p class="text-[#222] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Hur vi jobbar</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[80px] md:mb-[100px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
        Broschyrer kräver lite mer planering.
      </h2>
      <div class="grid md:grid-cols-3 gap-[40px] md:gap-[60px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Du berättar</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Du beskriver syfte, upplaga, målgrupp och hur broschyren ska användas.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Vi rekommenderar</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Vi föreslår format, sidantal, papper, tryckmetod, bindning och eventuell efterbehandling.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Du godkänner</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Du får ett tydligt förslag och godkänner innan broschyren går till tryck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP (grå sektion) ═══ -->
  <section class="bg-[#F3F3F3]">
    <div class="mx-[44px] py-[100px] md:py-[140px] px-[44px]">
      <p class="text-[#222] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Varför inte webbshop</p>
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
          Broschyrer är ingen standardlösning.
        </h2>
        <div class="space-y-[20px] text-[16px] leading-relaxed text-[#444] md:pt-[20px]">
          <p>Broschyrer påverkas av flera val som behöver hänga ihop. Sidantal, papper, tryckmetod, omslag och bindning styr både känsla och funktion.</p>
          <p>Med rådgivning får du en broschyr som passar innehållet. Det gör valet enklare och resultatet mer genomtänkt.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk RUNDAD med mx-[44px], bg #222 br 50px) ═══ -->
  <section class="py-[40px]">
    <div class="mx-[44px] rounded-[50px] bg-[#222]">
      <div class="px-[44px] md:px-[60px] py-[100px] md:py-[110px]">
        <p class="!text-white/60 mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[60px] md:mb-[80px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
          Format, papper, bindning – vi kan det.
        </h2>
        <div class="grid md:grid-cols-3 gap-[24px]">
          <div class="bg-[#313131] rounded-[25px] p-[39px]">
            <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[20px]" style="font-size: 32px; line-height: 40px;">Papper</h3>
            <p class="!text-white/80 text-[15px] leading-relaxed">Vi hjälper dig välja yta och gramvikt efter innehåll, bildkänsla, läsbarhet och hur broschyren ska hanteras.</p>
          </div>
          <div class="bg-[#313131] rounded-[25px] p-[39px]">
            <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[20px]" style="font-size: 32px; line-height: 40px;">Tryckmetod</h3>
            <p class="!text-white/80 text-[15px] leading-relaxed">Digitaltryck passar ofta mindre upplagor och flexibel produktion. Offsettryck passar ofta större upplagor där jämn färgåtergivning och styckekonomi blir viktiga.</p>
          </div>
          <div class="bg-[#313131] rounded-[25px] p-[39px]">
            <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[20px]" style="font-size: 32px; line-height: 40px;">Efterbehandling</h3>
            <p class="!text-white/80 text-[15px] leading-relaxed">Häftning, limbindning, falsning, laminering, lack, prägling och foliering kan förstärka funktion, hållbarhet och känsla.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KUNDCITAT (1 citat, vit bg, centrerad) ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="max-w-[1140px] mx-auto px-[44px] text-center">
      <p class="font-[var(--font-heading)] text-[clamp(1.5rem,2.8vw,2.5rem)] leading-[1.3] text-[#222] mb-[40px]">
        &ldquo;{testimonial.quote}&rdquo;
      </p>
      <div class="text-[15px]">
        <span class="font-bold text-[#222]">{testimonial.author}</span>
        <span class="text-[#666]"> – {testimonial.role}</span>
      </div>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="max-w-[1140px] mx-auto px-[44px] py-[80px] md:py-[120px]">
    <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
      Vanliga frågor om broschyrer.
    </h2>
    <p class="text-[15px] text-[#555] mb-[40px] md:mb-[60px]">
      Har du fler frågor? Ring oss på <strong class="text-[#222]">08-96 01 35</strong> – vi svarar gärna.
    </p>
    <div id="faq-list">
      {faqs.map((item) => (
        <div class="border-b border-[#D5D8DC]">
          <button class="faq-toggle w-full flex justify-between items-center py-[20px] px-[10px] text-left cursor-pointer">
            <span class="font-[var(--font-body)] font-bold text-[16px] md:text-[18px] text-[#222] pr-4">{item.q}</span>
            <span class="faq-icon shrink-0 w-[28px] h-[28px] flex items-center justify-center text-[#D9222A]">
              <svg class="faq-plus" width="28" height="28" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
              <svg class="faq-minus hidden" width="28" height="28" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12H124c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h264c6.6 0 12 5.4 12 12v56z"/></svg>
            </span>
          </button>
          <div class="faq-answer text-[16px] leading-[1.7] pb-[20px] px-[10px] text-[#444]">
            <p>{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ══ FOOTER START — allt efter FAQ ══ -->

  <!-- ═══ HJÄLP? + FORMULÄR (grå #F3F3F3) ═══ -->
  <section class="bg-[#F3F3F3]">
    <div class="px-[44px] py-[100px] md:py-[120px]">
      <div class="max-w-[1300px] mx-auto grid md:grid-cols-2 gap-[40px] md:gap-[80px]">
        <div>
          <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[24px]" style="font-size: clamp(3.5rem, 7vw, 6.25rem); line-height: 1; letter-spacing: -0.04em;">Hjälp?</h2>
          <h3 class="font-[var(--font-heading)] !font-normal text-[26px] md:text-[32px] text-[#222] mb-[28px] leading-[1.2]">
            Berätta om ditt broschyrprojekt.
          </h3>
          <p class="text-[16px] leading-relaxed text-[#444] mb-[36px] max-w-[480px]">
            Skicka en förfrågan eller ring oss direkt. Vi återkommer med en rekommendation och ett pris – oftast samma dag. Du förbinder dig till ingenting förrän du säger ja.
          </p>
          <div class="space-y-[8px] text-[15px] text-[#222]">
            <p><strong class="font-bold">Telefon:</strong> 08-96 01 35</p>
            <p><strong class="font-bold">E-post:</strong> <a href="mailto:tryckeri@norrmalmstryckeriet.se" class="text-[#D9222A] hover:underline">tryckeri@norrmalmstryckeriet.se</a></p>
            <p><strong class="font-bold">Besök:</strong> Hammarbacken 4A, Sollentuna (15 min från city)</p>
          </div>
        </div>
        <div>
          <form class="space-y-[12px]" action="#" method="post">
            <input type="text" name="name" placeholder="Ditt namn" required class="w-full px-[16px] py-[14px] rounded-[4px] bg-[#FDFDFD] border border-white focus:border-[#222] outline-none text-[18px] font-[var(--font-body)]" />
            <input type="text" name="company" placeholder="Företagsnamn" class="w-full px-[16px] py-[14px] rounded-[4px] bg-[#FDFDFD] border border-white focus:border-[#222] outline-none text-[18px] font-[var(--font-body)]" />
            <input type="email" name="email" placeholder="E-post" required class="w-full px-[16px] py-[14px] rounded-[4px] bg-[#FDFDFD] border border-white focus:border-[#222] outline-none text-[18px] font-[var(--font-body)]" />
            <input type="tel" name="phone" placeholder="Telefon" class="w-full px-[16px] py-[14px] rounded-[4px] bg-[#FDFDFD] border border-white focus:border-[#222] outline-none text-[18px] font-[var(--font-body)]" />
            <textarea name="message" placeholder="Berätta kort om ditt projekt..." rows="6" class="w-full px-[16px] py-[14px] rounded-[4px] bg-[#FDFDFD] border border-white focus:border-[#222] outline-none text-[18px] font-[var(--font-body)] resize-none"></textarea>
            <button type="submit" class="btn-pill mt-[8px]" style="background: white; color: #222;">
              Skicka meddelande
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KUNDREFERENSER ═══ -->
  <section class="py-[80px]">
    <h3 class="typo-carousel-heading ml-[44px] mb-[20px]">Kundreferenser.</h3>
    <div id="ref-carousel" class="flex gap-[20px] overflow-x-auto scrollbar-hide ml-[44px] pr-[44px]">
      {[
