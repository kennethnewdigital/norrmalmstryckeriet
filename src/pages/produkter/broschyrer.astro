---
import Layout from '../../layouts/Layout.astro';

const scenarios = [
  {
    title: 'Du ska presentera företaget',
    body: 'Du behöver visa verksamhet, erbjudande, människor och kontaktvägar i en tydlig helhet. Konsekvensen blir att innehållet behöver en röd tråd över flera sidor.',
    rec: 'A5 eller A4, 8–12 sidor, fullfärg 4+4, silk eller obestruket papper och häftning eller limbindning efter sidantal.',
  },
  {
    title: 'Du ska göra en produktbroschyr',
    body: 'Du behöver visa bilder, funktioner, användning och fördelar utan att allt trängs på en sida. Konsekvensen blir att format och sidflöde behöver hjälpa kunden att jämföra och förstå.',
    rec: 'A4 vid mer information, fullfärg, papper med bra bildåtergivning och tydliga avsnitt för produkt, nytta och kontakt.',
  },
  {
    title: 'Du ska skapa en kampanjbroschyr',
    body: 'Du vill samla erbjudande, argument och nästa steg i ett material som känns mer genomarbetat än ett blad. Konsekvensen blir att första sidan behöver väcka intresse och insidorna bygga förtroende.',
    rec: 'A5, 8 sidor, digitaltryck vid mindre upplaga och offsettryck vid större upplaga.',
  },
  {
    title: 'Du ska ta fram utbildningsmaterial',
    body: 'Du behöver ett häfte som går att läsa i ordning, anteckna i och spara. Konsekvensen blir att läsbarhet, papper och bindning blir viktiga för användningen.',
    rec: 'A4 eller A5, obestruket papper, tydlig sidnumrering och häftning eller limbindning beroende på sidantal.',
  },
  {
    title: 'Du ska trycka till mässa',
    body: 'Du behöver ett material som ger mer fördjupning än ett reklamblad och som kan tas med vidare. Konsekvensen blir att broschyren behöver vara lätt att dela ut, lätt att bläddra i och tydlig i avslutet.',
    rec: 'A5, 8–12 sidor, fullfärg, kraftigare omslag och tydlig kontakt på baksidan.',
  },
  {
    title: 'Du vill skapa premiumkänsla',
    body: 'Du behöver en broschyr som speglar varumärket och känns genomarbetad i handen. Konsekvensen blir att papper, omslag och efterbehandling påverkar helhetsintrycket.',
    rec: 'Högre gramvikt på omslag, silk eller bestruket papper, laminering, prägling eller foliering där känslan ska förstärkas.',
  },
];

const faqs = [
  { q: 'Vad är skillnaden mellan folder och broschyr?', a: 'En folder är ofta ett vikt blad med färre ytor. En broschyr har flera sidor och passar när innehållet behöver mer struktur.' },
  { q: 'När passar en broschyr bäst?', a: 'Broschyrer passar företagspresentationer, produktinformation, kampanjer och utbildningsmaterial. De fungerar när mottagaren behöver läsa mer än ett kort budskap.' },
  { q: 'Vilket format ska jag välja?', a: 'A5 passar när broschyren ska vara lätt att dela ut och ta med. A4 passar när bilder, tabeller eller längre texter behöver mer utrymme.' },
  { q: 'Vad påverkar priset på en broschyr?', a: 'Sidantal, format, upplaga, papper, tryckmetod, bindning och efterbehandling påverkar priset. Vi rekommenderar val efter innehåll och användning.' },
  { q: 'När passar digitaltryck?', a: 'Digitaltryck passar ofta mindre upplagor och flexibla produktioner. Det är ett bra val när materialet ska tas fram i begränsad mängd.' },
  { q: 'När passar offsettryck?', a: 'Offsettryck passar ofta större upplagor. Det kan ge bra styckekonomi och jämn färgåtergivning vid volym.' },
  { q: 'Kan broschyren få en mer exklusiv känsla?', a: 'Ja. Omslag, gramvikt, laminering, prägling eller foliering kan göra broschyren mer bearbetad. Valet bör kopplas till varumärke, mottagare och användning.' },
];

const relatedLinks = [
  { label: 'Blad, reklamblad, flyers', href: '/produkter/blad' },
  { label: 'Foldrar', href: '/produkter/foldrar' },
  { label: 'Böcker', href: '/produkter/bocker' },
  { label: 'Mappar', href: '/produkter/mappar' },
  { label: 'Affischer', href: '/produkter/affischer' },
  { label: 'Digitaltryck', href: '/guider/digitaltryck' },
  { label: 'Offsettryck', href: '/guider/offsettryck' },
  { label: 'Filhantering & inställningar', href: '/guider/filhantering' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka broschyrer – format, papper och bindning | Norrmalmstryckeriet"
  description="Tryck broschyrer för företag, produkt, kampanj och utbildning. Vi hjälper dig välja format, sidantal, papper, tryckmetod och bindning."
>

  <!-- ═══ HERO SECTION (samma form som startsidan) ═══ -->
  <section class="relative">
    <div class="mx-[34px] mt-[51px] rounded-[50px] overflow-hidden relative" style="aspect-ratio:1.75/1; max-height:85vh; background:#000;">
      <img
        src="/images/hero/hero-tryckpress.webp"
        alt="Tryckpress på Norrmalmstryckeriet"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/30 to-transparent pointer-events-none"></div>
      <div class="absolute bottom-[40px] left-[40px] right-[40px] md:bottom-[60px] md:left-[60px] md:right-[60px] z-10">
        <span class="block text-white/80 text-[14px] md:text-[16px] mb-[16px] tracking-wide uppercase font-medium">Broschyrer</span>
        <h1 class="typo-hero !text-white max-w-[900px]">
          Mer att berätta
        </h1>
        <p class="!text-white/90 max-w-[640px] mt-[20px] mb-[28px] text-[16px] md:text-[18px] leading-relaxed">
          När ett blad blir för kort ger broschyren plats för ordning, bilder och fördjupning. Vi hjälper dig välja format, sidantal, papper, tryck och bindning efter hur broschyren ska användas.
        </p>
        <div class="flex flex-wrap items-center gap-[16px]">
          <a href="/begar-offert" class="btn-pill btn-red">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="/wp-content/uploads/broschyr-infografik.pdf" class="!text-white inline-flex items-center font-medium hover:underline">
            Ladda ner infografik<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP ═══ -->
  <section class="py-[40px] mx-[34px] overflow-hidden">
    <div class="flex flex-wrap justify-center items-center gap-[40px] md:gap-[80px] py-[10px]">
      <div class="flex items-center gap-[10px]">
        <span class="w-[8px] h-[8px] rounded-full bg-[#D9222A]"></span>
        <span class="font-[var(--font-body)] text-[18px] text-[#222] opacity-80">100+ år</span>
      </div>
      <div class="flex items-center gap-[10px]">
        <span class="w-[8px] h-[8px] rounded-full bg-[#D9222A]"></span>
        <span class="font-[var(--font-body)] text-[18px] text-[#222] opacity-80">1000+ uppdrag</span>
      </div>
      <div class="flex items-center gap-[10px]">
        <span class="w-[8px] h-[8px] rounded-full bg-[#D9222A]"></span>
        <span class="font-[var(--font-body)] text-[18px] text-[#222] opacity-80">Svanenmärkt</span>
      </div>
    </div>
  </section>

  <!-- ═══ INTRO QUOTE (samma form som startsidans quote) ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-quote">
        En broschyr kan vara många sidor. <em>Eller en tydlig väg genom ett längre budskap.</em>
      </h2>
    </div>
  </section>

  <!-- ═══ VARFÖR + EFFEKT (två-kolumn grå sektion) ═══ -->
  <section class="bg-[#F3F3F3]">
    <div class="max-w-[1140px] mx-auto px-[34px] py-[80px]">
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start">
        <div>
          <h2 class="text-[#222]">
            Varför broschyr?
          </h2>
        </div>
        <div>
          <p class="mb-8 leading-relaxed">
            När struktur, papper och bindning samspelar blir innehållet lättare att följa. En broschyr ger plats för ordning, bilder och fördjupning – och bygger förtroende på ett sätt som ett kort budskap aldrig kan.
          </p>
          <ul class="space-y-3">
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-[8px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span class="text-[#222]">Mer plats för förklaring och bild</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-[8px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span class="text-[#222]">Tydlig läsordning över flera sidor</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-[8px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span class="text-[#222]">Rätt känsla för företag, produkt och varumärke</span>
            </li>
            <li class="flex items-start gap-3">
              <span class="shrink-0 mt-[8px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
              <span class="text-[#222]">Möjlighet till häftning, limbindning och finish</span>
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VAD VILL DU UPPNÅ? – sidoscroll-kort (samma form som produktkarusellen) ═══ -->
  <section class="pt-[80px] pb-[80px]">
    <div class="ml-[34px] mb-[20px]">
      <h3 class="typo-carousel-heading mb-[12px]">Vad vill du uppnå?</h3>
      <p class="text-[#444] text-[18px]">Berätta situationen. Vi löser trycket.</p>
    </div>
    <div id="scenario-carousel" class="flex gap-[20px] overflow-x-auto scrollbar-hide ml-[34px] pr-[34px]">
      {scenarios.map((s) => (
        <div class="shrink-0 w-[420px] bg-[#F5F5F5] rounded-[16px] p-[34px] flex flex-col">
          <h4 class="typo-process-sub mb-[16px]">{s.title}</h4>
          <p class="text-[16px] leading-relaxed text-[#444] mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[20px] border-t border-[#D5D8DC]">
            <span class="block font-bold text-[#222] mb-[8px] text-[13px] uppercase tracking-wider">Vår rekommendation</span>
            <p class="text-[15px] leading-relaxed text-[#222]">{s.rec}</p>
          </div>
        </div>
      ))}
    </div>
    <div class="flex justify-end gap-2 mt-4 mr-[34px]">
      <button id="scenario-prev" class="w-[44px] h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-gray-300 hover:text-[#222] transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[44px] h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#222] hover:bg-[#E5E5E5] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR (samma form som "Enkel process") ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-section-title text-center text-[#222] mb-[60px] md:mb-[80px]">
        Hur vi jobbar.
      </h2>
      <div class="grid md:grid-cols-3 gap-[20px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h4 class="typo-process-sub mb-[12px]">Du berättar:</h4>
          <p>Du beskriver syfte, upplaga, målgrupp och hur broschyren ska användas.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h4 class="typo-process-sub mb-[12px]">Vi rekommenderar:</h4>
          <p>Vi föreslår format, sidantal, papper, tryckmetod, bindning och eventuell efterbehandling.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h4 class="typo-process-sub mb-[12px]">Du godkänner:</h4>
          <p>Du får ett tydligt förslag och godkänner innan broschyren går till tryck.</p>
        </div>
      </div>
      <div class="mt-[40px]">
        <a href="/begar-offert" class="btn-pill btn-red">
          Offertförfrågan<Fragment set:html={arrowSvg} />
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP (två-kolumn grå sektion) ═══ -->
  <section class="bg-[#F3F3F3]">
    <div class="max-w-[1140px] mx-auto px-[34px] py-[80px]">
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start">
        <div>
          <h2 class="text-[#222]">
            Varför inte webbshop?
          </h2>
        </div>
        <div>
          <p class="mb-8 leading-relaxed">
            Broschyrer påverkas av flera val som behöver hänga ihop. Sidantal, papper, tryckmetod, omslag och bindning styr både känsla och funktion.
          </p>
          <p class="mb-8 leading-relaxed">
            Med rådgivning får du en broschyr som passar innehållet. Det gör valet enklare och resultatet mer genomtänkt.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (3 kolumner) ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-section-title text-[#222] mb-[60px] md:mb-[80px]">
        Vår expertis.
      </h2>
      <div class="grid md:grid-cols-3 gap-[40px]">
        <div>
          <h4 class="typo-process-sub mb-[16px]">Papper</h4>
          <p>Vi hjälper dig välja yta och gramvikt efter innehåll, bildkänsla, läsbarhet och hur broschyren ska hanteras.</p>
        </div>
        <div>
          <h4 class="typo-process-sub mb-[16px]">Tryckmetod</h4>
          <p>Digitaltryck passar ofta mindre upplagor och flexibel produktion. Offsettryck passar ofta större upplagor där jämn färgåtergivning och styckekonomi blir viktiga.</p>
        </div>
        <div>
          <h4 class="typo-process-sub mb-[16px]">Efterbehandling</h4>
          <p>Häftning, limbindning, falsning, laminering, lack, prägling och foliering kan förstärka funktion, hållbarhet och känsla.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ KUNDCITAT ═══ -->
  <section class="py-[80px] md:py-[120px] bg-[#F3F3F3]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h3 class="typo-quote">
        <em>"Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser."</em>
      </h3>
      <p class="mt-[24px] text-[16px] text-[#444] font-medium">
        — Björn Jansson, Projektledare, Repro 8
      </p>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="max-w-[1140px] mx-auto px-[34px] py-[80px] md:py-[120px]">
    <h2 class="typo-section-title text-[#222] mb-[40px] md:mb-[60px]">
      Vanliga frågor om broschyrer.
    </h2>
    <div id="faq-list">
      {faqs.map((item) => (
        <div class="border-b border-[#D5D8DC]">
          <button class="faq-toggle w-full flex justify-between items-center py-[20px] px-[10px] text-left cursor-pointer">
            <span class="font-[var(--font-body)] text-[18px] text-[#222] pr-4"><strong>Fråga:</strong> {item.q}</span>
            <span class="faq-icon shrink-0 w-[25px] h-[25px] flex items-center justify-center text-[#222]">
              <svg class="faq-plus" width="25" height="25" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
              <svg class="faq-minus hidden" width="25" height="25" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12H124c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h264c6.6 0 12 5.4 12 12v56z"/></svg>
            </span>
          </button>
          <div class="faq-answer text-[18px] leading-[1.7] pb-[20px] px-[10px]">
            <p>{item.a}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ SLUTKONTAKT (röd rundad sektion) ═══ -->
  <section class="mx-[34px] mb-[80px] rounded-[50px] bg-[#D9222A] overflow-hidden">
    <div class="max-w-[1140px] mx-auto px-[34px] py-[80px] md:py-[120px]">
      <h2 class="typo-section-title !text-white mb-[24px] max-w-[900px]">
        Berätta om ditt broschyrprojekt.
      </h2>
      <p class="!text-white/90 text-[18px] leading-relaxed max-w-[720px] mb-[40px]">
        Berätta hur broschyren ska användas, så rekommenderar vi format, papper, sidantal och bindning.
      </p>
      <div class="flex flex-wrap gap-[16px]">
        <a href="/begar-offert" class="btn-pill bg-white text-[#222]">
          Offertförfrågan<Fragment set:html={arrowSvg} />
        </a>
        <a href="tel:+4686210090" class="btn-pill bg-transparent text-white border-2 border-white">
          Ring 08-621 00 90
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ RELATERADE TRYCKSAKER (pill-länkar) ═══ -->
  <section class="max-w-[1140px] mx-auto px-[34px] pb-[120px]">
    <h3 class="typo-process-sub mb-[24px] text-[#222]">Relaterade trycksaker</h3>
    <div class="flex flex-wrap gap-[12px]">
      {relatedLinks.map((link) => (
        <a href={link.href} class="inline-flex items-center px-[20px] py-[12px] rounded-full border border-[#222] text-[#222] text-[15px] font-medium hover:bg-[#222] hover:text-white transition-colors no-underline">
          {link.label}
        </a>
      ))}
    </div>
  </section>

</Layout>

<script>
  function initBroschyrer() {
    // FAQ accordion
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const plusIcon = btn.querySelector('.faq-plus') as HTMLElement;
        const minusIcon = btn.querySelector('.faq-minus') as HTMLElement;
        const isOpen = answer.classList.contains('is-open');

        document.querySelectorAll('.faq-answer').forEach((a) => {
          (a as HTMLElement).style.maxHeight = '0';
          a.classList.remove('is-open');
        });
        document.querySelectorAll('.faq-plus').forEach((p) => p.classList.remove('hidden'));
        document.querySelectorAll('.faq-minus').forEach((m) => m.classList.add('hidden'));

        if (!isOpen) {
          answer.classList.add('is-open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          plusIcon.classList.add('hidden');
          minusIcon.classList.remove('hidden');
        }
      });
    });

    // Scenario carousel
    const carousel = document.getElementById('scenario-carousel');
    document.getElementById('scenario-prev')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: -440, behavior: 'smooth' });
    });
    document.getElementById('scenario-next')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: 440, behavior: 'smooth' });
    });
  }

  initBroschyrer();
  document.addEventListener('astro:after-swap', initBroschyrer);
</script>
