---
import Layout from '../../layouts/Layout.astro';

const trustItems = ['100+ år', '1000+ uppdrag', 'Svanenmärkt'];

const effects = [
  'Mer plats för förklaring och bild',
  'Tydlig läsordning över flera sidor',
  'Rätt känsla för företag, produkt och varumärke',
  'Möjlighet till häftning, limbindning och finish',
];

const scenarios = [
  {
    title: 'Du ska presentera företaget',
    body: 'Du behöver visa verksamhet, erbjudande, människor och kontaktvägar i en tydlig helhet. Konsekvensen blir att innehållet behöver en röd tråd över flera sidor.',
    rec: 'A5 eller A4, 8–12 sidor, fullfärg 4+4, silk eller obestruket papper och häftning eller limbindning efter sidantal.',
  },
  {
    title: 'Du ska göra en produktbroschyr',
    body: 'Du behöver visa bilder, funktioner, användning och fördelar utan att allt trängs på en sida. Konsekvensen blir att format och sidflöde behöver hjälpa kunden att jämföra och förstå.',
    rec: 'A4 vid mer information, fullfärg, papper med bra bildåtergivning och tydliga avsnitt för produkt, nytta och kontakt.',
  },
  {
    title: 'Du ska skapa en kampanjbroschyr',
    body: 'Du vill samla erbjudande, argument och nästa steg i ett material som känns mer genomarbetat än ett blad. Konsekvensen blir att första sidan behöver väcka intresse och insidorna bygga förtroende.',
    rec: 'A5, 8 sidor, digitaltryck vid mindre upplaga och offsettryck vid större upplaga.',
  },
  {
    title: 'Du ska ta fram utbildningsmaterial',
    body: 'Du behöver ett häfte som går att läsa i ordning, anteckna i och spara. Konsekvensen blir att läsbarhet, papper och bindning blir viktiga för användningen.',
    rec: 'A4 eller A5, obestruket papper, tydlig sidnumrering och häftning eller limbindning beroende på sidantal.',
  },
  {
    title: 'Du ska trycka till mässa',
    body: 'Du behöver ett material som ger mer fördjupning än ett reklamblad och som kan tas med vidare. Konsekvensen blir att broschyren behöver vara lätt att dela ut, lätt att bläddra i och tydlig i avslutet.',
    rec: 'A5, 8–12 sidor, fullfärg, kraftigare omslag och tydlig kontakt på baksidan.',
  },
  {
    title: 'Du vill skapa premiumkänsla',
    body: 'Du behöver en broschyr som speglar varumärket och känns genomarbetad i handen. Konsekvensen blir att papper, omslag och efterbehandling påverkar helhetsintrycket.',
    rec: 'Högre gramvikt på omslag, silk eller bestruket papper, laminering, prägling eller foliering där känslan ska förstärkas.',
  },
];

const processSteps = [
  { num: '1.', title: 'Du berättar', body: 'Du beskriver syfte, upplaga, målgrupp och hur broschyren ska användas.' },
  { num: '2.', title: 'Vi rekommenderar', body: 'Vi föreslår format, sidantal, papper, tryckmetod, bindning och eventuell efterbehandling.' },
  { num: '3.', title: 'Du godkänner', body: 'Du får ett tydligt förslag och godkänner innan broschyren går till tryck.' },
];

const expertise = [
  {
    title: 'Papper',
    body: 'Vi hjälper dig välja yta och gramvikt efter innehåll, bildkänsla, läsbarhet och hur broschyren ska hanteras.',
  },
  {
    title: 'Tryckmetod',
    body: 'Digitaltryck passar ofta mindre upplagor och flexibel produktion. Offsettryck passar ofta större upplagor där jämn färgåtergivning och styckekonomi blir viktiga.',
  },
  {
    title: 'Efterbehandling',
    body: 'Häftning, limbindning, falsning, laminering, lack, prägling och foliering kan förstärka funktion, hållbarhet och känsla.',
  },
];

const faqs = [
  {
    q: 'Vad är skillnaden mellan folder och broschyr?',
    a: 'En folder är ofta ett vikt blad med färre ytor. En broschyr har flera sidor och passar när innehållet behöver mer struktur.',
  },
  {
    q: 'När passar en broschyr bäst?',
    a: 'Broschyrer passar företagspresentationer, produktinformation, kampanjer och utbildningsmaterial. De fungerar när mottagaren behöver läsa mer än ett kort budskap.',
  },
  {
    q: 'Vilket format ska jag välja?',
    a: 'A5 passar när broschyren ska vara lätt att dela ut och ta med. A4 passar när bilder, tabeller eller längre texter behöver mer utrymme.',
  },
  {
    q: 'Vad påverkar priset på en broschyr?',
    a: 'Sidantal, format, upplaga, papper, tryckmetod, bindning och efterbehandling påverkar priset. Vi rekommenderar val efter innehåll och användning.',
  },
  {
    q: 'När passar digitaltryck?',
    a: 'Digitaltryck passar ofta mindre upplagor och flexibla produktioner. Det är ett bra val när materialet ska tas fram i begränsad mängd.',
  },
  {
    q: 'När passar offsettryck?',
    a: 'Offsettryck passar ofta större upplagor. Det kan ge bra styckekonomi och jämn färgåtergivning vid volym.',
  },
  {
    q: 'Kan broschyren få en mer exklusiv känsla?',
    a: 'Ja. Omslag, gramvikt, laminering, prägling eller foliering kan göra broschyren mer bearbetad. Valet bör kopplas till varumärke, mottagare och användning.',
  },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka broschyrer – format, papper och bindning | Norrmalmstryckeriet"
  description="Tryck broschyrer för företag, produkt, kampanj och utbildning. Vi hjälper dig välja format, sidantal, papper, tryckmetod och bindning."
>

  <!-- ═══ HERO ═══ -->
  <section class="relative">
    <div class="mx-[34px] mt-[51px] rounded-[50px] overflow-hidden relative bg-[#222]" style="aspect-ratio:2.4/1; max-height:75vh;">
      <img
        src="/images/icons/broschyrer-1.svg"
        alt=""
        class="absolute right-[5%] top-1/2 -translate-y-1/2 w-[280px] h-[280px] opacity-15 hidden md:block"
      />
      <div class="absolute inset-0 flex flex-col justify-end p-[40px] md:p-[80px] lg:p-[100px]">
        <span class="text-white/70 text-[14px] md:text-[16px] mb-[16px] tracking-wide uppercase">Broschyrer</span>
        <h1 class="typo-hero !text-white max-w-[900px] mb-[24px]">
          Mer att berätta
        </h1>
        <p class="!text-white/90 max-w-[640px] mb-[32px] text-[16px] md:text-[18px] leading-relaxed">
          När ett blad blir för kort ger broschyren plats för ordning, bilder och fördjupning. Vi hjälper dig välja format, sidantal, papper, tryck och bindning efter hur broschyren ska användas.
        </p>
        <div>
          <a href="/begar-offert" class="btn-pill btn-red">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP ═══ -->
  <section class="py-[40px] md:py-[60px] mx-[34px] border-b border-[#E5E5E5]">
    <div class="flex flex-wrap justify-center items-center gap-[40px] md:gap-[80px]">
      {trustItems.map((item) => (
        <div class="flex items-center gap-[12px]">
          <span class="w-[8px] h-[8px] rounded-full bg-[#D9222A]"></span>
          <span class="font-[var(--font-body)] font-medium text-[#222] text-[16px] md:text-[18px]">{item}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ═══ VARFÖR ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-feature-heading max-w-[900px] mb-[32px]">
        En broschyr kan vara många sidor. Eller en tydlig väg genom ett längre budskap.
      </h2>
      <p class="max-w-[720px] text-[18px] leading-relaxed text-[#444]">
        När struktur, papper och bindning samspelar blir innehållet lättare att följa.
      </p>
    </div>
  </section>

  <!-- ═══ EFFEKT ═══ -->
  <section class="bg-[#F3F3F3] py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h3 class="typo-carousel-heading mb-[40px] md:mb-[60px]">Effekt.</h3>
      <ul class="grid md:grid-cols-2 gap-[20px] md:gap-[30px]">
        {effects.map((eff) => (
          <li class="flex items-start gap-[16px] bg-white rounded-[16px] p-[28px]">
            <span class="shrink-0 mt-[4px] w-[24px] h-[24px] rounded-full bg-[#222] flex items-center justify-center text-white">
              <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><path d="M5 13l4 4L19 7"/></svg>
            </span>
            <span class="text-[18px] leading-relaxed text-[#222]">{eff}</span>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- ═══ VAD VILL DU UPPNÅ ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-section-title mb-[20px]">Vad vill du uppnå?</h2>
      <p class="text-[18px] mb-[60px] md:mb-[80px] text-[#444] max-w-[640px]">
        Berätta situationen. Vi löser trycket.
      </p>
      <div class="grid gap-[40px] md:gap-[60px]">
        {scenarios.map((s) => (
          <article class="grid md:grid-cols-[1fr_1fr] gap-[20px] md:gap-[60px] pb-[40px] md:pb-[60px] border-b border-[#E5E5E5] last:border-0">
            <div>
              <h3 class="typo-process-sub mb-[16px]">{s.title}</h3>
              <p class="text-[17px] leading-relaxed text-[#444]">{s.body}</p>
            </div>
            <div class="bg-[#F5F5F5] rounded-[16px] p-[28px] md:p-[34px]">
              <span class="block font-bold text-[#222] mb-[8px] text-[15px] uppercase tracking-wide">Vår rekommendation</span>
              <p class="text-[17px] leading-relaxed text-[#222]">{s.rec}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-section-title text-center mb-[60px] md:mb-[80px]">Hur vi jobbar.</h2>
      <div class="grid md:grid-cols-3 gap-[20px] md:gap-[40px]">
        {processSteps.map((step) => (
          <div>
            <span class="typo-process-number block">{step.num}</span>
            <h4 class="typo-process-sub mb-[12px]">{step.title}</h4>
            <p class="text-[17px] leading-relaxed text-[#444]">{step.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP ═══ -->
  <section class="bg-[#F3F3F3] py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start">
        <h2 class="typo-feature-heading">
          Varför inte webbshop?
        </h2>
        <div>
          <p class="mb-[20px] text-[18px] leading-relaxed text-[#222]">
            Broschyrer påverkas av flera val som behöver hänga ihop. Sidantal, papper, tryckmetod, omslag och bindning styr både känsla och funktion.
          </p>
          <p class="text-[18px] leading-relaxed text-[#444]">
            Med rådgivning får du en broschyr som passar innehållet. Det gör valet enklare och resultatet mer genomtänkt.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h2 class="typo-section-title mb-[60px] md:mb-[80px]">Vår expertis.</h2>
      <div class="grid md:grid-cols-3 gap-[40px]">
        {expertise.map((item) => (
          <div>
            <h3 class="typo-process-sub mb-[16px]">{item.title}</h3>
            <p class="text-[17px] leading-relaxed text-[#444]">{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ KUNDCITAT ═══ -->
  <section class="py-[80px] md:py-[120px] bg-[#222]">
    <div class="max-w-[1140px] mx-auto px-[34px] text-center">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="mx-auto mb-[32px] text-white/30"><path d="M9.4 7.5C5.6 9.4 3 12.7 3 17.3c0 1.1.5 2 1.5 2.5.7.4 1.6.5 2.4.3.8-.2 1.5-.7 1.9-1.4.4-.7.5-1.5.3-2.3-.2-.8-.7-1.5-1.4-1.9-.7-.4-1.5-.5-2.3-.3.5-1.5 1.6-2.7 3.1-3.4.3-.2.6-.4.8-.7l-.9-2.6zm10 0c-3.8 1.9-6.4 5.2-6.4 9.8 0 1.1.5 2 1.5 2.5.7.4 1.6.5 2.4.3.8-.2 1.5-.7 1.9-1.4.4-.7.5-1.5.3-2.3-.2-.8-.7-1.5-1.4-1.9-.7-.4-1.5-.5-2.3-.3.5-1.5 1.6-2.7 3.1-3.4.3-.2.6-.4.8-.7l-.9-2.6z"/></svg>
      <blockquote class="typo-feature-heading !text-white mb-[32px] max-w-[900px] mx-auto">
        Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser.
      </blockquote>
      <cite class="!text-white/70 text-[16px] not-italic">
        — Björn Jansson, Projektledare, Repro 8
      </cite>
    </div>
  </section>

  <!-- ═══ FAQ ═══ -->
  <section class="py-[80px] md:py-[120px]">
    <div class="max-w-[900px] mx-auto px-[34px]">
      <h2 class="typo-section-title mb-[40px] md:mb-[60px]">Vanliga frågor.</h2>
      <div id="faq-list">
        {faqs.map((item) => (
          <div class="border-b border-[#D5D8DC]">
            <button class="faq-toggle w-full flex justify-between items-center py-[24px] px-[10px] text-left cursor-pointer">
              <span class="font-[var(--font-body)] text-[18px] text-[#222] pr-4 font-medium">{item.q}</span>
              <span class="faq-icon shrink-0 w-[28px] h-[28px] flex items-center justify-center text-[#222]">
                <svg class="faq-plus" width="28" height="28" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
                <svg class="faq-minus hidden" width="28" height="28" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12H124c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h264c6.6 0 12 5.4 12 12v56z"/></svg>
              </span>
            </button>
            <div class="faq-answer text-[17px] leading-[1.7] pb-[24px] px-[10px] text-[#444]">
              <p>{item.a}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ SLUTKONTAKT ═══ -->
  <section class="mx-[34px] mb-[80px] rounded-[50px] bg-[#D9222A] overflow-hidden">
    <div class="max-w-[1140px] mx-auto px-[34px] py-[80px] md:py-[120px] text-center">
      <h2 class="typo-section-title !text-white mb-[24px] max-w-[900px] mx-auto">
        Vill du trycka broschyrer för företag, produkt, kampanj eller utbildning?
      </h2>
      <p class="!text-white/90 text-[18px] leading-relaxed max-w-[720px] mx-auto mb-[40px]">
        Berätta hur broschyren ska användas, så rekommenderar vi format, papper, sidantal och bindning.
      </p>
      <div class="flex flex-wrap justify-center gap-[16px]">
        <a href="/begar-offert" class="btn-pill bg-white text-[#222]">
          Offertförfrågan<Fragment set:html={arrowSvg} />
        </a>
        <a href="tel:+4686901350" class="btn-pill bg-transparent text-white border-2 border-white">
          Ring 08-96 01 35
        </a>
      </div>
    </div>
  </section>

  <!-- ═══ INTERNAL LINKS ═══ -->
  <section class="py-[60px] mb-[80px]">
    <div class="max-w-[1140px] mx-auto px-[34px]">
      <h3 class="typo-process-sub mb-[24px]">Relaterade trycksaker</h3>
      <div class="flex flex-wrap gap-[12px]">
        {[
          { label: 'Blad', href: '/produkter/blad' },
          { label: 'Foldrar', href: '/produkter/foldrar' },
          { label: 'Böcker', href: '/produkter/bocker' },
          { label: 'Digitaltryck', href: '/digitaltryck' },
          { label: 'Offsettryck', href: '/offsettryck' },
          { label: 'Filhantering & inställningar', href: '/guider/filhantering' },
          { label: 'Kontakta oss', href: '/kontakta-oss' },
        ].map((link) => (
          <a href={link.href} class="inline-flex items-center px-[20px] py-[12px] rounded-full border border-[#222] text-[#222] text-[15px] font-medium hover:bg-[#222] hover:text-white transition-colors">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>

</Layout>

<script>
  function initBroschyrer() {
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const plusIcon = btn.querySelector('.faq-plus') as HTMLElement;
        const minusIcon = btn.querySelector('.faq-minus') as HTMLElement;
        const isOpen = answer.classList.contains('is-open');

        // Close all
        document.querySelectorAll('.faq-answer').forEach((a) => {
          (a as HTMLElement).style.maxHeight = '0';
          a.classList.remove('is-open');
        });
        document.querySelectorAll('.faq-plus').forEach((p) => p.classList.remove('hidden'));
        document.querySelectorAll('.faq-minus').forEach((m) => m.classList.add('hidden'));

        if (!isOpen) {
          answer.classList.add('is-open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          plusIcon.classList.add('hidden');
          minusIcon.classList.remove('hidden');
        }
      });
    });
  }

  initBroschyrer();
  document.addEventListener('astro:after-swap', initBroschyrer);
</script>
