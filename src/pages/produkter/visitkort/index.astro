---
import Layout from '../../../layouts/Layout.astro';

const effects = [
  'Gör kontaktuppgifter enkla att spara',
  'Stärker första intrycket vid möten',
  'Passar säljteam, mässa och nätverk',
  'Kan lyftas med papper och specialeffekter',
];

// 7 scenarier — exakt från copy
const scenarios = [
  {
    title: 'Du ska beställa visitkort till teamet',
    body: 'Du behöver kort till flera personer med samma grafiska uttryck och olika kontaktuppgifter. Konsekvensen blir att original, versioner och kvalitet behöver hanteras konsekvent.',
    rec: 'Standardformat, gemensam mall, digitaltryck vid mindre antal per person och papper som matchar företagets profil.',
  },
  {
    title: 'Du ska till mässa eller event',
    body: 'Du behöver ett kort som är lätt att dela ut och enkelt för mottagaren att spara. Konsekvensen blir att informationen behöver vara tydlig och kortet kännas professionellt i många möten.',
    rec: 'Visitkort med tydlig framsida, kontaktuppgifter på baksidan, fullfärg och något kraftigare papper.',
  },
  {
    title: 'Du vill stärka första intrycket',
    body: 'Du behöver ett visitkort som känns genomarbetat redan när det lämnas över. Konsekvensen blir att papper, yta och efterbehandling får större betydelse.',
    rec: 'Kraftigare papper, matt laminering, prägling eller folieprägling där logotyp eller namn ska lyftas.',
  },
  {
    title: 'Du behöver visitkort snabbt i mindre upplaga',
    body: 'Du behöver ett begränsat antal kort för nyanställd, rollbyte eller kommande möte. Konsekvensen blir att produktionen behöver vara flexibel och originalet redo för tryck.',
    rec: 'Digitaltryck, standardformat, färdigt original i korrekt format och pappersval som fungerar med kort ledtid.',
  },
  {
    title: 'Du vill skapa miljömedveten profil',
    body: 'Du vill att visitkortet ska spegla omtanke om material och produktion. Konsekvensen blir att pappersval och helhet behöver stödja företagets hållbarhetsprofil.',
    rec: 'Miljövänligt papper, tydlig men återhållsam design, tryck som matchar materialets känsla och förpackning i miljövänlig visitkortsbox.',
  },
  {
    title: 'Du behöver hjälp med design',
    body: 'Du har logotyp och kontaktuppgifter men behöver få visitkortet att kännas färdigt och professionellt. Konsekvensen blir att layout, marginaler, typografi och informationshierarki behöver sitta rätt.',
    rec: 'Designhjälp eller rekommenderad grafisk designer, tydlig originalmall och tryckanpassning med rätt utfall och färginställningar.',
  },
  {
    title: 'Du vill skapa exklusiva visitkort',
    body: 'Du behöver ett kort som fungerar som varumärkesbärare i möten där detaljerna märks. Konsekvensen blir att finishen behöver förstärka varumärket utan att göra kortet svårläst.',
    rec: 'Kraftigare papper, folieprägling, UV-lack eller prägling på utvalda delar samt tydlig kontrast för läsbarhet.',
  },
];

const expertise = [
  {
    title: 'Pappersval',
    intro: 'Visitkort behöver kännas stabila, tydliga och rätt för personen, rollen och varumärket. Materialet påverkar både första intrycket och hur kortet sparas.',
    items: [
      ['Obestruket', 'Naturlig och taktil känsla. Bra för personliga, hållbara eller mer nedtonade uttryck.'],
      ['Bestruket', 'Slätare yta och tydligare färgtryck. Bra för logotyp, bild och starkare kontrast.'],
      ['Kraftigare papper', 'Ger mer tyngd och professionellt intryck i handen.'],
      ['Miljövänliga papper', 'Passar när hållbarhetsprofilen ska synas även i materialvalet.'],
      ['Specialpapper', 'Passar visitkort som ska kännas mer unika eller premium.'],
    ],
  },
  {
    title: 'Tryckmetod',
    intro: 'Visitkort kan behöva produceras till en person, ett helt team eller flera versioner samtidigt. Valet av tryckmetod styrs av upplaga, färgkrav och hur många versioner som behövs.',
    items: [
      ['Digitaltryck', 'Snabbt och flexibelt. Passar mindre upplagor, flera namn och kortare serier.'],
      ['Offsettryck', 'Effektivt vid större upplagor och när färgstabilitet blir viktig.'],
      ['Pantone', 'Exakt färgmatchning. Bra när logotyp eller varumärkesfärg behöver återges konsekvent.'],
      ['Variabeltryck', 'Bra när många personer ska ha samma design men olika kontaktuppgifter.'],
    ],
  },
  {
    title: 'Efterbehandling',
    intro: 'Efterbehandlingen kan göra visitkortet mer taktilt, mer exklusivt eller mer minnesvärt. Det viktiga är att effekten stärker kortet utan att störa läsbarheten.',
    items: [
      ['Laminering', 'Matt, silk eller blank yta. Skyddar och ger ett mer färdigt uttryck.'],
      ['Folieprägling', 'Metallisk detalj i exempelvis guld eller silver. Bra för logotyp, namn eller grafisk detalj.'],
      ['UV-lack', 'Blank detaljeffekt som kan lyfta utvalda delar av kortet.'],
      ['Prägling', 'Upphöjd eller nedsänkt effekt som känns i handen.'],
      ['Rundade hörn / specialform', 'Kan ge kortet ett mer eget uttryck, om det passar varumärket.'],
    ],
  },
];

const testimonial = {
  quote: 'Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser.',
  author: 'Björn Jansson',
  role: 'Projektledare, Repro 8',
};

// 8 FAQ — exakt från copy
const faqs = [
  { q: 'Vad ska finnas på ett visitkort?', a: 'Namn, roll, företag, telefon, e-post och webbadress är ofta viktigast. Logotyp och eventuell QR-kod kan läggas till när de stärker användningen.' },
  { q: 'Vilket papper passar visitkort?', a: 'Ett kraftigare papper ger visitkortet stabilitet och bättre känsla i handen. Valet bör matcha varumärke, design och hur kortet ska användas.' },
  { q: 'Kan ni trycka visitkort till flera personer?', a: 'Ja, visitkort kan tas fram med samma mall och olika kontaktuppgifter. Det passar team, säljorganisationer och nyanställda.' },
  { q: 'När passar digitaltryck för visitkort?', a: 'Digitaltryck passar ofta mindre upplagor, flera namn och kortare serier. Det är praktiskt när visitkorten behöver versioneras.' },
  { q: 'Vad påverkar priset på visitkort?', a: 'Pris påverkas av upplaga, papper, tryck, antal versioner och eventuell efterbehandling. Specialeffekter som folieprägling, UV-lack eller prägling påverkar också priset.' },
  { q: 'Kan visitkort få specialeffekter?', a: 'Ja, folieprägling, UV-lack och prägling kan lyfta logotyp, namn eller grafiska detaljer. Effekten bör användas där den förstärker helheten och behåller läsbarheten.' },
  { q: 'Kan ni hjälpa till med design?', a: 'Ja, sidan beskriver designhjälp och möjlighet att rekommendera grafiska designers. Det passar när du har logotyp och innehåll men behöver en färdig layout.' },
  { q: 'Finns det miljövänliga alternativ?', a: 'Ja, befintlig sida beskriver miljövänliga papper, tryckmetoder och visitkortsbox. Exakta materialval bör verifieras inför beställning.' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka visitkort med rätt papper och finish | Norrmalmstryckeriet"
  description="Tryck visitkort för företag, team, mässa och kundmöten. Vi hjälper dig välja papper, tryck, design, upplaga och specialeffekter."
>

  <!-- ═══ HERO ═══ -->
  <!-- MOBILE+TABLET HERO: Bild överst, text under (stackad vertikalt) — upp till lg 1024px -->
  <section class="lg:hidden">
    <div class="mx-[16px] sm:mx-[24px] mt-[16px] sm:mt-[24px]">
      <!-- Bild överst -->
      <div class="rounded-[20px] sm:rounded-[28px] overflow-hidden aspect-[4/3] sm:aspect-[16/9] md:aspect-[2/1] mb-[24px] sm:mb-[32px]">
        <img
          src="/images/hero/visitkort-hero.png"
          alt="Visitkort från Norrmalmstryckeriet"
          class="w-full h-full object-cover"
        />
      </div>
      <!-- Text under -->
      <div class="px-[4px] sm:px-[8px] md:px-[16px] max-w-[760px]">
        <p class="text-[#888] mb-[12px] sm:mb-[16px] uppercase font-medium text-[10px] sm:text-[11px]" style="letter-spacing:1.5px; line-height:1;">
          Tryckeri Stockholm • Sollentuna / Häggvik
        </p>
        <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.875rem, 5vw + 0.5rem, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
          Lämna rätt intryck
        </h1>
        <p class="text-[#444] text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed mb-[24px] sm:mb-[28px]">
          När du möter kund, partner eller kontaktperson behöver dina uppgifter vara enkla att ta med. Vi hjälper dig välja papper, tryck och finish efter hur visitkortet ska kännas och användas.
        </p>
        <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px] mb-[32px] sm:mb-[40px]">
          <a href="/begar-offert" class="btn-pill btn-red w-full sm:w-auto justify-center">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686210090" class="btn-pill w-full sm:w-auto justify-center" style="background: #F3F3F3; color: #222;">
            Ring 08-96 01 35
          </a>
        </div>
        <!-- Trust strip -->
        <div class="flex flex-wrap items-end gap-x-[24px] sm:gap-x-[40px] gap-y-[16px] pt-[8px]">
          <div class="flex flex-col items-start">
            <span class="font-[var(--font-heading)] text-[#222] leading-none text-[22px] sm:text-[26px]">100+ år</span>
            <span class="text-[#666] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">År av erfarenhet</span>
          </div>
          <div class="flex flex-col items-start">
            <span class="font-[var(--font-heading)] text-[#222] leading-none text-[22px] sm:text-[26px]">1000+</span>
            <span class="text-[#666] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">Uppdrag årligen</span>
          </div>
          <div class="flex flex-col items-start">
            <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[30px] h-[31px] sm:w-[34px] sm:h-[35px]" />
            <span class="text-[#222] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">Svanenmärkt</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESKTOP HERO: Overlay med text på bilden (1024px+) -->
  <section class="relative hidden lg:block">
    <div
      class="hero-box mx-[34px] mt-[24px] rounded-[50px] overflow-hidden relative"
    >
      <img
        src="/images/hero/visitkort-hero.png"
        alt="Visitkort från Norrmalmstryckeriet"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/35 to-black/10 pointer-events-none"></div>
      <div class="absolute top-1/2 -translate-y-1/2 left-[40px] right-[40px] lg:left-[60px] lg:right-[60px] z-10">
        <p class="!text-white/85 mb-[16px] uppercase font-medium text-[12px]" style="letter-spacing:1.8px; line-height:1;">
          Tryckeri Stockholm • Sollentuna / Häggvik
        </p>
        <h1 class="typo-hero !text-white mb-[20px] max-w-[640px]" style="text-wrap: balance;">
          Lämna rätt intryck
        </h1>
        <p class="!text-white/90 text-[16px] md:text-[18px] leading-relaxed mb-[28px] max-w-[640px]">
          När du möter kund, partner eller kontaktperson behöver dina uppgifter vara enkla att ta med. Vi hjälper dig välja papper, tryck och finish efter hur visitkortet ska kännas och användas.
        </p>
        <div class="flex flex-wrap items-center gap-[12px] mb-[40px]">
          <a href="/begar-offert" class="btn-pill btn-red">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686210090" class="btn-pill" style="background: white; color: #222;">
            Ring 08-96 01 35
          </a>
        </div>
        <!-- Trust strip -->
        <div class="flex flex-wrap items-end gap-x-[40px] lg:gap-x-[60px] gap-y-[16px]">
          <div class="flex flex-col items-start">
            <span class="!text-white font-[var(--font-heading)] leading-none text-[24px] lg:text-[30px]">100+ år</span>
            <span class="!text-white/70 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">År av erfarenhet</span>
          </div>
          <div class="flex flex-col items-start">
            <span class="!text-white font-[var(--font-heading)] leading-none text-[24px] lg:text-[30px]">1000+</span>
            <span class="!text-white/70 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">Uppdrag årligen</span>
          </div>
          <div class="flex flex-col items-start">
            <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[34px] h-[35px]" />
            <span class="!text-white/85 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">Svanenmärkt</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR VISITKORT?" ═══ -->
  <section class="page-section">
    <div class="page-content">
      <p class="section-label">Varför visitkort?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          Ett visitkort kan bara lämna kontaktuppgifter. <em>Eller göra mötet lättare att minnas.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            När papper, tryck och finish passar varumärket blir kortet en naturlig del av presentationen.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            {effects.map((eff) => (
              <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
                <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
                <span>{eff}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="/begar-offert" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Offertförfrågan<Fragment set:html={arrowSvg} />
            </a>
            <a href="/produkter/visitkort/infografik" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Gratis infografik<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "Vad vill du uppnå?" — sidoscroll-kort ═══ -->
  <section class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">När du behöver visitkort</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Det handlar inte om kontaktuppgifter. Det handlar om vad du lämnar efter dig.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px] mb-[4px] sm:mb-[6px]">
        Ett visitkort kan vara enkelt, klassiskt eller mer exklusivt.
      </p>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Det viktiga är att det känns rätt för personen, rollen och varumärket. Berätta vad du vill uppnå – vi rekommenderar papper och finish.
      </p>
    </div>
    <div id="scenario-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] lg:pl-[44px] pr-[16px] sm:pr-[24px] lg:pr-[44px]">
      {scenarios.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[400px] sm:min-h-[440px] md:min-h-[482px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.75rem); line-height: 1.15; hyphens: auto; word-wrap: break-word;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444] mb-[20px] sm:mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[16px] sm:pt-[20px] border-t border-[#C8C8C8]">
            <p class="text-[13px] sm:text-[14px] leading-relaxed text-[#222]">
              <strong class="font-bold">Vår rekommendation:</strong> {s.rec}
            </p>
          </div>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] lg:mr-[44px]">
      <button id="scenario-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR ═══ -->
  <section class="page-section">
    <div class="max-w-[1140px] mx-auto text-center">
      <p class="section-label" style="margin-bottom: 16px;">Hur vi jobbar</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[40px] sm:mb-[56px] md:mb-[72px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
        Tre steg till rätt visitkort.
      </h2>
      <div class="grid sm:grid-cols-3 gap-[28px] sm:gap-[32px] md:gap-[48px] lg:gap-[60px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Du berättar</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Du beskriver antal, personer, användning, varumärke och om originalet finns klart.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Vi rekommenderar</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Vi föreslår papper, tryckmetod, finish, specialeffekter och eventuell hjälp med design.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Du godkänner</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Du får ett tydligt förslag och godkänner innan visitkorten går till tryck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-content max-w-[1400px] mx-auto">
      <p class="section-label">Varför vi inte har en webbshop</p>
      <div class="grid md:grid-cols-[1fr_1fr] gap-[32px] md:gap-[60px] lg:gap-[120px] items-start">
        <div class="md:max-w-[520px]">
          <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 3.5vw, 3.5rem); line-height: 1.1; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
            Visitkort är små, men detaljerna syns direkt.
          </h2>
        </div>
        <div class="md:max-w-[480px] md:pt-[12px]">
          <div class="space-y-[20px] sm:space-y-[24px] text-[16px] sm:text-[17px] leading-[1.65] text-[#444]" style="text-wrap: pretty;">
            <p>
              Hos webbtryckerier väljer du ur en meny.<br class="hidden md:inline" />
              Hos oss får du rådgivning som matchar varumärket — och en lösning som faktiskt fungerar.
            </p>
            <p class="text-[#222] font-medium">
              Resultatet?<br class="hidden md:inline" />
              Ett visitkort som speglar varumärket — inte bara ett som kostade minst.
            </p>
          </div>
          <div class="pt-[28px] sm:pt-[36px]">
            <a href="/kontakta-oss" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Hjälp? Kontakta oss<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>
