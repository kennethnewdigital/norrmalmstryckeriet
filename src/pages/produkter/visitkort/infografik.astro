---
import Layout from '../../../layouts/Layout.astro';

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Gratis infografik om visitkort | Norrmalmstryckeriet"
  description="Ladda ner vår gratis PDF-guide om visitkort: papperstips, tryckmetoder och finish-effekter. Fyll i formuläret så skickas guiden direkt."
>

  <!-- ═══ HERO (vänsterställd, ljusgrå bg) ═══ -->
  <section class="bg-[#F3F3F3] py-[80px] md:py-[120px] reveal">
    <div class="mx-[44px] md:mx-[80px] max-w-[900px]">
      <p class="text-[#888] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Gratis nedladdning</p>
      <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[24px]" style="font-size: clamp(2.25rem, 5vw, 4rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
        Visitkort-guiden — välj rätt papper, tryck och finish.
      </h1>
      <p class="text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[680px]" style="text-wrap: pretty;">
        En PDF-guide med konkreta råd om pappersval, tryckmetoder, specialeffekter och vad som påverkar priset. Fyll i uppgifterna nedan så får du nedladdningen direkt.
      </p>
    </div>
  </section>

  <!-- ═══ FORMULÄR (vänsterställd, max-w för läsbarhet) ═══ -->
  <section class="py-[60px] md:py-[100px] reveal">
    <div class="mx-[44px] md:mx-[80px] max-w-[560px]">
      <form
        id="visitkort-infografik-form"
        class="space-y-[14px]"
        action="/downloads/visitkort-infographic.pdf"
        method="get"
        target="_blank"
      >
        <div>
          <label for="name" class="block text-[14px] font-medium text-[#222] mb-[6px]">Ditt namn <span class="text-[#D9222A]">*</span></label>
          <input
            type="text"
            id="name"
            name="name"
            placeholder="För- och efternamn"
            required
            class="w-full px-[16px] py-[14px] rounded-[6px] bg-white border border-[#D5D8DC] focus:border-[#222] outline-none text-[16px] font-[var(--font-body)] transition-colors"
          />
        </div>

        <div>
          <label for="email" class="block text-[14px] font-medium text-[#222] mb-[6px]">E-post <span class="text-[#D9222A]">*</span></label>
          <input
            type="email"
            id="email"
            name="email"
            placeholder="namn@foretag.se"
            required
            class="w-full px-[16px] py-[14px] rounded-[6px] bg-white border border-[#D5D8DC] focus:border-[#222] outline-none text-[16px] font-[var(--font-body)] transition-colors"
          />
        </div>

        <div>
          <label for="company" class="block text-[14px] font-medium text-[#222] mb-[6px]">Företag <span class="text-[#888] font-normal">(valfritt)</span></label>
          <input
            type="text"
            id="company"
            name="company"
            placeholder="Företagsnamn"
            class="w-full px-[16px] py-[14px] rounded-[6px] bg-white border border-[#D5D8DC] focus:border-[#222] outline-none text-[16px] font-[var(--font-body)] transition-colors"
          />
        </div>

        <div>
          <label for="role" class="block text-[14px] font-medium text-[#222] mb-[6px]">Roll <span class="text-[#888] font-normal">(valfritt)</span></label>
          <input
            type="text"
            id="role"
            name="role"
            placeholder="T.ex. marknadschef, designer"
            class="w-full px-[16px] py-[14px] rounded-[6px] bg-white border border-[#D5D8DC] focus:border-[#222] outline-none text-[16px] font-[var(--font-body)] transition-colors"
          />
        </div>

        <div class="flex items-start gap-[10px] mt-[16px]">
          <input
            type="checkbox"
            id="newsletter"
            name="newsletter"
            class="mt-[5px] w-[16px] h-[16px] cursor-pointer"
          />
          <label for="newsletter" class="text-[14px] leading-relaxed text-[#555] cursor-pointer">
            Ja tack, jag vill gärna få tryck-tips och guider per e-post (kan avregistreras när som helst).
          </label>
        </div>

        <button type="submit" class="btn-pill btn-red w-full justify-center mt-[20px]">
          Ladda ner infografik (PDF)<Fragment set:html={arrowSvg} />
        </button>

        <p class="text-[12px] text-[#888] mt-[14px] leading-relaxed" style="text-wrap: pretty;">
          Vi använder uppgifterna för att skicka guiden och eventuella uppföljningar. Vi delar aldrig din e-post med tredje part. Läs vår <a href="/integritetspolicy" class="underline hover:text-[#222]">integritetspolicy</a>.
        </p>
      </form>
    </div>
  </section>

  <!-- ═══ DETTA FÅR DU I GUIDEN (samma form som "Hur vi jobbar" på visitkort) ═══ -->
  <section class="bg-[#F3F3F3] py-[100px] md:py-[140px] reveal">
    <div class="mx-[44px] md:mx-[80px] max-w-[1300px]">
      <p class="text-[#888] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">I guiden</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[80px] md:mb-[100px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
        Detta får du i guiden.
      </h2>
      <div class="grid md:grid-cols-3 gap-[40px] md:gap-[60px]">
        <div class="reveal">
          <span class="typo-process-number block">1.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Pappersval</h3>
          <p class="text-[15px] leading-relaxed text-[#555]" style="text-wrap: pretty;">Bestruket vs obestruket, gramvikter och specialpapper — när varje typ passar bäst för ditt budskap och varumärke.</p>
        </div>
        <div class="reveal" style="transition-delay: 100ms;">
          <span class="typo-process-number block">2.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Tryckmetod</h3>
          <p class="text-[15px] leading-relaxed text-[#555]" style="text-wrap: pretty;">Digitaltryck, offsettryck, Pantone och variabeltryck — när varje metod är rätt val baserat på upplaga, färgkrav och versioner.</p>
        </div>
        <div class="reveal" style="transition-delay: 200ms;">
          <span class="typo-process-number block">3.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Efterbehandling</h3>
          <p class="text-[15px] leading-relaxed text-[#555]" style="text-wrap: pretty;">Folieprägling, UV-lack, prägling, laminering och specialformer — när varje effekt lyfter kortet utan att störa läsbarheten.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TILLBAKA-LÄNK ═══ -->
  <section class="py-[60px] md:py-[80px]">
    <div class="mx-[44px] md:mx-[80px]">
      <a href="/produkter/visitkort" class="inline-flex items-center text-[#222] font-medium hover:underline text-[16px]">
        ← Tillbaka till visitkort
      </a>
    </div>
  </section>

</Layout>
