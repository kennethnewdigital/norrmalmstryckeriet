---
import Layout from '../../../layouts/Layout.astro';

const effects = [
  'Mer plats för innehåll och bilder',
  'Tydlig struktur från start till CTA',
  'Rätt känsla för möte, mässa och utskick',
  'Smidigare val av format, papper och upplaga',
];

const scenarios = [
  {
    title: 'Du ska presentera företaget',
    body: 'Du behöver en folder som snabbt förklarar vilka ni är, vad ni erbjuder och varför kunden ska välja er. Konsekvensen blir att innehållet behöver kännas samlat, tydligt och representativt.',
    rec: '4-sidig A4 eller A5, silk eller obestruket papper, fullfärg 4+4 och falsning som ger tydlig läsordning.',
  },
  {
    title: 'Du ska sälja en tjänst',
    body: 'Du vill lämna något efter mötet som kunden kan läsa, dela och återkomma till. Konsekvensen blir att foldern behöver bära både argument, exempel och kontaktväg.',
    rec: 'A5-folder med tydlig framsida, strukturerat innehåll, digitaltryck för mindre upplaga och papper som känns professionellt i handen.',
  },
  {
    title: 'Du ska lansera en produkt',
    body: 'Du behöver visa funktioner, nytta, bilder och tekniska detaljer på ett sätt som känns enkelt. Konsekvensen blir att ytan behöver planeras så att kunden snabbt förstår värdet.',
    rec: '4-sidig A4-folder, fullfärg, bildstarkt papper och falsning som delar upp produkt, fördelar, specifikation och kontakt.',
  },
  {
    title: 'Du ska trycka till mässa',
    body: 'Du behöver material som går snabbt att dela ut och lätt att ta med sig vidare. Konsekvensen blir att formatet behöver vara kompakt, tydligt och tåla många händer.',
    rec: 'A5-folder, digitaltryck vid mindre upplaga eller offsettryck vid större upplaga, samt matt eller tålig yta beroende på användning.',
  },
  {
    title: 'Du ska göra ett utskick',
    body: 'Du vill skicka information som känns mer genomarbetad än ett enkelt blad. Konsekvensen blir att format, vikt och falsning behöver fungera med kuvert, porto och hantering.',
    rec: '4-sidig A5-folder, anpassad gramvikt, fullfärg och falsning som gör foldern enkel att packa och distribuera.',
  },
  {
    title: 'Du vill skapa premiumkänsla',
    body: 'Du behöver en folder som stärker varumärket och känns genomarbetad redan vid första kontakten. Konsekvensen blir att materialval och efterbehandling får stor betydelse.',
    rec: 'Högre gramvikt, silk eller bestruket papper, laminering, prägling eller foliering där uttrycket ska förstärkas.',
  },
];

const expertise = [
  {
    title: 'Pappersval',
    intro: 'Pappret påverkar både känslan och hur foldern falsas. Ett för kraftigt papper kan göra en folder svår att stänga snyggt, särskilt vid flera falsningar.',
    items: [
      ['Bestruket', 'Slät yta där färger och bilder får tydligt tryck. Bra för produktpresentationer, kampanjer och bildstarkt material.'],
      ['Obestruket', 'Naturlig och taktil känsla. Bra för text, instruktioner, miljöprofil och material som ska kännas mer nedtonat.'],
      ['Lättare papper', 'Smidigt för utskick och foldrar med flera falsningar.'],
      ['Stabilare papper', 'Ger mer professionell känsla i handen. Bra för mässor, företagspresentationer och säljmaterial.'],
      ['Kraftigare papper', 'Passar enklare falsningar där foldern ska kännas mer exklusiv.'],
    ],
  },
  {
    title: 'Tryckmetod',
    intro: 'Digitaltryck eller offset? Det beror på upplaga, tidsram, färgkrav och hur foldern ska användas.',
    items: [
      ['Digitaltryck', 'Snabbt och flexibelt. Passar mindre upplagor, testversioner och kortare serier.'],
      ['Offsettryck', 'Effektivt vid större upplagor. Passar kampanjer, utskick och material där styckpris och färgstabilitet blir viktiga.'],
      ['Pantone', 'Exakt färgmatchning. Bra när logotyp eller profilfärg behöver återges konsekvent.'],
      ['Variabeltryck', 'Anpassa foldern med namn, område, QR-kod eller mottagarstyrt innehåll.'],
    ],
  },
  {
    title: 'Efterbehandling',
    intro: 'Här avgörs mycket av folderns funktion. Efterbehandlingen styr hur foldern öppnas, håller och upplevs i handen.',
    items: [
      ['Falsning', 'Rullfals, parallellfals, altarfals eller annan lösning efter innehåll och format.'],
      ['Laminering', 'Matt, silk eller blank yta. Skyddar och ger mer tålig känsla.'],
      ['Prägling', 'Upphöjd detalj, till exempel logotyp. Ger taktil och mer exklusiv känsla.'],
      ['Stansning', 'Skapar specialform, öppning eller ett mer unikt uttryck.'],
      ['Foliering', 'Metallisk effekt i exempelvis guld eller silver. Bra när detaljer ska lyftas.'],
    ],
  },
];

const testimonial = {
  quote: 'Vi fick hjälp att välja rätt format och papper för vårt material. Foldern blev tydlig, lätt att använda och kändes professionell i mötet.',
  author: 'Exempelcitat',
  role: 'Ersätt med verifierat kundcitat före publicering',
};

const faqs = [
  { q: 'Vad är en folder?', a: 'En folder är ett tryckt blad som falsas till flera sidor. Den passar när du vill presentera mer innehåll än vad ett enkelt blad rymmer.' },
  { q: 'Vad är falsning?', a: 'Falsning är när ett tryckt ark viks maskinellt till flera sidor. Valet av falsning påverkar läsordning, format och hur foldern öppnas.' },
  { q: 'Ska jag välja A5 eller A4?', a: 'A5 passar när foldern ska vara kompakt, lätt att dela ut och enkel att ta med. A4 passar när du behöver mer plats för bilder, erbjudanden eller produktinformation.' },
  { q: 'När passar digitaltryck?', a: 'Digitaltryck passar ofta mindre upplagor, versionerat material och produktion där flexibilitet är viktig. Det är bra när foldern ska tas fram snabbt eller i flera varianter.' },
  { q: 'När passar offsettryck?', a: 'Offsettryck passar ofta större upplagor där styckpris och färgstabilitet blir viktiga. Det är vanligt vid utskick, kampanjer och återkommande material.' },
  { q: 'Vad påverkar priset på en folder?', a: 'Pris påverkas av format, upplaga, papper, tryckmetod, falsning och efterbehandling. Vi rekommenderar lösning efter användning, budget och önskat intryck.' },
  { q: 'Vilket papper ska jag välja?', a: 'Silk ger ofta en jämn och professionell känsla med bra bildåtergivning. Obestruket passar när uttrycket ska kännas mer naturligt, taktilt eller skrivbart.' },
  { q: 'Kan foldern få premiumkänsla?', a: 'Ja. Laminering, prägling, foliering och kraftigare papper kan förstärka känslan. Valet bör kopplas till varumärke, mottagare och användning.' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka foldrar – rådgivning, format och falsning | Norrmalmstryckeriet"
  description="Tryck foldrar för mässa, utskick, presentation och säljmaterial. Vi hjälper dig välja format, papper, falsning, digitaltryck eller offsettryck."
>

  <!-- ═══ HERO ═══ -->
  <!-- MOBILE+TABLET HERO -->
  <section class="lg:hidden">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] mt-[16px] sm:mt-[24px]">
      <div class="rounded-[20px] sm:rounded-[28px] overflow-hidden aspect-[4/3] sm:aspect-[16/9] md:aspect-[2/1] mb-[24px] sm:mb-[32px] bg-[#1a1a2e]">
        <img
          src="/images/hero/foldrar-hero.svg"
          alt="Foldrar från Norrmalmstryckeriet"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="px-[4px] sm:px-[8px] md:px-[16px] max-w-[760px]">
        <p class="text-[#888] mb-[12px] sm:mb-[16px] uppercase font-medium text-[10px] sm:text-[11px]" style="letter-spacing:1.5px; line-height:1;">
          Tryckeri Stockholm • Sollentuna / Häggvik
        </p>
        <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.875rem, 5vw + 0.5rem, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
          Foldrar som förklarar
        </h1>
        <p class="text-[#444] text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed mb-[24px] sm:mb-[28px]">
          När ett blad blir för kort ger foldern plats för ordning, bilder och tydlig nästa handling. Vi hjälper dig välja format, papper, falsning och tryck efter hur foldern ska användas.
        </p>
        <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px] mb-[32px] sm:mb-[40px]">
          <a href="/offert" class="btn-pill btn-red w-full sm:w-auto justify-center">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686960135" class="btn-pill w-full sm:w-auto justify-center" style="background: #F3F3F3; color: #222;">
            Ring 08-96 01 35
          </a>
        </div>
        <div class="flex flex-wrap items-end gap-x-[24px] sm:gap-x-[40px] gap-y-[16px] pt-[8px]">
          <div class="flex flex-col items-start">
            <span class="font-[var(--font-heading)] text-[#222] leading-none text-[22px] sm:text-[26px]">100+ år</span>
            <span class="text-[#666] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">År av erfarenhet</span>
          </div>
          <div class="flex flex-col items-start">
            <span class="font-[var(--font-heading)] text-[#222] leading-none text-[22px] sm:text-[26px]">1000+</span>
            <span class="text-[#666] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">Uppdrag årligen</span>
          </div>
          <div class="flex flex-col items-start">
            <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[30px] h-[31px] sm:w-[34px] sm:h-[35px]" />
            <span class="text-[#222] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">Svanenmärkt tryckeri</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESKTOP HERO -->
  <section class="relative hidden lg:block">
    <div class="hero-box mx-[34px] mt-[24px] rounded-[50px] overflow-hidden relative bg-[#1a1a2e]">
      <img
        src="/images/hero/foldrar-hero.svg"
        alt="Foldrar från Norrmalmstryckeriet"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/35 to-black/10 pointer-events-none"></div>
      <div class="absolute top-1/2 -translate-y-1/2 left-[40px] right-[40px] lg:left-[60px] lg:right-[60px] z-10">
        <p class="!text-white/85 mb-[16px] uppercase font-medium text-[12px]" style="letter-spacing:1.8px; line-height:1;">
          Tryckeri Stockholm • Sollentuna / Häggvik
        </p>
        <h1 class="typo-hero !text-white mb-[20px] max-w-[640px]" style="text-wrap: balance;">
          Foldrar som förklarar
        </h1>
        <p class="!text-white/90 text-[16px] md:text-[18px] leading-relaxed mb-[28px] max-w-[640px]">
          När ett blad blir för kort ger foldern plats för ordning, bilder och tydlig nästa handling. Vi hjälper dig välja format, papper, falsning och tryck efter hur foldern ska användas.
        </p>
        <div class="flex flex-wrap items-center gap-[12px] mb-[40px]">
          <a href="/offert" class="btn-pill btn-red">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686960135" class="btn-pill" style="background: white; color: #222;">
            Ring 08-96 01 35
          </a>
        </div>
        <div class="flex flex-wrap items-end gap-x-[40px] lg:gap-x-[60px] gap-y-[16px]">
          <div class="flex flex-col items-start">
            <span class="!text-white font-[var(--font-heading)] leading-none text-[24px] lg:text-[30px]">100+ år</span>
            <span class="!text-white/70 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">År av erfarenhet</span>
          </div>
          <div class="flex flex-col items-start">
            <span class="!text-white font-[var(--font-heading)] leading-none text-[24px] lg:text-[30px]">1000+</span>
            <span class="!text-white/70 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">Uppdrag årligen</span>
          </div>
          <div class="flex flex-col items-start">
            <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[34px] h-[35px]" />
            <span class="!text-white/85 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">Svanenmärkt tryckeri</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR FOLDER?" ═══ -->
  <section class="page-section">
    <div class="page-content">
      <p class="section-label">Varför folder?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          En folder kan vara löst falsad. <em>Eller genomtänkt från första sida till sista uppmaning.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            När format, papper, tryck och falsning samspelar blir budskapet lättare att ta till sig.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            {effects.map((eff) => (
              <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
                <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
                <span>{eff}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="/offert" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Offertförfrågan<Fragment set:html={arrowSvg} />
            </a>
            <a href="/guider/foldrar" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Läs guiden<Fragment set:html={arrowSvg} />
            </a>
            <a href="/produkter/foldrar/infografik" class="btn-pill w-full sm:w-auto justify-center" style="background: #F3F3F3; color: #222;">
              Ladda ner PDF<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4M7 10l5 5 5-5M12 15V3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "Vad vill du uppnå?" — sidoscroll-kort ═══ -->
  <section class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Vad vill du uppnå</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Berätta situationen. Vi löser trycket.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px] mb-[4px] sm:mb-[6px]">
        Det handlar inte om falsning. Det handlar om ordning. En folder kan guida mottagaren genom erbjudande, produkt, instruktion eller kampanj.
      </p>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Det viktiga är att innehållet kommer i rätt följd. Berätta vad du vill uppnå – vi rekommenderar format och falsning.
      </p>
    </div>
    <div id="scenario-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {scenarios.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[400px] sm:min-h-[440px] md:min-h-[482px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.75rem); line-height: 1.15; hyphens: auto; word-wrap: break-word;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444] mb-[20px] sm:mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[16px] sm:pt-[20px] border-t border-[#C8C8C8]">
            <p class="text-[13px] sm:text-[14px] leading-relaxed text-[#222]">
              <strong class="font-bold">Vår rekommendation:</strong> {s.rec}
            </p>
          </div>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="scenario-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR ═══ -->
  <section class="page-section">
    <div class="max-w-[1140px] mx-auto text-center">
      <p class="section-label" style="margin-bottom: 16px;">Hur vi jobbar</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[40px] sm:mb-[56px] md:mb-[72px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
        Tre steg till rätt folder.
      </h2>
      <div class="grid sm:grid-cols-3 gap-[28px] sm:gap-[32px] md:gap-[48px] lg:gap-[60px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Du berättar</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Du beskriver syfte, upplaga, målgrupp och hur foldern ska användas.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Vi rekommenderar</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Vi föreslår format, papper, tryckmetod, falsning och eventuell efterbehandling.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Du godkänner</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Du får ett tydligt förslag och godkänner innan foldern går till tryck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP ═══ -->
  <section class="bg-[#F3F3F3] reveal">
    <div class="page-section">
      <div class="page-container max-w-[1400px]">
        <p class="section-label">Varför vi inte har en webbshop</p>
        <div class="grid md:grid-cols-[1fr_1fr] gap-[32px] md:gap-[60px] lg:gap-[120px] items-start">
          <div class="md:max-w-[520px]">
            <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 3.5vw, 3.5rem); line-height: 1.1; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
              Foldrar påverkas mycket av valen runt trycket.
            </h2>
          </div>
          <div class="md:max-w-[480px] md:pt-[12px]">
            <div class="space-y-[20px] sm:space-y-[24px] text-[16px] sm:text-[17px] leading-[1.65] text-[#444]" style="text-wrap: pretty;">
              <p>
                Format, gramvikt, falsning, upplaga och efterbehandling avgör hur foldern känns, fungerar och används.
              </p>
              <p class="text-[#222] font-medium">
                Med rådgivning får du en lösning som passar situationen. Det gör valet enklare och resultatet mer genomtänkt.
              </p>
            </div>
            <div class="pt-[28px] sm:pt-[36px]">
              <a href="/kontakta-oss" class="btn-pill btn-dark w-full sm:w-auto justify-center">
                Hjälp? Kontakta oss<Fragment set:html={arrowSvg} />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk rundad) ═══ -->
