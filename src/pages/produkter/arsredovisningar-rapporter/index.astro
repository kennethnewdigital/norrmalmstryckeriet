  }
  @media (min-width: 1440px) {
    .hero-box { aspect-ratio: 2 / 1; max-height: 88vh; }
  }
  @media (min-width: 1920px) {
    .hero-box { aspect-ratio: 2.2 / 1; max-height: 90vh; }
  }

  .page-section-no-px {
    padding-top: 48px;
    padding-bottom: 48px;
  }
  @media (min-width: 640px) {
    .page-section-no-px { padding-top: 56px; padding-bottom: 56px; }
  }
  @media (min-width: 768px) {
    .page-section-no-px { padding-top: 72px; padding-bottom: 72px; }
  }
  @media (min-width: 1024px) {
    .page-section-no-px { padding-top: 88px; padding-bottom: 88px; }
  }
</style>

<script>
  function initArsRapport() {
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const plusIcon = btn.querySelector('.faq-plus') as HTMLElement;
        const minusIcon = btn.querySelector('.faq-minus') as HTMLElement;
        if (!answer) return;
        const isOpen = answer.classList.contains('open');
        if (isOpen) {
          answer.classList.remove('open');
          answer.style.maxHeight = '0';
          plusIcon?.classList.remove('hidden');
          minusIcon?.classList.add('hidden');
        } else {
          answer.classList.add('open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          plusIcon?.classList.add('hidden');
          minusIcon?.classList.remove('hidden');
        }
      });
    });

    document.querySelectorAll('.faq-answer').forEach((a) => {
      (a as HTMLElement).style.maxHeight = '0';
      (a as HTMLElement).style.overflow = 'hidden';
      (a as HTMLElement).style.transition = 'max-height 0.25s ease';
    });

    const scenarioC = document.getElementById('scenario-carousel');
    const sw = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('scenario-prev')?.addEventListener('click', () => { scenarioC?.scrollBy({ left: -sw, behavior: 'smooth' }); });
    document.getElementById('scenario-next')?.addEventListener('click', () => { scenarioC?.scrollBy({ left: sw, behavior: 'smooth' }); });

    const refC = document.getElementById('ref-carousel');
    const rw = window.matchMedia('(min-width: 768px)').matches ? 620 : (window.matchMedia('(min-width: 640px)').matches ? 420 : 296);
    document.getElementById('ref-prev')?.addEventListener('click', () => { refC?.scrollBy({ left: -rw, behavior: 'smooth' }); });
    document.getElementById('ref-next')?.addEventListener('click', () => { refC?.scrollBy({ left: rw, behavior: 'smooth' }); });
  }

  initArsRapport();
  document.addEventListener('astro:after-swap', initArsRapport);
</script>
