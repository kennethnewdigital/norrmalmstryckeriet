---
import Layout from '../../../layouts/Layout.astro';

const effects = [
  'Mer plats för förklaring och bild',
  'Tydlig läsordning över flera sidor',
  'Rätt känsla för företag, produkt och varumärke',
  'Möjlighet till häftning, limbindning och finish',
];

const scenarios = [
  {
    title: 'Du ska presentera företaget',
    body: 'Du behöver visa verksamhet, erbjudande, människor och kontaktvägar i en tydlig helhet. Konsekvensen blir att innehållet behöver en röd tråd över flera sidor.',
    rec: 'A5 eller A4, 8–12 sidor, fullfärg 4+4, silk eller obestruket papper och häftning eller limbindning efter sidantal.',
  },
  {
    title: 'Du ska göra en produktbroschyr',
    body: 'Du behöver visa bilder, funktioner, användning och fördelar utan att allt trängs på en sida. Konsekvensen blir att format och sidflöde behöver hjälpa kunden att jämföra och förstå.',
    rec: 'A4 vid mer information, fullfärg, papper med bra bildåtergivning och tydliga avsnitt för produkt, nytta och kontakt.',
  },
  {
    title: 'Du ska skapa en kampanjbroschyr',
    body: 'Du vill samla erbjudande, argument och nästa steg i ett material som känns mer genomarbetat än ett blad. Konsekvensen blir att första sidan behöver väcka intresse och insidorna bygga förtroende.',
    rec: 'A5, 8 sidor, digitaltryck vid mindre upplaga och offsettryck vid större upplaga.',
  },
  {
    title: 'Du ska ta fram utbildningsmaterial',
    body: 'Du behöver ett häfte som går att läsa i ordning, anteckna i och spara. Konsekvensen blir att läsbarhet, papper och bindning blir viktiga för användningen.',
    rec: 'A4 eller A5, obestruket papper, tydlig sidnumrering och häftning eller limbindning beroende på sidantal.',
  },
  {
    title: 'Du ska trycka till mässa',
    body: 'Du behöver ett material som ger mer fördjupning än ett reklamblad och som kan tas med vidare. Konsekvensen blir att broschyren behöver vara lätt att dela ut, lätt att bläddra i och tydlig i avslutet.',
    rec: 'A5, 8–12 sidor, fullfärg, kraftigare omslag och tydlig kontakt på baksidan.',
  },
  {
    title: 'Du vill skapa premiumkänsla',
    body: 'Du behöver en broschyr som speglar varumärket och känns genomarbetad i handen. Konsekvensen blir att papper, omslag och efterbehandling påverkar helhetsintrycket.',
    rec: 'Högre gramvikt på omslag, silk eller bestruket papper, laminering, prägling eller foliering där känslan ska förstärkas.',
  },
];

const expertise = [
  {
    title: 'Pappersval',
    intro: 'I en broschyr ska pappret fungera över flera sidor. Det påverkar bläddring, bildkänsla och hur materialet upplevs.',
    items: [
      ['Bestruket', 'Slät yta med tydlig färgåtergivning. Bra för bilder, produktkataloger och visuella presentationer.'],
      ['Obestruket', 'Naturlig och taktil känsla. Bra för text, utbildningsmaterial och ett mer nedtonat uttryck.'],
      ['Lättare inlaga', 'Bra när sidantalet är högre och broschyren ska vara smidig att bläddra i.'],
      ['Stabilare inlaga', 'Ger mer professionell känsla och fungerar bra när broschyren ska sparas.'],
      ['Kraftigare omslag', 'Ger bättre första intryck, tydligare struktur och mer hållbarhet.'],
    ],
  },
  {
    title: 'Tryckmetod',
    intro: 'Broschyrens upplaga, sidantal och färgkrav styr tryckvalet. Målet är att innehåll, ekonomi och känsla ska mötas i rätt produktion.',
    items: [
      ['Digitaltryck', 'Snabbt och flexibelt. Passar mindre upplagor, korta serier och versionerade broschyrer.'],
      ['Offsettryck', 'Effektivt vid större upplagor. Passar när jämn färgåtergivning och lägre styckpris i volym blir viktiga.'],
      ['Pantone', 'Exakt färgmatchning. Bra när varumärkesfärger behöver återges konsekvent.'],
      ['Variabeltryck', 'Anpassa broschyren efter mottagare, region, kundgrupp eller kampanjversion.'],
    ],
  },
  {
    title: 'Efterbehandling',
    intro: 'Bindning och finish gör broschyren mer användbar och mer värd att spara. Här avgörs mycket av slutkänslan.',
    items: [
      ['Häftning', 'Vanligt för broschyrer med färre sidor. Ger ett smidigt och lättbläddrat format.'],
      ['Limbindning', 'Passar större sidantal och mer bokliknande känsla.'],
      ['Laminering eller lack', 'Skyddar omslaget och ger matt, silk eller blank finish.'],
      ['Prägling', 'Ger logotyp eller detalj mer djup och taktil känsla.'],
      ['Foliering', 'Skapar premiumkänsla på omslag, titel eller rubrik.'],
    ],
  },
];

const testimonial = {
  quote: 'Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser.',
  author: 'Björn Jansson',
  role: 'Projektledare, Repro 8',
};

const faqs = [
  { q: 'Vad är skillnaden mellan folder och broschyr?', a: 'En folder är ofta ett falsat blad med färre ytor. En broschyr har flera sidor och passar när innehållet behöver mer struktur.' },
  { q: 'När passar en broschyr bäst?', a: 'Broschyrer passar företagspresentationer, produktinformation, kampanjer och utbildningsmaterial. De fungerar när mottagaren behöver läsa mer än ett kort budskap.' },
  { q: 'Vilket format ska jag välja?', a: 'A5 passar när broschyren ska vara lätt att dela ut och ta med. A4 passar när bilder, tabeller eller längre texter behöver mer utrymme.' },
  { q: 'Vad påverkar priset på en broschyr?', a: 'Sidantal, format, upplaga, papper, tryckmetod, bindning och efterbehandling påverkar priset. Vi rekommenderar val efter innehåll och användning.' },
  { q: 'När passar digitaltryck?', a: 'Digitaltryck passar ofta mindre upplagor och flexibla produktioner. Det är ett bra val när materialet ska tas fram i begränsad mängd.' },
  { q: 'När passar offsettryck?', a: 'Offsettryck passar ofta större upplagor. Det kan ge bra styckekonomi och jämn färgåtergivning vid volym.' },
  { q: 'När ska broschyren häftas?', a: 'Häftning passar ofta broschyrer med färre sidor och smidigt format. Det ger en lättbläddrad trycksak som fungerar bra för presentation och kampanj.' },
  { q: 'När passar limbindning?', a: 'Limbindning passar när broschyren har fler sidor eller ska kännas mer som en bok. Det ger mer tyngd och en tydligare rygg.' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka broschyrer – format, papper och bindning | Norrmalmstryckeriet"
  description="Tryck broschyrer för företag, produkt, kampanj och utbildning. Vi hjälper dig välja format, sidantal, papper, tryckmetod och bindning."
>

  <!-- ═══ HERO ═══ -->
  <!-- MOBILE+TABLET HERO: Bild överst, text under -->
  <section class="lg:hidden">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] mt-[16px] sm:mt-[24px]">
      <div class="rounded-[20px] sm:rounded-[28px] overflow-hidden aspect-[4/3] sm:aspect-[16/9] md:aspect-[2/1] mb-[24px] sm:mb-[32px]">
        <img
          src="/images/hero/broschyr-hero.webp"
          alt="Broschyrer från Norrmalmstryckeriet"
          class="w-full h-full object-cover"
        />
      </div>
      <div class="px-[4px] sm:px-[8px] md:px-[16px] max-w-[760px]">
        <p class="text-[#888] mb-[12px] sm:mb-[16px] uppercase font-medium text-[10px] sm:text-[11px]" style="letter-spacing:1.5px; line-height:1;">
          Tryckeri Stockholm • Sollentuna / Häggvik
        </p>
        <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.875rem, 5vw + 0.5rem, 3.5rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
          Mer att berätta
        </h1>
        <p class="text-[#444] text-[15px] sm:text-[16px] md:text-[18px] leading-relaxed mb-[24px] sm:mb-[28px]">
          När ett blad blir för kort ger broschyren plats för ordning, bilder och fördjupning. Vi hjälper dig välja format, sidantal, papper, tryck och bindning efter hur broschyren ska användas.
        </p>
        <div class="flex flex-col sm:flex-row sm:flex-wrap gap-[10px] sm:gap-[12px] mb-[32px] sm:mb-[40px]">
          <a href="/offert" class="btn-pill btn-red w-full sm:w-auto justify-center">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686960135" class="btn-pill w-full sm:w-auto justify-center" style="background: #F3F3F3; color: #222;">
            Ring 08-96 01 35
          </a>
        </div>
        <div class="flex flex-wrap items-end gap-x-[24px] sm:gap-x-[40px] gap-y-[16px] pt-[8px]">
          <div class="flex flex-col items-start">
            <span class="font-[var(--font-heading)] text-[#222] leading-none text-[22px] sm:text-[26px]">100+ år</span>
            <span class="text-[#666] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">År av erfarenhet</span>
          </div>
          <div class="flex flex-col items-start">
            <span class="font-[var(--font-heading)] text-[#222] leading-none text-[22px] sm:text-[26px]">1000+</span>
            <span class="text-[#666] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">Uppdrag årligen</span>
          </div>
          <div class="flex flex-col items-start">
            <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[30px] h-[31px] sm:w-[34px] sm:h-[35px]" />
            <span class="text-[#222] mt-[6px] font-medium uppercase text-[10px]" style="letter-spacing: 1.4px;">Svanenmärkt tryckeri</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- DESKTOP HERO: Overlay (1024px+) -->
  <section class="relative hidden lg:block">
    <div class="hero-box mx-[34px] mt-[24px] rounded-[50px] overflow-hidden relative">
      <img
        src="/images/hero/broschyr-hero.webp"
        alt="Broschyrer från Norrmalmstryckeriet"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-r from-black/65 via-black/35 to-black/10 pointer-events-none"></div>
      <div class="absolute top-1/2 -translate-y-1/2 left-[40px] right-[40px] lg:left-[60px] lg:right-[60px] z-10">
        <p class="!text-white/85 mb-[16px] uppercase font-medium text-[12px]" style="letter-spacing:1.8px; line-height:1;">
          Tryckeri Stockholm • Sollentuna / Häggvik
        </p>
        <h1 class="typo-hero !text-white mb-[20px] max-w-[640px]" style="text-wrap: balance;">
          Mer att berätta
        </h1>
        <p class="!text-white/90 text-[16px] md:text-[18px] leading-relaxed mb-[28px] max-w-[640px]">
          När ett blad blir för kort ger broschyren plats för ordning, bilder och fördjupning. Vi hjälper dig välja format, sidantal, papper, tryck och bindning efter hur broschyren ska användas.
        </p>
        <div class="flex flex-wrap items-center gap-[12px] mb-[40px]">
          <a href="/offert" class="btn-pill btn-red">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686960135" class="btn-pill" style="background: white; color: #222;">
            Ring 08-96 01 35
          </a>
        </div>
        <div class="flex flex-wrap items-end gap-x-[40px] lg:gap-x-[60px] gap-y-[16px]">
          <div class="flex flex-col items-start">
            <span class="!text-white font-[var(--font-heading)] leading-none text-[24px] lg:text-[30px]">100+ år</span>
            <span class="!text-white/70 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">År av erfarenhet</span>
          </div>
          <div class="flex flex-col items-start">
            <span class="!text-white font-[var(--font-heading)] leading-none text-[24px] lg:text-[30px]">1000+</span>
            <span class="!text-white/70 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">Uppdrag årligen</span>
          </div>
          <div class="flex flex-col items-start">
            <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[34px] h-[35px]" />
            <span class="!text-white/85 mt-[8px] font-medium uppercase text-[10px]" style="letter-spacing: 1.5px;">Svanenmärkt tryckeri</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR BROSCHYR?" ═══ -->
  <section class="page-section">
    <div class="page-content">
      <p class="section-label">Varför broschyr?</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
          En broschyr kan vara många sidor. <em>Eller en tydlig väg genom ett längre budskap.</em>
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#222] mb-[24px] sm:mb-[28px]">
            När struktur, papper och bindning samspelar blir innehållet lättare att följa, läsa och spara.
          </p>
          <ul class="space-y-[10px] mb-[28px] sm:mb-[36px]">
            {effects.map((eff) => (
              <li class="flex items-start gap-[10px] text-[15px] sm:text-[16px] leading-relaxed text-[#222]">
                <span class="shrink-0 mt-[9px] sm:mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
                <span>{eff}</span>
              </li>
            ))}
          </ul>
          <div class="flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-[10px] sm:gap-[12px]">
            <a href="/offert" class="btn-pill btn-red w-full sm:w-auto justify-center">
              Offertförfrågan<Fragment set:html={arrowSvg} />
            </a>
            <a href="/produkter/broschyrer/infografik" class="btn-pill btn-dark w-full sm:w-auto justify-center">
              Gratis infografik<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "Vad vill du uppnå?" — sidoscroll-kort ═══ -->
  <section class="page-section-no-px">
    <div class="ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-[44px] mb-[28px] sm:mb-[40px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <p class="section-label" style="margin-bottom: 16px;">Vad vill du uppnå</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Berätta situationen. Vi löser trycket.
      </h2>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px] mb-[4px] sm:mb-[6px]">
        Det handlar inte om sidor. Det handlar om syfte. En broschyr kan vara 8 eller 64 sidor. Det viktiga är att den gör jobbet.
      </p>
      <p class="text-[#555] text-[15px] sm:text-[16px] md:text-[18px] max-w-[800px]">
        Berätta vad du vill uppnå – vi rekommenderar formatet.
      </p>
    </div>
    <div id="scenario-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] lg:pl-[44px] pr-[16px] sm:pr-[24px] md:pr-[32px] lg:pr-[44px]">
      {scenarios.map((s) => (
        <article class="shrink-0 w-[280px] sm:w-[320px] md:w-[380px] bg-[#F5F5F5] rounded-[16px] p-[24px] sm:p-[32px] md:p-[43px] flex flex-col min-h-[400px] sm:min-h-[440px] md:min-h-[482px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px] sm:mb-[20px]" style="font-size: clamp(1.25rem, 1.5vw + 0.5rem, 1.75rem); line-height: 1.15; hyphens: auto; word-wrap: break-word;" lang="sv">{s.title}</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444] mb-[20px] sm:mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[16px] sm:pt-[20px] border-t border-[#C8C8C8]">
            <p class="text-[13px] sm:text-[14px] leading-relaxed text-[#222]">
              <strong class="font-bold">Vår rekommendation:</strong> {s.rec}
            </p>
          </div>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[16px] sm:mt-[24px] mr-[16px] sm:mr-[24px] md:mr-[32px] lg:mr-[44px]">
      <button id="scenario-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR ═══ -->
  <section class="page-section">
    <div class="max-w-[1140px] mx-auto text-center">
      <p class="section-label" style="margin-bottom: 16px;">Hur vi jobbar</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[40px] sm:mb-[56px] md:mb-[72px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em;">
        Tre steg till rätt broschyr.
      </h2>
      <div class="grid sm:grid-cols-3 gap-[28px] sm:gap-[32px] md:gap-[48px] lg:gap-[60px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Du berättar</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Du beskriver syfte, upplaga, målgrupp och hur broschyren ska användas.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Vi rekommenderar</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Vi föreslår format, sidantal, papper, tryckmetod, bindning och eventuell efterbehandling.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.25rem, 2vw, 1.625rem); line-height: 1.2;">Du godkänner</h3>
          <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">Du får ett tydligt förslag och godkänner innan broschyren går till tryck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP ═══ -->
  <section class="bg-[#F3F3F3] reveal">
    <div class="page-section">
      <div class="page-container max-w-[1400px]">
        <p class="section-label">Varför vi inte har en webbshop</p>
        <div class="grid md:grid-cols-[1fr_1fr] gap-[32px] md:gap-[60px] lg:gap-[120px] items-start">
          <div class="md:max-w-[520px]">
            <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 3.5vw, 3.5rem); line-height: 1.1; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance;" lang="sv">
              Broschyrer påverkas av flera val som behöver hänga ihop.
            </h2>
          </div>
          <div class="md:max-w-[480px] md:pt-[12px]">
            <div class="space-y-[20px] sm:space-y-[24px] text-[16px] sm:text-[17px] leading-[1.65] text-[#444]" style="text-wrap: pretty;">
              <p>
                Sidantal, papper, tryckmetod, omslag och bindning styr både känsla och funktion.
              </p>
              <p class="text-[#222] font-medium">
                Med rådgivning får du en broschyr som passar innehållet. Det gör valet enklare och resultatet mer genomtänkt.
              </p>
            </div>
            <div class="pt-[28px] sm:pt-[36px]">
              <a href="/kontakta-oss" class="btn-pill btn-dark w-full sm:w-auto justify-center">
                Hjälp? Kontakta oss<Fragment set:html={arrowSvg} />
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk rundad) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Vår expertis</p>
