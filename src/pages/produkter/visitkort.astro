<script>
  function initVisitkort() {
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const plusIcon = btn.querySelector('.faq-plus') as HTMLElement;
        const minusIcon = btn.querySelector('.faq-minus') as HTMLElement;
        const isOpen = answer.classList.contains('is-open');
        document.querySelectorAll('.faq-answer').forEach((a) => {
          (a as HTMLElement).style.maxHeight = '0';
          a.classList.remove('is-open');
        });
        document.querySelectorAll('.faq-plus').forEach((p) => p.classList.remove('hidden'));
        document.querySelectorAll('.faq-minus').forEach((m) => m.classList.add('hidden'));
        if (!isOpen) {
          answer.classList.add('is-open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          plusIcon.classList.add('hidden');
          minusIcon.classList.remove('hidden');
        }
      });
    });

    const carousel = document.getElementById('scenario-carousel');
    document.getElementById('scenario-prev')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: -400, behavior: 'smooth' });
    });
    document.getElementById('scenario-next')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: 400, behavior: 'smooth' });
    });

    const refCarousel = document.getElementById('ref-carousel');
    document.getElementById('ref-prev')?.addEventListener('click', () => {
      refCarousel?.scrollBy({ left: -620, behavior: 'smooth' });
    });
    document.getElementById('ref-next')?.addEventListener('click', () => {
      refCarousel?.scrollBy({ left: 620, behavior: 'smooth' });
    });
  }

  initVisitkort();
  document.addEventListener('astro:after-swap', initVisitkort);
</script>
