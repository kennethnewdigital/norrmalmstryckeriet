---
import Layout from '../../layouts/Layout.astro';

const effects = [
  'Gör kontaktuppgifter enkla att spara',
  'Stärker första intrycket vid möten',
  'Passar säljteam, mässa och nätverk',
  'Kan lyftas med papper och specialeffekter',
];

// 7 scenarier — exakt från copy
const scenarios = [
  {
    title: 'Du ska beställa visitkort till teamet',
    body: 'Du behöver kort till flera personer med samma grafiska uttryck och olika kontaktuppgifter. Konsekvensen blir att original, versioner och kvalitet behöver hanteras konsekvent.',
    rec: 'Standardformat, gemensam mall, digitaltryck vid mindre antal per person och papper som matchar företagets profil.',
  },
  {
    title: 'Du ska till mässa eller event',
    body: 'Du behöver ett kort som är lätt att dela ut och enkelt för mottagaren att spara. Konsekvensen blir att informationen behöver vara tydlig och kortet kännas professionellt i många möten.',
    rec: 'Visitkort med tydlig framsida, kontaktuppgifter på baksidan, fullfärg och något kraftigare papper.',
  },
  {
    title: 'Du vill stärka första intrycket',
    body: 'Du behöver ett visitkort som känns genomarbetat redan när det lämnas över. Konsekvensen blir att papper, yta och efterbehandling får större betydelse.',
    rec: 'Kraftigare papper, matt laminering, prägling eller folieprägling där logotyp eller namn ska lyftas.',
  },
  {
    title: 'Du behöver visitkort snabbt i mindre upplaga',
    body: 'Du behöver ett begränsat antal kort för nyanställd, rollbyte eller kommande möte. Konsekvensen blir att produktionen behöver vara flexibel och originalet redo för tryck.',
    rec: 'Digitaltryck, standardformat, färdigt original i korrekt format och pappersval som fungerar med kort ledtid.',
  },
  {
    title: 'Du vill skapa miljömedveten profil',
    body: 'Du vill att visitkortet ska spegla omtanke om material och produktion. Konsekvensen blir att pappersval och helhet behöver stödja företagets hållbarhetsprofil.',
    rec: 'Miljövänligt papper, tydlig men återhållsam design, tryck som matchar materialets känsla och förpackning i miljövänlig visitkortsbox.',
  },
  {
    title: 'Du behöver hjälp med design',
    body: 'Du har logotyp och kontaktuppgifter men behöver få visitkortet att kännas färdigt och professionellt. Konsekvensen blir att layout, marginaler, typografi och informationshierarki behöver sitta rätt.',
    rec: 'Designhjälp eller rekommenderad grafisk designer, tydlig originalmall och tryckanpassning med rätt utfall och färginställningar.',
  },
  {
    title: 'Du vill skapa exklusiva visitkort',
    body: 'Du behöver ett kort som fungerar som varumärkesbärare i möten där detaljerna märks. Konsekvensen blir att finishen behöver förstärka varumärket utan att göra kortet svårläst.',
    rec: 'Kraftigare papper, folieprägling, UV-lack eller prägling på utvalda delar samt tydlig kontrast för läsbarhet.',
  },
];

const expertise = [
  {
    title: 'Pappersval',
    intro: 'Visitkort behöver kännas stabila, tydliga och rätt för personen, rollen och varumärket. Materialet påverkar både första intrycket och hur kortet sparas.',
    items: [
      ['Obestruket', 'Naturlig och taktil känsla. Bra för personliga, hållbara eller mer nedtonade uttryck.'],
      ['Bestruket', 'Slätare yta och tydligare färgtryck. Bra för logotyp, bild och starkare kontrast.'],
      ['Kraftigare papper', 'Ger mer tyngd och professionellt intryck i handen.'],
      ['Miljövänliga papper', 'Passar när hållbarhetsprofilen ska synas även i materialvalet.'],
      ['Specialpapper', 'Passar visitkort som ska kännas mer unika eller premium.'],
    ],
  },
  {
    title: 'Tryckmetod',
    intro: 'Visitkort kan behöva produceras till en person, ett helt team eller flera versioner samtidigt. Valet av tryckmetod styrs av upplaga, färgkrav och hur många versioner som behövs.',
    items: [
      ['Digitaltryck', 'Snabbt och flexibelt. Passar mindre upplagor, flera namn och kortare serier.'],
      ['Offsettryck', 'Effektivt vid större upplagor och när färgstabilitet blir viktig.'],
      ['Pantone', 'Exakt färgmatchning. Bra när logotyp eller varumärkesfärg behöver återges konsekvent.'],
      ['Variabeltryck', 'Bra när många personer ska ha samma design men olika kontaktuppgifter.'],
    ],
  },
  {
    title: 'Efterbehandling',
    intro: 'Efterbehandlingen kan göra visitkortet mer taktilt, mer exklusivt eller mer minnesvärt. Det viktiga är att effekten stärker kortet utan att störa läsbarheten.',
    items: [
      ['Laminering', 'Matt, silk eller blank yta. Skyddar och ger ett mer färdigt uttryck.'],
      ['Folieprägling', 'Metallisk detalj i exempelvis guld eller silver. Bra för logotyp, namn eller grafisk detalj.'],
      ['UV-lack', 'Blank detaljeffekt som kan lyfta utvalda delar av kortet.'],
      ['Prägling', 'Upphöjd eller nedsänkt effekt som känns i handen.'],
      ['Rundade hörn / specialform', 'Kan ge kortet ett mer eget uttryck, om det passar varumärket.'],
    ],
  },
];

const testimonial = {
  quote: 'Norrmalmstryckeriet är en trygg och kunnig samarbetspartner som alltid levererar på topp, dessutom till vettiga priser.',
  author: 'Björn Jansson',
  role: 'Projektledare, Repro 8',
};

// 8 FAQ — exakt från copy
const faqs = [
  { q: 'Vad ska finnas på ett visitkort?', a: 'Namn, roll, företag, telefon, e-post och webbadress är ofta viktigast. Logotyp och eventuell QR-kod kan läggas till när de stärker användningen.' },
  { q: 'Vilket papper passar visitkort?', a: 'Ett kraftigare papper ger visitkortet stabilitet och bättre känsla i handen. Valet bör matcha varumärke, design och hur kortet ska användas.' },
  { q: 'Kan ni trycka visitkort till flera personer?', a: 'Ja, visitkort kan tas fram med samma mall och olika kontaktuppgifter. Det passar team, säljorganisationer och nyanställda.' },
  { q: 'När passar digitaltryck för visitkort?', a: 'Digitaltryck passar ofta mindre upplagor, flera namn och kortare serier. Det är praktiskt när visitkorten behöver versioneras.' },
  { q: 'Vad påverkar priset på visitkort?', a: 'Pris påverkas av upplaga, papper, tryck, antal versioner och eventuell efterbehandling. Specialeffekter som folieprägling, UV-lack eller prägling påverkar också priset.' },
  { q: 'Kan visitkort få specialeffekter?', a: 'Ja, folieprägling, UV-lack och prägling kan lyfta logotyp, namn eller grafiska detaljer. Effekten bör användas där den förstärker helheten och behåller läsbarheten.' },
  { q: 'Kan ni hjälpa till med design?', a: 'Ja, sidan beskriver designhjälp och möjlighet att rekommendera grafiska designers. Det passar när du har logotyp och innehåll men behöver en färdig layout.' },
  { q: 'Finns det miljövänliga alternativ?', a: 'Ja, befintlig sida beskriver miljövänliga papper, tryckmetoder och visitkortsbox. Exakta materialval bör verifieras inför beställning.' },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Trycka visitkort med rätt papper och finish | Norrmalmstryckeriet"
  description="Tryck visitkort för företag, team, mässa och kundmöten. Vi hjälper dig välja papper, tryck, design, upplaga och specialeffekter."
>

  <!-- ═══ HERO (matchar startsidan: aspect-ratio 1.75/1, mx-[34px], gradient bottom) ═══ -->
  <section class="relative">
    <div class="mx-[34px] mt-[51px] rounded-[50px] overflow-hidden relative" style="aspect-ratio:1.75/1; max-height:85vh; min-height:600px; background:#000;">
      <img
        src="/images/hero/visitkort-hero.png"
        alt="Visitkort från Norrmalmstryckeriet"
        class="absolute inset-0 w-full h-full object-cover"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/40 to-black/20 pointer-events-none"></div>
      <div class="absolute bottom-[40px] left-[40px] right-[40px] md:bottom-[60px] md:left-[60px] md:right-[60px] z-10">
        <p class="!text-white/85 mb-[16px] uppercase font-medium" style="font-size:12px; letter-spacing:1.8px; line-height:1;">Tryckeri Stockholm • Sollentuna / Häggvik</p>
        <h1 class="typo-hero !text-white mb-[20px]" style="text-wrap: balance;">
          Lämna rätt intryck
        </h1>
        <p class="!text-white/90 max-w-[560px] text-[16px] md:text-[18px] leading-relaxed mb-[28px]">
          När du möter kund, partner eller kontaktperson behöver dina uppgifter vara enkla att ta med. Vi hjälper dig välja papper, tryck och finish efter hur visitkortet ska kännas och användas.
        </p>
        <div class="flex flex-wrap items-center gap-[12px]">
          <a href="/begar-offert" class="btn-pill btn-red">
            Offertförfrågan<Fragment set:html={arrowSvg} />
          </a>
          <a href="tel:+4686210090" class="btn-pill" style="background: white; color: #222;">
            Ring 08-96 01 35
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TRUST STRIP (under hero, separat) ═══ -->
  <section class="py-[40px] mx-[34px]">
    <div class="flex flex-wrap items-center justify-center gap-[40px] md:gap-[80px]">
      <div class="flex items-center gap-[14px]">
        <span class="font-[var(--font-heading)] text-[#222] leading-none" style="font-size: clamp(1.75rem, 2.5vw, 2.25rem);">100+ år</span>
        <span class="text-[#666] font-medium uppercase" style="font-size: 11px; letter-spacing: 1.65px;">År av erfarenhet</span>
      </div>
      <div class="flex items-center gap-[14px]">
        <span class="font-[var(--font-heading)] text-[#222] leading-none" style="font-size: clamp(1.75rem, 2.5vw, 2.25rem);">1000+</span>
        <span class="text-[#666] font-medium uppercase" style="font-size: 11px; letter-spacing: 1.65px;">Uppdrag årligen</span>
      </div>
      <div class="flex items-center gap-[14px]">
        <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[36px] h-[37px]" />
        <span class="text-[#222] font-medium uppercase" style="font-size: 11px; letter-spacing: 1.65px;">Svanenmärkt</span>
      </div>
    </div>
  </section>

  <!-- ═══ "VARFÖR VISITKORT?" — Quote + Infografik-nedladdning ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="mx-[44px]">
      <p class="text-[#222] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Varför visitkort?</p>
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(2rem, 5vw, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; hyphens: auto; text-wrap: balance;" lang="sv">
          Ett visitkort kan bara lämna kontaktuppgifter. <em>Eller göra mötet lättare att minnas.</em>
        </h2>
        <div class="md:pt-[20px]">
          <p class="text-[18px] leading-relaxed text-[#222] mb-[28px]">
            När papper, tryck och finish passar varumärket blir kortet en naturlig del av presentationen.
          </p>
          <ul class="space-y-[10px] mb-[40px]">
            {effects.map((eff) => (
              <li class="flex items-start gap-[10px] text-[16px] leading-relaxed text-[#222]">
                <span class="shrink-0 mt-[10px] w-[6px] h-[6px] rounded-full bg-[#222]"></span>
                <span>{eff}</span>
              </li>
            ))}
          </ul>

          <!-- Infografik-nedladdning med leadcapture -->
          <div class="bg-[#F5F5F5] rounded-[16px] p-[28px] md:p-[34px]">
            <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[8px]" style="font-size: 22px; line-height: 1.2;">
              Visitkort-guiden — gratis infografik
            </h3>
            <p class="text-[14px] leading-relaxed text-[#555] mb-[20px]">
              Få vår 1-sidiga PDF-guide med papperstips, tryckmetoder och finish-effekter. Skicka uppgifterna så skickar vi guiden direkt.
            </p>
            <form id="infografik-form" class="space-y-[10px]" action="/downloads/visitkort-infographic.pdf" method="get" target="_blank">
              <input type="text" name="name" placeholder="Ditt namn" required class="w-full px-[14px] py-[12px] rounded-[4px] bg-white border border-[#E5E5E5] focus:border-[#222] outline-none text-[15px] font-[var(--font-body)]" />
              <input type="email" name="email" placeholder="E-post" required class="w-full px-[14px] py-[12px] rounded-[4px] bg-white border border-[#E5E5E5] focus:border-[#222] outline-none text-[15px] font-[var(--font-body)]" />
              <input type="text" name="company" placeholder="Företag (valfritt)" class="w-full px-[14px] py-[12px] rounded-[4px] bg-white border border-[#E5E5E5] focus:border-[#222] outline-none text-[15px] font-[var(--font-body)]" />
              <button type="submit" class="btn-pill btn-dark w-full justify-center mt-[6px]">
                Ladda ner infografik (PDF)
              </button>
              <p class="text-[12px] text-[#777] mt-[10px] leading-relaxed">
                Vi använder uppgifterna för att skicka guiden och eventuella uppföljningar. Du kan avregistrera dig när som helst.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ "Vad vill du uppnå?" — sidoscroll-kort ═══ -->
  <section class="pt-[80px] pb-[100px]">
    <div class="ml-[44px] mb-[40px]">
      <p class="text-[#222] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">När du behöver visitkort</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em; hyphens: auto; text-wrap: balance; max-width: 1100px;" lang="sv">
        Det handlar inte om kontaktuppgifter. Det handlar om vad du lämnar efter dig.
      </h2>
      <p class="text-[#555] text-[16px] md:text-[18px] max-w-[800px] mb-[6px]">
        Ett visitkort kan vara enkelt, klassiskt eller mer exklusivt.
      </p>
      <p class="text-[#555] text-[16px] md:text-[18px] max-w-[800px]">
        Det viktiga är att det känns rätt för personen, rollen och varumärket. Berätta vad du vill uppnå – vi rekommenderar papper och finish.
      </p>
    </div>
    <div id="scenario-carousel" class="flex gap-[20px] overflow-x-auto scrollbar-hide pl-[44px] pr-[44px]">
      {scenarios.map((s) => (
        <article class="shrink-0 w-[380px] bg-[#F5F5F5] rounded-[16px] p-[43px] flex flex-col min-h-[482px]">
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px]" style="font-size: 26px; line-height: 30px; hyphens: auto; word-wrap: break-word;" lang="sv">{s.title}</h3>
          <p class="text-[15px] leading-relaxed text-[#444] mb-[24px]">{s.body}</p>
          <div class="mt-auto pt-[20px] border-t border-[#C8C8C8]">
            <p class="text-[14px] leading-relaxed text-[#222]">
              <strong class="font-bold">Vår rekommendation:</strong> {s.rec}
            </p>
          </div>
        </article>
      ))}
    </div>
    <div class="flex justify-end gap-[8px] mt-[24px] mr-[44px]">
      <button id="scenario-prev" class="w-[44px] h-[44px] rounded-full bg-[#F5F5F5] flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M15 18l-6-6 6-6"/></svg>
      </button>
      <button id="scenario-next" class="w-[44px] h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18l6-6-6-6"/></svg>
      </button>
    </div>
  </section>

  <!-- ═══ HUR VI JOBBAR ═══ -->
  <section class="py-[100px] md:py-[140px]">
    <div class="max-w-[1140px] mx-auto px-[44px] text-center">
      <p class="text-[#222] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Hur vi jobbar</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[80px] md:mb-[100px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
        Tre steg till rätt visitkort.
      </h2>
      <div class="grid md:grid-cols-3 gap-[40px] md:gap-[60px]">
        <div>
          <span class="typo-process-number block">1.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Du berättar</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Du beskriver antal, personer, användning, varumärke och om originalet finns klart.</p>
        </div>
        <div>
          <span class="typo-process-number block">2.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Vi rekommenderar</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Vi föreslår papper, tryckmetod, finish, specialeffekter och eventuell hjälp med design.</p>
        </div>
        <div>
          <span class="typo-process-number block">3.</span>
          <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[16px]" style="font-size: 26px; line-height: 1.2;">Du godkänner</h3>
          <p class="text-[15px] leading-relaxed text-[#555]">Du får ett tydligt förslag och godkänner innan visitkorten går till tryck.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VARFÖR INTE WEBBSHOP — 2-kol med expert-tips ═══ -->
  <section class="bg-[#F3F3F3]">
    <div class="px-[44px] py-[100px] md:py-[140px]">
      <div class="grid md:grid-cols-2 gap-[40px] md:gap-[80px]">
        <div>
          <p class="text-[#888] mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Varför vi inte har en webbshop</p>
          <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[40px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em; hyphens: auto; text-wrap: balance;" lang="sv">
            Visitkort är små, men detaljerna syns direkt.
          </h2>
          <div class="space-y-[20px] text-[16px] leading-relaxed text-[#444]">
            <p>Visitkort är små, men detaljerna märks direkt i handen. Papper, färg, marginaler, finish och läsbarhet påverkar hur kortet uppfattas.</p>
            <p>Hos webbtryckerier väljer du ur en meny. Hos oss får du rådgivning som matchar varumärket — och en lösning som faktiskt fungerar.</p>
            <p class="text-[#222] font-medium">Resultatet? Ett visitkort som speglar varumärket — inte bara ett som kostade minst.</p>
          </div>
        </div>
        <div class="space-y-[32px] md:pt-[60px]">
          <div>
            <h3 class="font-[var(--font-body)] font-bold text-[16px] md:text-[17px] text-[#222] mb-[8px]">Detaljerna märks direkt</h3>
            <p class="text-[15px] leading-relaxed text-[#555]">Pappersval, marginaler, typografi och färg avgör hur kortet känns. Vi hjälper dig välja kombinationen som passar rollen och varumärket.</p>
          </div>
          <div>
            <h3 class="font-[var(--font-body)] font-bold text-[16px] md:text-[17px] text-[#222] mb-[8px]">Specialeffekter behöver omsorg</h3>
            <p class="text-[15px] leading-relaxed text-[#555]">Folieprägling, UV-lack och prägling kan lyfta kortet — men måste sitta rätt för att inte störa läsbarheten. Vi vägleder placering och omfattning.</p>
          </div>
          <div>
            <h3 class="font-[var(--font-body)] font-bold text-[16px] md:text-[17px] text-[#222] mb-[8px]">Versionering och team-hantering</h3>
            <p class="text-[15px] leading-relaxed text-[#555]">När flera personer ska ha samma kort med olika kontaktuppgifter behöver original, mall och versioner hanteras konsekvent. Vi sköter logistiken.</p>
          </div>
          <div class="pt-[12px]">
            <a href="/kontakta-oss" class="inline-flex items-center text-[#222] font-medium hover:underline">
              Hjälp? Kontakta oss<Fragment set:html={arrowSvg} />
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR EXPERTIS (mörk RUNDAD) ═══ -->
  <section class="py-[40px]">
    <div class="mx-[44px] rounded-[50px] bg-[#222]">
      <div class="px-[44px] md:px-[60px] py-[100px] md:py-[110px]">
        <p class="!text-white/60 mb-[24px] uppercase font-medium" style="font-size: 12px; letter-spacing: 1.8px;">Vår expertis</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[20px]" style="font-size: clamp(2rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.03em;">
          Papper, tryck och finish – vi kan det.
        </h2>
        <p class="!text-white/70 text-[16px] md:text-[18px] mb-[60px] md:mb-[80px] max-w-[720px]">
          Ett visitkort är litet, men detaljerna syns direkt. Papper, tryck och finish avgör vad du lämnar efter dig.
        </p>
        <div class="grid md:grid-cols-3 gap-[24px]">
          {expertise.map((e) => (
            <div class="bg-[#313131] rounded-[25px] p-[39px]">
              <h3 class="font-[var(--font-heading)] !font-normal !text-white mb-[20px]" style="font-size: 32px; line-height: 40px;">{e.title}</h3>
              <p class="!text-white/70 text-[15px] leading-relaxed mb-[24px]">{e.intro}</p>
              <div class="space-y-[14px]">
                {e.items.map(([term, desc]) => (
                  <p class="text-[14px] leading-relaxed !text-white/80">
                    <strong class="!text-white font-bold">{term}</strong> – {desc}
                  </p>
                ))}
              </div>
