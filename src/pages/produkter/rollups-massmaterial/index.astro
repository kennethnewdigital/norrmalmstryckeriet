<script>
  function initRollups() {
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const plusIcon = btn.querySelector('.faq-plus') as HTMLElement;
        const minusIcon = btn.querySelector('.faq-minus') as HTMLElement;
        if (!answer) return;
        const isOpen = answer.classList.contains('open');
        if (isOpen) {
          answer.classList.remove('open');
          answer.style.maxHeight = '0';
          plusIcon?.classList.remove('hidden');
          minusIcon?.classList.add('hidden');
        } else {
          answer.classList.add('open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          plusIcon?.classList.add('hidden');
          minusIcon?.classList.remove('hidden');
        }
      });
    });

    document.querySelectorAll('.faq-answer').forEach((a) => {
      (a as HTMLElement).style.maxHeight = '0';
      (a as HTMLElement).style.overflow = 'hidden';
      (a as HTMLElement).style.transition = 'max-height 0.25s ease';
    });

    const scenarioC = document.getElementById('scenario-carousel');
    const sw = window.matchMedia('(min-width: 768px)').matches ? 400 : (window.matchMedia('(min-width: 640px)').matches ? 340 : 296);
    document.getElementById('scenario-prev')?.addEventListener('click', () => { scenarioC?.scrollBy({ left: -sw, behavior: 'smooth' }); });
    document.getElementById('scenario-next')?.addEventListener('click', () => { scenarioC?.scrollBy({ left: sw, behavior: 'smooth' }); });
  }

  initRollups();
  document.addEventListener('astro:after-swap', initRollups);
</script>
