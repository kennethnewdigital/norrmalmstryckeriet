<script>
  function initHomepage() {
    // === FAQ Tabs ===
    const tabBtns = document.querySelectorAll('.faq-tab-btn');
    const panels = document.querySelectorAll('.faq-panel');

    tabBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        const idx = btn.getAttribute('data-tab-index');

        tabBtns.forEach((b) => {
          b.classList.remove('bg-[#222]', 'text-white');
          b.classList.add('bg-white', 'text-[#222]');
        });
        btn.classList.remove('bg-white', 'text-[#222]');
        btn.classList.add('bg-[#222]', 'text-white');

        panels.forEach((p) => p.classList.add('hidden'));
        const target = document.querySelector(`[data-panel-index="${idx}"]`);
        if (target) target.classList.remove('hidden');

        document.querySelectorAll('.faq-answer').forEach((a) => {
          (a as HTMLElement).style.maxHeight = '0';
          a.classList.remove('is-open');
        });
        document.querySelectorAll('.faq-plus').forEach((p) => p.classList.remove('hidden'));
        document.querySelectorAll('.faq-minus').forEach((m) => m.classList.add('hidden'));
      });
    });

    // === FAQ Accordion ===
    document.querySelectorAll('.faq-toggle').forEach((btn) => {
      btn.addEventListener('click', () => {
        const answer = btn.nextElementSibling as HTMLElement;
        const plusIcon = btn.querySelector('.faq-plus') as HTMLElement;
        const minusIcon = btn.querySelector('.faq-minus') as HTMLElement;
        const isOpen = answer.classList.contains('is-open');

        const panel = btn.closest('.faq-panel');
        if (panel) {
          panel.querySelectorAll('.faq-answer').forEach((a) => {
            (a as HTMLElement).style.maxHeight = '0';
            a.classList.remove('is-open');
          });
          panel.querySelectorAll('.faq-plus').forEach((p) => p.classList.remove('hidden'));
          panel.querySelectorAll('.faq-minus').forEach((m) => m.classList.add('hidden'));
        }

        if (!isOpen) {
          answer.classList.add('is-open');
          answer.style.maxHeight = answer.scrollHeight + 'px';
          plusIcon.classList.add('hidden');
          minusIcon.classList.remove('hidden');
        }
      });
    });

    // === Product Carousel ===
    const carousel = document.getElementById('product-carousel');
    document.getElementById('carousel-prev')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: -400, behavior: 'smooth' });
    });
    document.getElementById('carousel-next')?.addEventListener('click', () => {
      carousel?.scrollBy({ left: 400, behavior: 'smooth' });
    });

    // === Reference Carousel ===
    const refCarousel = document.getElementById('ref-carousel');
    document.getElementById('ref-prev')?.addEventListener('click', () => {
      refCarousel?.scrollBy({ left: -480, behavior: 'smooth' });
    });
    document.getElementById('ref-next')?.addEventListener('click', () => {
      refCarousel?.scrollBy({ left: 480, behavior: 'smooth' });
    });
  }

  initHomepage();
  document.addEventListener('astro:after-swap', initHomepage);
</script>
