const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Offertförfrågan – tryck blad, broschyrer, böcker och mer | Norrmalmstryckeriet"
  description="Fyll i formuläret eller ring 08-96 01 35. Vi hjälper dig välja format, papper, tryckmetod och finish – och återkommer med en tydlig offert."
>

  <!-- ═══ HERO ═══ -->
  <section class="page-section">
    <div class="page-container">
      <p class="section-label">Offertförfrågan</p>
      <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[28px] max-w-[920px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.05; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
        Berätta vad du vill trycka. Vi gör resten.
      </h1>
      <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[760px]" style="text-wrap: pretty;">
        Fyll i formuläret eller ring oss direkt på <a href="tel:+4686960135" class="text-[#222] underline hover:no-underline font-medium">08-96 01 35</a> — vi gillar att prata med våra kunder. Bifoga gärna PDF, EPS eller bilder så återkommer vi med ett tydligt förslag.
      </p>
    </div>
  </section>

  <!-- ═══ FORMULÄR ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container">
      <div class="grid md:grid-cols-[1fr_1.3fr] gap-[40px] md:gap-[60px] lg:gap-[80px] items-start">

        <!-- Vänster: Kontaktinfo -->
        <div>
          <p class="section-label">Kontakt</p>
          <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[20px] sm:mb-[24px]" style="font-size: clamp(1.5rem, 3vw, 2.5rem); line-height: 1.15; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
            Hör av dig – vi svarar snabbt.
          </h2>
          <div class="space-y-[12px] sm:space-y-[16px] text-[15px] sm:text-[16px] text-[#222] mb-[24px] sm:mb-[32px]">
            <p><strong class="font-bold">Telefon:</strong> <a href="tel:+4686960135" class="text-[#D9222A] hover:underline">08-96 01 35</a></p>
            <p><strong class="font-bold">E-post:</strong> <a href="mailto:tryckeri@norrmalmstryckeriet.se" class="text-[#D9222A] hover:underline break-all">tryckeri@norrmalmstryckeriet.se</a></p>
            <p><strong class="font-bold">Besök:</strong> Hammarbacken 4A, Häggvik (15 min från city)</p>
            <p><strong class="font-bold">Postadress:</strong> Box 416, 191 24 Sollentuna</p>
            <p class="text-[#666] text-[14px]">Org nr: 556088-1681</p>
          </div>
          <div class="rounded-[16px] bg-white p-[24px] sm:p-[28px] border border-[#E5E5E5]">
            <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#444]">
              <strong class="font-bold text-[#222]">Bifogade filer:</strong> Acceptade format är PDF, EPS, JPG, PNG, SVG och GIF (max 20 MB per fil). Större filer? Hör av dig så ordnar vi WeTransfer eller FTP.
            </p>
          </div>
        </div>

        <!-- Höger: Form -->
        <div class="w-full">
          <form
            id="offert-form"
            class="space-y-[14px] sm:space-y-[16px] bg-white rounded-[16px] p-[24px] sm:p-[32px] md:p-[40px] border border-[#E5E5E5]"
            action="#"
            method="post"
            enctype="multipart/form-data"
          >
            <!-- Företag eller Privatperson -->
            <fieldset class="space-y-[10px]">
              <legend class="block text-[14px] font-medium text-[#222] mb-[6px]">Jag är <span class="text-[#D9222A]">*</span></legend>
              <div class="flex flex-wrap gap-[16px] sm:gap-[24px]">
                <label class="inline-flex items-center gap-[8px] cursor-pointer">
                  <input type="radio" name="type" value="foretag" required class="w-[16px] h-[16px] accent-[#D9222A]" checked />
                  <span class="text-[14px] sm:text-[15px] text-[#222]">Företag</span>
                </label>
                <label class="inline-flex items-center gap-[8px] cursor-pointer">
                  <input type="radio" name="type" value="privat" class="w-[16px] h-[16px] accent-[#D9222A]" />
                  <span class="text-[14px] sm:text-[15px] text-[#222]">Privatperson</span>
                </label>
              </div>
            </fieldset>

            <div>
              <label for="company" class="block text-[14px] font-medium text-[#222] mb-[6px]">Företag <span class="text-[#888] font-normal">(om aktuellt)</span></label>
              <input type="text" id="company" name="company" placeholder="Företagsnamn" class="form-input" />
            </div>

            <div class="grid sm:grid-cols-2 gap-[14px] sm:gap-[16px]">
              <div>
                <label for="firstname" class="block text-[14px] font-medium text-[#222] mb-[6px]">Förnamn <span class="text-[#D9222A]">*</span></label>
                <input type="text" id="firstname" name="firstname" placeholder="Förnamn" required class="form-input" />
              </div>
              <div>
                <label for="lastname" class="block text-[14px] font-medium text-[#222] mb-[6px]">Efternamn <span class="text-[#D9222A]">*</span></label>
                <input type="text" id="lastname" name="lastname" placeholder="Efternamn" required class="form-input" />
              </div>
            </div>

            <div class="grid sm:grid-cols-2 gap-[14px] sm:gap-[16px]">
              <div>
                <label for="email" class="block text-[14px] font-medium text-[#222] mb-[6px]">E-post <span class="text-[#D9222A]">*</span></label>
                <input type="email" id="email" name="email" placeholder="namn@foretag.se" required class="form-input" />
              </div>
              <div>
                <label for="phone" class="block text-[14px] font-medium text-[#222] mb-[6px]">Telefon</label>
                <input type="tel" id="phone" name="phone" placeholder="070-123 45 67" class="form-input" />
              </div>
            </div>

            <div>
              <label for="product" class="block text-[14px] font-medium text-[#222] mb-[6px]">Vad vill du trycka? <span class="text-[#888] font-normal">(välj eller skriv fritt nedan)</span></label>
              <select id="product" name="product" class="form-input">
                <option value="">Välj produkt…</option>
                <option value="blad">Blad / reklamblad / flyers</option>
                <option value="foldrar">Foldrar</option>
                <option value="broschyrer">Broschyrer</option>
                <option value="mappar">Mappar</option>
                <option value="affischer">Affischer</option>
                <option value="kuvert">Kuvert</option>
                <option value="bocker">Böcker</option>
                <option value="storformat">Storformat</option>
                <option value="visitkort">Visitkort</option>
                <option value="annat">Annat</option>
              </select>
            </div>

            <div>
              <label for="message" class="block text-[14px] font-medium text-[#222] mb-[6px]">Beskriv ditt projekt <span class="text-[#D9222A]">*</span></label>
              <textarea id="message" name="message" rows="6" required placeholder="Beskriv format, sidantal, upplaga, papper, leveranstid och annat som påverkar offerten…" class="form-input resize-none"></textarea>
            </div>

            <div>
              <label for="files" class="block text-[14px] font-medium text-[#222] mb-[6px]">Bifoga filer <span class="text-[#888] font-normal">(PDF, EPS, JPG, PNG, SVG, GIF — max 20 MB per fil)</span></label>
              <input type="file" id="files" name="files" multiple accept=".pdf,.eps,.jpg,.jpeg,.png,.svg,.gif" class="form-input !p-[10px] file:mr-3 file:px-[14px] file:py-[8px] file:rounded-[6px] file:border-0 file:bg-[#F3F3F3] file:text-[#222] file:cursor-pointer file:font-medium hover:file:bg-[#E5E5E5]" />
            </div>

            <div class="flex items-start gap-[10px] mt-[8px]">
              <input type="checkbox" id="gdpr" name="gdpr" required class="mt-[5px] w-[16px] h-[16px] cursor-pointer accent-[#D9222A]" />
              <label for="gdpr" class="text-[13px] sm:text-[14px] leading-relaxed text-[#555] cursor-pointer">
                Jag godkänner att Norrmalmstryckeriet behandlar mina uppgifter enligt <a href="/integritetspolicy" class="underline hover:text-[#222]">integritetspolicyn</a>. <span class="text-[#D9222A]">*</span>
              </label>
            </div>

            <button type="submit" class="btn-pill btn-red w-full justify-center mt-[12px] sm:mt-[16px]">
              Skicka offertförfrågan<Fragment set:html={arrowSvg} />
            </button>
          </form>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══ KONTAKTPERSONER ═══ -->
  <section class="page-section">
    <div class="page-container">
      <p class="section-label">Kontaktpersoner</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[40px] sm:mb-[56px] md:mb-[72px] max-w-[920px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
        Människorna bakom tryckpressen.
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-5 gap-[20px] sm:gap-[24px] md:gap-[28px]">
        {team.map((person) => (
          <article class="bg-[#F5F5F5] rounded-[20px] overflow-hidden flex flex-col">
            <div class="aspect-[4/5] bg-[#E5E5E5] overflow-hidden">
              <img
                src={person.image}
                alt={person.name}
                loading="lazy"
                decoding="async"
                class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700 ease-out"
              />
            </div>
            <div class="p-[20px] sm:p-[24px] flex flex-col gap-[8px]">
              <h3 class="font-[var(--font-heading)] !font-normal text-[#222] text-[18px] sm:text-[20px] leading-[1.2]">{person.name}</h3>
              <p class="text-[13px] sm:text-[14px] text-[#666] uppercase font-medium" style="letter-spacing: 1.2px;">{person.role}</p>
              <div class="flex flex-col gap-[4px] mt-[8px]">
                {person.phones.map((p) => (
                  <a href={`tel:${p.tel}`} class="text-[14px] sm:text-[15px] text-[#222] hover:text-[#D9222A] transition-colors">
                    {p.label}
                  </a>
                ))}
                <a href={`mailto:${person.email}`} class="text-[13px] sm:text-[14px] text-[#D9222A] hover:underline break-all mt-[2px]">
                  {person.email}
                </a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ VAD VILL DU TRYCKA? — bento på lg+, sidoscroll <lg ═══ -->
  <section class="pt-[40px] pb-[80px] lg:pt-[60px] lg:pb-[120px] bg-[#F3F3F3]">
    <div class="lg:max-w-[1440px] lg:mx-auto lg:px-[44px] pt-[40px] sm:pt-[56px] md:pt-[72px]">
      <p class="section-label ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-0">Produkter</p>
      <h3 class="typo-carousel-heading ml-[16px] sm:ml-[24px] md:ml-[32px] lg:ml-0 mb-[20px] sm:mb-[28px]">Vad skall du trycka?</h3>
    </div>

    <!-- MOBILE/TABLET: sidoscroll-kort -->
    <div class="lg:hidden">
      <div id="product-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] pr-[16px] sm:pr-[24px] md:pr-[32px]">
        {[
          { label: 'Blad,\nreklamblad,\nflyers', icon: 'blad-1.svg', slug: 'blad' },
          { label: 'Visitkort', icon: 'blad-1.svg', slug: 'visitkort' },
          { label: 'Foldrar', icon: 'foldrar.svg', slug: 'foldrar' },
          { label: 'Broschyrer', icon: 'broschyrer-1.svg', slug: 'broschyrer' },
          { label: 'Mappar', icon: 'mappar-1.svg', slug: 'mappar' },
          { label: 'Affischer', icon: 'affischer-1.svg', slug: 'affischer' },
          { label: 'Kuvert', icon: 'kuvert-1.svg', slug: 'kuvert' },
          { label: 'Böcker', icon: 'bocker-1.svg', slug: 'bocker' },
          { label: 'Storformat', icon: 'storformat-1.svg', slug: 'storformat' },
        ].map((product) => (
          <a href={`/produkter/${product.slug}`} class="shrink-0 w-[260px] sm:w-[320px] md:w-[380px] min-h-[340px] sm:min-h-[395px] bg-white rounded-[16px] p-[24px] sm:p-[34px] flex flex-col items-center text-center group hover:bg-[#FAFAFA] transition-colors duration-200 no-underline relative">
            <img src={`/images/icons/${product.icon}`} alt={product.label} class="w-[72px] h-[72px] sm:w-[90px] sm:h-[90px] mb-[16px] sm:mb-[20px]" />
            <span class="typo-card-title whitespace-pre-line">{product.label}</span>
            <span class="mt-auto self-end text-[#222]">
              <svg width="36" height="36" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
            </span>
          </a>
        ))}
      </div>
      <div class="flex justify-end gap-2 mt-4 mr-[16px] sm:mr-[24px] md:mr-[32px]">
        <button id="carousel-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-white flex items-center justify-center text-gray-300 hover:text-[#222] transition-colors cursor-pointer" aria-label="Föregående">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
        </button>
        <button id="carousel-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-white flex items-center justify-center text-[#222] hover:bg-[#F5F5F5] transition-colors cursor-pointer" aria-label="Nästa">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
        </button>
      </div>
    </div>

    <!-- DESKTOP: Bento-grid -->
    <div class="hidden lg:block max-w-[1440px] mx-auto px-[44px]">
      <div class="grid grid-cols-3 grid-rows-4 gap-[16px] auto-rows-[220px]">
        {/* Card 1: BIG — Blad */}
        <a href="/produkter/blad" class="col-span-2 row-span-2 bg-white rounded-[20px] p-[40px] flex flex-col group hover:bg-[#FAFAFA] transition-colors duration-200 no-underline relative">
          <img src="/images/icons/blad-1.svg" alt="Blad, reklamblad, flyers" class="w-[120px] h-[120px] mb-[20px]" />
          <span class="typo-card-title whitespace-pre-line">Blad,
reklamblad,
flyers</span>
          <span class="mt-auto self-end text-[#222]">
            <svg width="44" height="44" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
          </span>
        </a>

        {/* Card 2: Foldrar */}
        <a href="/produkter/foldrar" class="bg-white rounded-[20px] p-[28px] flex flex-col group hover:bg-[#FAFAFA] transition-colors duration-200 no-underline relative">
          <img src="/images/icons/foldrar.svg" alt="Foldrar" class="w-[64px] h-[64px] mb-[12px]" />
          <span class="typo-card-title">Foldrar</span>
          <span class="mt-auto self-end text-[#222]">
            <svg width="32" height="32" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
          </span>
        </a>

        {/* Card 3: Broschyrer */}
        <a href="/produkter/broschyrer" class="bg-white rounded-[20px] p-[28px] flex flex-col group hover:bg-[#FAFAFA] transition-colors duration-200 no-underline relative">
          <img src="/images/icons/broschyrer-1.svg" alt="Broschyrer" class="w-[64px] h-[64px] mb-[12px]" />
          <span class="typo-card-title">Broschyrer</span>
          <span class="mt-auto self-end text-[#222]">
            <svg width="32" height="32" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
          </span>
        </a>

        {/* Card 4: Mappar */}
        <a href="/produkter/mappar" class="bg-white rounded-[20px] p-[28px] flex flex-col group hover:bg-[#FAFAFA] transition-colors duration-200 no-underline relative">
          <img src="/images/icons/mappar-1.svg" alt="Mappar" class="w-[64px] h-[64px] mb-[12px]" />
          <span class="typo-card-title">Mappar</span>
          <span class="mt-auto self-end text-[#222]">
            <svg width="32" height="32" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
          </span>
        </a>

        {/* Card 5: Affischer */}
        <a href="/produkter/affischer" class="bg-white rounded-[20px] p-[28px] flex flex-col group hover:bg-[#FAFAFA] transition-colors duration-200 no-underline relative">
          <img src="/images/icons/affischer-1.svg" alt="Affischer" class="w-[64px] h-[64px] mb-[12px]" />
          <span class="typo-card-title">Affischer</span>
          <span class="mt-auto self-end text-[#222]">
            <svg width="32" height="32" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
          </span>
        </a>

        {/* Card 6: Kuvert */}
        <a href="/produkter/kuvert" class="bg-white rounded-[20px] p-[28px] flex flex-col group hover:bg-[#FAFAFA] transition-colors duration-200 no-underline relative">
          <img src="/images/icons/kuvert-1.svg" alt="Kuvert" class="w-[64px] h-[64px] mb-[12px]" />
          <span class="typo-card-title">Kuvert</span>
          <span class="mt-auto self-end text-[#222]">
            <svg width="32" height="32" viewBox="0 0 512 512" fill="currentColor"><path d="M256 8C119 8 8 119 8 256s111 248 248 248 248-111 248-248S393 8 256 8zm144 276c0 6.6-5.4 12-12 12h-92v92c0 6.6-5.4 12-12 12h-56c-6.6 0-12-5.4-12-12v-92h-92c-6.6 0-12-5.4-12-12v-56c0-6.6 5.4-12 12-12h92v-92c0-6.6 5.4-12 12-12h56c6.6 0 12 5.4 12 12v92h92c6.6 0 12 5.4 12 12v56z"/></svg>
          </span>
        </a>

        {/* Card 7: WIDE — Böcker */}
