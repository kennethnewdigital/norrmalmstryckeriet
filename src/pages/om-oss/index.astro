<style>
  .page-container {
    width: 100%;
    max-width: 1440px;
    margin-left: auto;
    margin-right: auto;
  }
  .page-section {
    padding-top: 64px;
    padding-bottom: 64px;
    padding-left: 16px;
    padding-right: 16px;
  }
  @media (min-width: 640px) {
    .page-section { padding-top: 80px; padding-bottom: 80px; padding-left: 24px; padding-right: 24px; }
  }
  @media (min-width: 768px) {
    .page-section { padding-top: 100px; padding-bottom: 100px; }
  }
  @media (min-width: 1024px) {
    .page-section { padding-top: 140px; padding-bottom: 140px; padding-left: 44px; padding-right: 44px; }
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 11px;
    line-height: 1;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    font-weight: 500;
    color: #888;
    margin-bottom: 20px;
  }
  @media (min-width: 768px) {
    .section-label { font-size: 12px; letter-spacing: 1.8px; margin-bottom: 24px; }
  }

  .page-section-no-px {
    padding-top: 48px;
    padding-bottom: 48px;
  }
  @media (min-width: 640px) {
    .page-section-no-px { padding-top: 56px; padding-bottom: 56px; }
  }
  @media (min-width: 768px) {
    .page-section-no-px { padding-top: 72px; padding-bottom: 72px; }
  }
  @media (min-width: 1024px) {
    .page-section-no-px { padding-top: 88px; padding-bottom: 88px; }
  }
</style>

<script>
  function initOmOss() {
    const teamCarousel = document.getElementById('team-carousel');
    const teamWidth = window.matchMedia('(min-width: 1024px)').matches ? 236 : (window.matchMedia('(min-width: 768px)').matches ? 220 : (window.matchMedia('(min-width: 640px)').matches ? 200 : 176));
    document.getElementById('team-prev')?.addEventListener('click', () => {
      teamCarousel?.scrollBy({ left: -teamWidth, behavior: 'smooth' });
    });
    document.getElementById('team-next')?.addEventListener('click', () => {
      teamCarousel?.scrollBy({ left: teamWidth, behavior: 'smooth' });
    });
  }
  initOmOss();
  document.addEventListener('astro:after-swap', initOmOss);
</script>
