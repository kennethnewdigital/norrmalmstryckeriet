---
import Layout from '../../layouts/Layout.astro';

const services = [
  { title: 'Offsettryck', body: 'För större upplagor och jämn färgåtergivning.' },
  { title: 'Digitaltryck', body: 'Snabbt och flexibelt för mindre serier och versioner.' },
  { title: 'Storformat', body: 'Roll-ups, skyltar och mässmaterial som syns.' },
  { title: 'Original / prepress', body: 'Vi förbereder filen så den blir rätt i tryck.' },
  { title: 'Efterbehandling', body: 'Falsning, bindning, stansning, prägling och foliering.' },
  { title: 'Distribution', body: 'Från lager till mottagare, samordnat och tryggt.' },
];

const purposes = [
  'Skapa förtroende',
  'Informera tydligt',
  'Stärka ett varumärke',
  'Underlätta ett beslut',
  'Samla medlemmar',
  'Presentera ett erbjudande',
  'Göra ett möte mer professionellt',
];

const team = [
  {
    name: 'Mats Jansson', role: 'VD / Försäljning',
    phones: [{ label: '08-510 604 20', tel: '+4685106 0420' }, { label: '0708-29 12 05', tel: '+46708291205' }],
    email: 'mats@norrmalmstryckeriet.se',
    image: '/images/team/mats-jansson.webp',
  },
  {
    name: 'Bengt Lindau', role: 'Sälj / Projektledare',
    phones: [{ label: '08-510 604 22', tel: '+46851060422' }, { label: '0708-29 67 95', tel: '+46708296795' }],
    email: 'bengt@norrmalmstryckeriet.se',
    image: '/images/team/bengt-lindau.webp',
  },
  {
    name: 'Jens Johansson', role: 'Sälj / Projektledare',
    phones: [{ label: '070-527 78 80', tel: '+46705277880' }],
    email: 'jens.johansson@sandvikenstryckeri.se',
    image: '/images/team/jens-johansson.webp',
  },
  {
    name: 'Stefan Johansson', role: 'Prepress / Projektledare',
    phones: [{ label: '070-777 98 63', tel: '+46707779863' }],
    email: 'stefan@norrmalmstryckeriet.se',
    image: '/images/team/stefan-johansson.webp',
  },
  {
    name: 'Peter Näslund', role: 'Prepress / Projektledare',
    phones: [{ label: '070-774 78 53', tel: '+46707747853' }],
    email: 'peter@norrmalmstryckeriet.se',
    image: '/images/team/peter-naslund.webp',
  },
];

const arrowSvg = `<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>`;
---

<Layout
  title="Om oss – Svanenmärkt tryckeri i Sollentuna sedan 1800-talet | Norrmalmstryckeriet"
  description="Norrmalmstryckeriet är ett Svanenmärkt tryckeri i Sollentuna med anor tillbaka till slutet av 1800-talet. Vi hjälper företag, organisationer och byråer att ta fram trycksaker med rätt känsla, funktion och kvalitet."
>

  <!-- ═══ HERO ═══ -->
  <section class="page-section">
    <div class="page-container">
      <div class="grid lg:grid-cols-[1fr_0.85fr] gap-[32px] md:gap-[48px] lg:gap-[64px] items-center">
        <!-- Vänster: Text -->
        <div>
          <p class="section-label">Om oss</p>
          <h1 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[24px] sm:mb-[32px] max-w-[720px]" style="font-size: clamp(2rem, 4vw + 0.5rem, 4.25rem); line-height: 1.03; letter-spacing: -0.035em; text-wrap: balance;" lang="sv">
            Trycksaker med kunskap, känsla och ansvar.
          </h1>
          <p class="text-[16px] sm:text-[18px] md:text-[20px] leading-relaxed text-[#444] max-w-[620px]" style="text-wrap: pretty;">
            Norrmalmstryckeriet är ett Svanenmärkt tryckeri i Sollentuna med anor tillbaka till slutet av 1800-talet. Vi hjälper företag, organisationer och byråer att ta fram trycksaker med rätt känsla, rätt funktion och rätt kvalitet — från original och materialval till tryck, efterbehandling och leverans.
          </p>
        </div>

        <!-- Höger: Bild -->
        <div class="rounded-[24px] sm:rounded-[32px] lg:rounded-[40px] overflow-hidden aspect-[4/3] lg:aspect-[4/5] bg-[#E5E5E5]">
          <img
            src="/images/hero/om-oss-hero.webp"
            alt="Personalen på Norrmalmstryckeriet"
            class="w-full h-full object-cover"
            loading="eager"
            decoding="async"
          />
        </div>
      </div>

      <!-- Stats / trust -->
      <div class="flex flex-wrap items-end gap-x-[40px] sm:gap-x-[60px] lg:gap-x-[80px] gap-y-[20px] mt-[40px] sm:mt-[56px] pt-[28px] sm:pt-[36px] border-t border-[#E5E5E5]">
        <div class="flex flex-col items-start">
          <span class="font-[var(--font-heading)] text-[#222] leading-none text-[28px] sm:text-[36px]">100+ år</span>
          <span class="text-[#666] mt-[8px] font-medium uppercase text-[10px] sm:text-[11px]" style="letter-spacing: 1.5px;">År av erfarenhet</span>
        </div>
        <div class="flex flex-col items-start">
          <span class="font-[var(--font-heading)] text-[#222] leading-none text-[28px] sm:text-[36px]">1000+</span>
          <span class="text-[#666] mt-[8px] font-medium uppercase text-[10px] sm:text-[11px]" style="letter-spacing: 1.5px;">Uppdrag årligen</span>
        </div>
        <div class="flex items-center gap-[14px]">
          <img src="/images/certifications/svanen-market.svg" alt="Svanenmärkt" class="w-[40px] h-[41px] sm:w-[44px] sm:h-[45px]" />
          <span class="text-[#222] font-medium uppercase text-[10px] sm:text-[11px]" style="letter-spacing: 1.5px;">Svanenmärkt</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ EMOTIONAL QUOTE ═══ -->
  <section class="bg-[#F3F3F3]">
    <div class="page-section">
      <div class="max-w-[1140px] mx-auto px-[0]">
        <p class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.5rem, 3.5vw, 3rem); line-height: 1.2; letter-spacing: -0.02em; text-wrap: balance;" lang="sv">
          Tryck handlar om mer än papper och färg. Det handlar om <em>känslan när mottagaren håller materialet i handen</em>, om förtroendet det skapar och om hur väl det representerar avsändaren.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ VÅR HISTORIA ═══ -->
  <section class="page-section">
    <div class="page-container">
      <p class="section-label">Vår historia</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[100px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 4.5vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
          En grafisk hantverkstradition där varje detalj räknades.
        </h2>
        <div class="md:pt-[12px] space-y-[20px] sm:space-y-[24px] text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#444]" style="text-wrap: pretty;">
          <p>
            Vår historia börjar i en grafisk hantverkstradition där varje detalj räknades. Papper, färg, format, sättning, repro, tryck och efterbehandling krävde erfarenhet i varje led. Den kunskapen bär vi med oss i dagens produktion.
          </p>
          <p>
            I dag arbetar vi med offsettryck, digitaltryck, storformat, originalhantering, prepress, efterbehandling och distribution. Tekniken har utvecklats. Uppdraget är detsamma: att hjälpa våra kunder ta fram trycksaker som fungerar i verkligheten.
          </p>
          <p class="text-[#222] font-medium">
            En bra trycksak ska kännas rätt. Den ska vara genomtänkt, välproducerad och anpassad efter sitt syfte.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ VAD VI GÖR ═══ -->
  <section class="page-section bg-[#F3F3F3]">
    <div class="page-container">
      <p class="section-label">Vad vi gör</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[100px] items-start mb-[48px] sm:mb-[64px] md:mb-[80px]">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 4.5vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
          Allt under samma tak.
        </h2>
        <div class="md:pt-[12px] text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#444]" style="text-wrap: pretty;">
          <p>
            Hos oss produceras allt från visitkort, foldrar och blad till årsredovisningar, böcker, utskick, medlemsmaterial, roll-ups, skyltar och mässmaterial. Original, prepress, tryck och efterbehandling arbetar nära varandra — det gör det enklare att hålla ihop detaljerna och skapa ett resultat som känns genomarbetat från början till slut.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px]">
        {services.map((s) => (
          <div class="bg-white rounded-[16px] p-[24px] sm:p-[28px] lg:p-[32px]">
            <h3 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[10px] sm:mb-[12px]" style="font-size: clamp(1.125rem, 1.5vw + 0.5rem, 1.5rem); line-height: 1.2;">{s.title}</h3>
            <p class="text-[14px] sm:text-[15px] leading-relaxed text-[#555]">{s.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ═══ RÅDGIVNING ═══ -->
  <section class="page-section">
    <div class="page-container">
      <p class="section-label">Rådgivning</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[100px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 4.5vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
          Erfarenhet och produktion. Tillsammans.
        </h2>
        <div class="md:pt-[12px] space-y-[20px] sm:space-y-[24px] text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#444]" style="text-wrap: pretty;">
          <p>
            Vi hjälper företag, organisationer, föreningar och byråer att välja rätt väg från idé till färdig trycksak. Ibland handlar det om papper och färgåtergivning. Ibland om format, upplaga, falsning, bindning, stansning, prägling eller distribution. Ibland om att hitta den tryckmetod som passar bäst för uppdraget.
          </p>
          <p class="text-[#222] font-medium">
            Här finns människor som kan tryck. Här finns maskinerna, hantverket och dialogen nära varandra.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ NÄRA (mörk rundad) ═══ -->
  <section class="py-[24px] sm:py-[32px] lg:py-[40px]">
    <div class="mx-[16px] sm:mx-[24px] md:mx-[32px] lg:mx-[44px] rounded-[24px] sm:rounded-[36px] lg:rounded-[50px] bg-[#222]">
      <div class="px-[24px] sm:px-[32px] md:px-[44px] lg:px-[60px] py-[64px] sm:py-[80px] md:py-[100px] lg:py-[110px]">
        <p class="!text-white/60 mb-[16px] sm:mb-[24px] uppercase font-medium text-[10px] sm:text-[12px]" style="letter-spacing: 1.5px;">Det är så vi vill arbeta</p>
        <h2 class="font-[var(--font-heading)] !font-normal !text-white mb-[40px] sm:mb-[60px] md:mb-[80px] max-w-[920px]" style="font-size: clamp(1.75rem, 4.5vw, 4.5rem); line-height: 1.02; letter-spacing: -0.03em; text-wrap: balance;">
          Vi tycker om <em>den personliga kontakten.</em>
        </h2>
        <div class="grid sm:grid-cols-3 gap-[16px] sm:gap-[20px] lg:gap-[24px] mb-[40px] sm:mb-[60px]">
          <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[28px] sm:p-[36px] lg:p-[44px]">
            <h3 class="font-[var(--font-heading)] !font-normal !text-white" style="font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem); line-height: 1.15;">Nära kunden.</h3>
          </div>
          <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[28px] sm:p-[36px] lg:p-[44px]">
            <h3 class="font-[var(--font-heading)] !font-normal !text-white" style="font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem); line-height: 1.15;">Nära produktionen.</h3>
          </div>
          <div class="bg-[#313131] rounded-[20px] sm:rounded-[25px] p-[28px] sm:p-[36px] lg:p-[44px]">
            <h3 class="font-[var(--font-heading)] !font-normal !text-white" style="font-size: clamp(1.5rem, 2.5vw + 0.5rem, 2.25rem); line-height: 1.15;">Nära hantverket.</h3>
          </div>
        </div>
        <p class="!text-white/80 text-[15px] sm:text-[17px] md:text-[18px] leading-relaxed max-w-[820px]" style="text-wrap: pretty;">
          Ett samtal kan göra stor skillnad. En fråga om material kan lyfta hela känslan. Ett råd om format kan göra trycksaken mer användbar. En genomgång av originalet kan ge ett bättre resultat i produktion.
        </p>
      </div>
    </div>
  </section>

  <!-- ═══ VARJE UPPDRAG HAR SITT SYFTE ═══ -->
  <section class="page-section">
    <div class="page-container">
      <p class="section-label">Vi börjar med syftet</p>
      <div class="grid md:grid-cols-2 gap-[32px] md:gap-[60px] lg:gap-[100px] items-start">
        <h2 class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.75rem, 4.5vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; text-wrap: balance;" lang="sv">
          Vad ska <em>trycksaken</em> göra?
        </h2>
        <div class="md:pt-[12px]">
          <p class="text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed text-[#444] mb-[24px] sm:mb-[32px]" style="text-wrap: pretty;">
            Varje uppdrag har sitt eget syfte. Därför börjar vi gärna där: med vad trycksaken ska göra.
          </p>
          <ul class="space-y-[10px] sm:space-y-[12px] mb-[28px] sm:mb-[36px]">
            {purposes.map((p) => (
              <li class="flex items-start gap-[12px] text-[15px] sm:text-[16px] md:text-[17px] leading-relaxed text-[#222]">
                <span class="shrink-0 mt-[10px] sm:mt-[11px] w-[6px] h-[6px] rounded-full bg-[#D9222A]"></span>
                <span>{p}</span>
              </li>
            ))}
          </ul>
          <p class="text-[#222] text-[16px] sm:text-[17px] md:text-[18px] leading-relaxed font-medium" style="text-wrap: pretty;">
            När syftet är tydligt blir produktionen bättre. Då kan vi välja rätt papper, rätt format, rätt tryckmetod och rätt efterbehandling.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TEAM — sidoscroll <lg, grid lg+ — fullständig kontaktinfo ═══ -->
  <section class="page-section-no-px bg-[#F3F3F3]">
    <div class="max-w-[1440px] mx-auto px-[16px] sm:px-[24px] md:px-[32px] lg:px-[44px] mb-[28px] sm:mb-[40px]">
      <p class="section-label" style="margin-bottom: 16px;">Människorna</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[12px] sm:mb-[16px]" style="font-size: clamp(1.75rem, 4vw, 4rem); line-height: 1.05; letter-spacing: -0.025em; hyphens: auto; text-wrap: balance; max-width: 880px;" lang="sv">
        Människorna du pratar med.
      </h2>
      <p class="text-[15px] sm:text-[16px] md:text-[17px] leading-relaxed text-[#555] max-w-[680px]">
        Sälj, projektledning och prepress — ring eller maila direkt så hjälper vi dig vidare.
      </p>
    </div>

    <!-- MOBILE/TABLET: sidoscroll -->
    <div class="lg:hidden">
      <div id="team-carousel" class="flex gap-[16px] sm:gap-[20px] overflow-x-auto scrollbar-hide pl-[16px] sm:pl-[24px] md:pl-[32px] pr-[16px] sm:pr-[24px] md:pr-[32px] snap-x snap-mandatory">
        {team.map((person) => (
          <article class="shrink-0 w-[240px] sm:w-[260px] md:w-[280px] bg-white rounded-[16px] overflow-hidden flex flex-col snap-start">
            <div class="aspect-[4/5] bg-[#E5E5E5] overflow-hidden">
              <img src={person.image} alt={person.name} loading="lazy" decoding="async" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700 ease-out" />
            </div>
            <div class="p-[18px] sm:p-[20px] flex flex-col gap-[4px]">
              <h3 class="text-[#222] leading-[1.15]" style="font-family: var(--font-heading); font-size: 20px; font-weight: 400; letter-spacing: -0.01em;">{person.name}</h3>
              <p class="text-[#666] mt-[2px]" style="font-size: 15px;">{person.role}</p>
              <div class="flex flex-col gap-[2px] mt-[10px]">
                {person.phones.map((p) => (
                  <a href={`tel:${p.tel}`} class="text-[#222] hover:text-[#D9222A] transition-colors" style="font-size: 15px;">{p.label}</a>
                ))}
                <a href={`mailto:${person.email}`} class="text-[#D9222A] hover:underline break-all mt-[2px]" style="font-size: 14px;">{person.email}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
      <div class="flex justify-between items-center gap-[12px] mt-[16px] sm:mt-[24px] ml-[16px] sm:ml-[24px] md:ml-[32px] mr-[16px] sm:mr-[24px] md:mr-[32px]">
        <a href="/kontakta-oss" class="btn-pill btn-dark inline-flex">
          Se alla kontaktuppgifter<Fragment set:html={arrowSvg} />
        </a>
        <div class="flex gap-[8px]">
          <button id="team-prev" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-white flex items-center justify-center text-[#888] hover:bg-[#222] hover:text-white transition-colors cursor-pointer" aria-label="Föregående">
            <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M15 18l-6-6 6-6"/></svg>
          </button>
          <button id="team-next" class="w-[40px] h-[40px] sm:w-[44px] sm:h-[44px] rounded-full bg-[#222] flex items-center justify-center text-white hover:bg-[#000] transition-colors cursor-pointer" aria-label="Nästa">
            <svg width="16" height="16" class="sm:w-[18px] sm:h-[18px]" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18l6-6-6-6"/></svg>
          </button>
        </div>
      </div>
    </div>

    <!-- DESKTOP: 5-col grid -->
    <div class="hidden lg:block max-w-[1440px] mx-auto px-[44px]">
      <div class="grid grid-cols-5 gap-[16px] mb-[32px]">
        {team.map((person) => (
          <article class="bg-white rounded-[16px] overflow-hidden flex flex-col">
            <div class="aspect-[4/5] bg-[#E5E5E5] overflow-hidden">
              <img src={person.image} alt={person.name} loading="lazy" decoding="async" class="w-full h-full object-cover hover:scale-[1.03] transition-transform duration-700 ease-out" />
            </div>
            <div class="p-[20px] flex flex-col gap-[4px]">
              <h3 class="text-[#222] leading-[1.15]" style="font-family: var(--font-heading); font-size: 22px; font-weight: 400; letter-spacing: -0.01em;">{person.name}</h3>
              <p class="text-[#666] mt-[2px]" style="font-size: 16px;">{person.role}</p>
              <div class="flex flex-col gap-[2px] mt-[12px]">
                {person.phones.map((p) => (
                  <a href={`tel:${p.tel}`} class="text-[#222] hover:text-[#D9222A] transition-colors" style="font-size: 16px;">{p.label}</a>
                ))}
                <a href={`mailto:${person.email}`} class="text-[#D9222A] hover:underline break-all mt-[2px]" style="font-size: 15px;">{person.email}</a>
              </div>
            </div>
          </article>
        ))}
      </div>
      <a href="/kontakta-oss" class="btn-pill btn-dark inline-flex">
        Se alla kontaktuppgifter<Fragment set:html={arrowSvg} />
      </a>
    </div>
  </section>

  <!-- ═══ EMOTIONAL CLOSE ═══ -->
  <section class="page-section">
    <div class="page-container">
      <p class="section-label">Det är därför vi gör det</p>
      <h2 class="font-[var(--font-heading)] !font-normal text-[#222] mb-[40px] sm:mb-[56px] md:mb-[72px] max-w-[1100px]" style="font-size: clamp(2rem, 5vw + 0.25rem, 4.5rem); line-height: 1.02; letter-spacing: -0.03em; text-wrap: balance;" lang="sv">
        För oss är tryck fortfarande <em>något levande.</em>
      </h2>
      <div class="space-y-[16px] sm:space-y-[20px] max-w-[680px]">
        <p class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.25rem, 2.8vw, 2rem); line-height: 1.25; letter-spacing: -0.015em;" lang="sv">Det börjar med en idé.</p>
        <p class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.25rem, 2.8vw, 2rem); line-height: 1.25; letter-spacing: -0.015em;" lang="sv">Det formas genom erfarenhet.</p>
        <p class="font-[var(--font-heading)] !font-normal text-[#222]" style="font-size: clamp(1.25rem, 2.8vw, 2rem); line-height: 1.25; letter-spacing: -0.015em;" lang="sv">Det blir färdigt genom hantverk.</p>
        <p class="font-[var(--font-heading)] !font-normal text-[#D9222A]" style="font-size: clamp(1.25rem, 2.8vw, 2rem); line-height: 1.25; letter-spacing: -0.015em;" lang="sv">Och det lämnar ett avtryck hos mottagaren.</p>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="page-section">
    <div class="page-container">
