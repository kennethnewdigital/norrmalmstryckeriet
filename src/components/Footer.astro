---
/* No props needed */
---

<footer class="bg-white">
  <div class="section-boxed py-[80px]">

    <!-- TOP ROW: Logo + tagline + CTA buttons -->
    <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-6 mb-12">
      <div class="flex items-center gap-4">
        <a href="/">
          <img
            src="/images/logos/site-logo.svg"
            alt="Norrmalmstryckeriet"
            class="h-[30px] w-auto"
          />
        </a>
        <span class="font-[var(--font-heading)] text-[18px] text-[#222] italic">
          Närproducerade trycksaker.
        </span>
      </div>

      <div class="flex items-center gap-3 flex-wrap">
        <a href="/kontakt" class="btn-pill btn-red">
          Kontakta oss
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
        <a href="/offert" class="btn-pill btn-red">
          Offertförfrågan
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
        </a>
      </div>
    </div>

    <!-- COLUMNS -->
    <div class="grid grid-cols-1 md:grid-cols-4 gap-5">

      <!-- Column 1: Contact -->
      <div class="flex flex-col gap-4 text-[18px] text-[#222] font-[var(--font-body)]">
        <h3 class="font-[var(--font-heading)] text-[18px] font-normal italic">AB Norrmalmstryckeriet</h3>

        <div>
          <p><strong>Besöksadress:</strong></p>
          <p>Hammarbacken 4A, Häggvik</p>
        </div>

        <div>
          <p><strong>Postadress:</strong></p>
          <p>Box 416</p>
          <p>191 24 Sollentuna</p>
        </div>

        <p>Org nr: 556088-1681</p>

        <div class="flex flex-col gap-1">
          <a
            href="mailto:tryckeri@norrmalmstryckeriet.se"
            class="text-[#CC3366] font-bold hover:underline"
          >
            tryckeri@norrmalmstryckeriet.se
          </a>
          <a
            href="mailto:info@sandvikenstryckeri.se"
            class="text-[#CC3366] font-bold hover:underline"
          >
            info@sandvikenstryckeri.se
          </a>
        </div>

        <div class="flex items-center gap-4 mt-2">
          <img
            src="/images/certifications/svanen.svg"
            alt="Svanen"
            class="h-[60px] w-auto"
          />
          <img
            src="/images/logos/sandvikens-tryckeri-logo.svg"
            alt="Sandvikens Tryckeri"
            class="h-[60px] w-auto"
          />
        </div>
      </div>

      <!-- Column 2: Produktväljare -->
      <div class="flex flex-col gap-2 text-[18px] text-[#222] font-[var(--font-body)]">
        <h3 class="font-[var(--font-heading)] text-[18px] font-normal italic mb-2">Produktväljare</h3>
        <a href="/produkter/visitkort" class="hover:underline">Visitkort</a>
        <a href="/produkter/blad-reklamblad-flyers" class="hover:underline">Blad reklamblad och flyers</a>
        <a href="/produkter/foldrar" class="hover:underline">Foldrar</a>
        <a href="/produkter/broschyrer" class="hover:underline">Broschyrer</a>
        <a href="/produkter/mappar" class="hover:underline">Mappar</a>
        <a href="/produkter/affischer" class="hover:underline">Affischer</a>
        <a href="/produkter/kuvert" class="hover:underline">Kuvert</a>
        <a href="/produkter/bocker" class="hover:underline">Böcker</a>
        <a href="/produkter/storformat" class="hover:underline">Storformat</a>

        <h3 class="font-[var(--font-heading)] text-[18px] font-normal italic mt-6 mb-2">Webshop</h3>
        <a href="https://shop.norrmalmstryckeriet.se/prepri" class="hover:underline">PREPRI</a>
        <a href="https://shop.norrmalmstryckeriet.se/icc" class="hover:underline">ICC-Profiler</a>
      </div>

      <!-- Column 3: Alla guider -->
      <div class="flex flex-col gap-2 text-[18px] text-[#222] font-[var(--font-body)]">
        <h3 class="font-[var(--font-heading)] text-[18px] font-normal italic mb-2">Alla guider</h3>
        <a href="/guider/stansmallar-mappar" class="hover:underline">Stansmallar för mappar</a>
        <a href="/guider/industritryck-planprint" class="hover:underline">Industritryck och planprint</a>
        <a href="/guider/storformat" class="hover:underline">Storformat</a>
        <a href="/guider/kuvert" class="hover:underline">Kuvert</a>
        <a href="/guider/affischer" class="hover:underline">Affischer</a>
        <a href="/guider/offsettryck" class="hover:underline">Offsettryck stora upplagor</a>
        <a href="/guider/digitaltryck" class="hover:underline">Digitaltryck</a>
        <a href="/guider/boktryck" class="hover:underline">Boktryck</a>
        <a href="/guider/filhantering" class="hover:underline">Filhantering/inställningar</a>
        <a href="/guider/reklamblad" class="hover:underline">Reklamblad</a>
        <a href="/guider/foldrar" class="hover:underline">Foldrar</a>
        <a href="/guider/broschyrer" class="hover:underline">Broschyrer</a>
        <a href="/guider/mappar" class="hover:underline">Mappar</a>
      </div>

      <!-- Column 4: Kundreferenser + Om oss -->
      <div class="flex flex-col gap-2 text-[18px] text-[#222] font-[var(--font-body)]">
        <h3 class="font-[var(--font-heading)] text-[18px] font-normal italic mb-2">Kundreferenser</h3>
        <a href="/kundreferenser/memira" class="hover:underline">Memira</a>
        <a href="/kundreferenser/kyrkbyran" class="hover:underline">Kyrkbyrån</a>
        <a href="/kundreferenser/odelius" class="hover:underline">Odelius & Co</a>
        <a href="/kundreferenser/curlingforbundet" class="hover:underline">Svenska Curlingförbundet</a>
        <a href="/kundreferenser/zetatrade" class="hover:underline">Zetatrade AB</a>

        <h3 class="font-[var(--font-heading)] text-[18px] font-normal italic mt-6 mb-2">Om oss</h3>
        <a href="/kontakt" class="hover:underline">Kontakta oss</a>
        <a href="/om-oss" class="hover:underline">Om oss</a>
        <a href="/nyheter" class="hover:underline">Nyheter</a>
        <a href="/miljo" class="hover:underline">Miljö</a>
        <a href="/historik" class="hover:underline">Historik</a>
        <a href="/integritetspolicy" class="hover:underline">Integritetspolicy</a>
      </div>

    </div>
  </div>
</footer>
