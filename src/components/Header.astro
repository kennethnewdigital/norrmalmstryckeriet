---
/* No props needed */
---

<header
  class="fixed top-0 left-0 right-0 z-[99] bg-white h-[48px] px-[30px] flex items-center justify-between"
>
  <!-- Logo -->
  <a href="/" class="shrink-0">
    <img
      src="/images/logos/site-logo.svg"
      alt="Norrmalmstryckeriet"
      class="h-[26px] w-auto"
    />
  </a>

  <!-- Desktop nav -->
  <nav class="hidden md:flex items-center gap-5">
    <a
      href="/kontakt"
      class="font-[var(--font-ui)] text-[16px] font-medium text-black inline-flex items-center hover:opacity-80 transition-opacity"
    >
      Kontakta oss
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>

    <a
      href="/offert"
      class="btn-pill btn-red"
    >
      Begär offert
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>

    <a
      href="https://shop.norrmalmstryckeriet.se"
      class="font-[var(--font-ui)] text-[16px] font-medium text-black inline-flex items-center hover:opacity-80 transition-opacity"
    >
      Webbshop
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>

    <a href="https://www.sandvikenstryckeri.se" class="shrink-0">
      <img
        src="/images/logos/sandvikens-tryckeri-logo.svg"
        alt="Sandvikens Tryckeri"
        class="h-[43px] w-auto"
      />
    </a>

    <!-- Hamburger (desktop) -->
    <button
      id="hamburger-btn"
      class="text-[#D9222A] flex flex-col justify-center items-center gap-[5px] cursor-pointer"
      aria-label="Meny"
      aria-expanded="false"
    >
      <span class="block w-[22px] h-[2px] bg-current transition-transform duration-200 origin-center" id="ham-top"></span>
      <span class="block w-[22px] h-[2px] bg-current transition-opacity duration-200" id="ham-mid"></span>
      <span class="block w-[22px] h-[2px] bg-current transition-transform duration-200 origin-center" id="ham-bot"></span>
    </button>
  </nav>

  <!-- Mobile hamburger -->
  <button
    id="hamburger-btn-mobile"
    class="md:hidden text-[#D9222A] flex flex-col justify-center items-center gap-[5px] cursor-pointer"
    aria-label="Meny"
    aria-expanded="false"
  >
    <span class="block w-[22px] h-[2px] bg-current transition-transform duration-200 origin-center" id="ham-top-m"></span>
    <span class="block w-[22px] h-[2px] bg-current transition-opacity duration-200" id="ham-mid-m"></span>
    <span class="block w-[22px] h-[2px] bg-current transition-transform duration-200 origin-center" id="ham-bot-m"></span>
  </button>
</header>

<!-- Mobile / slide-down nav -->
<div
  id="mobile-nav"
  class="fixed top-[48px] left-0 right-0 bg-white z-[98] shadow-lg translate-y-[-100%] opacity-0 pointer-events-none transition-all duration-300"
>
  <nav class="flex flex-col px-[30px] py-6 gap-4">
    <a href="/produkter" class="font-[var(--font-ui)] text-[16px] font-medium text-[#222]">Produkter och tjänster</a>
    <div class="pl-4 flex flex-col gap-3 -mt-1">
      <a href="/produkter/blad" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Blad, reklamblad, flyers</a>
      <a href="/produkter/foldrar" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Foldrar</a>
      <a href="/produkter/broschyrer" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Broschyrer</a>
      <a href="/produkter/mappar" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Mappar</a>
      <a href="/produkter/affischer" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Affischer</a>
      <a href="/produkter/kuvert" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Kuvert</a>
      <a href="/produkter/bocker" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Böcker</a>
      <a href="/produkter/storformat" class="font-[var(--font-ui)] text-[15px] text-[#444] hover:text-[#222]">Storformat</a>
    </div>
    <a href="/guider" class="font-[var(--font-ui)] text-[16px] font-medium text-[#222]">Guider</a>
    <a href="/kundreferenser" class="font-[var(--font-ui)] text-[16px] font-medium text-[#222]">Kundreferenser</a>
    <a href="/om-oss" class="font-[var(--font-ui)] text-[16px] font-medium text-[#222]">Om oss</a>

    <hr class="border-[var(--color-divider)]" />

    <a href="/kontakt" class="font-[var(--font-ui)] text-[16px] font-medium text-black inline-flex items-center">
      Kontakta oss
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>

    <a href="/offert" class="btn-pill btn-red w-fit">
      Begär offert
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>

    <a href="https://shop.norrmalmstryckeriet.se" class="font-[var(--font-ui)] text-[16px] font-medium text-black inline-flex items-center">
      Webbshop
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" class="inline-block ml-1"><path d="M7 17L17 7M17 7H7M17 7v10"/></svg>
    </a>

    <hr class="border-[var(--color-divider)]" />

    <a href="tel:+4686210090" class="font-[var(--font-ui)] text-[16px] font-medium text-[#D9222A]">
      08-621 00 90
    </a>

    <div class="flex items-center gap-4 mt-2">
      <img src="/images/logos/sandvikens-tryckeri-logo.svg" alt="Sandvikens Tryckeri" class="h-[40px] w-auto" />
    </div>
  </nav>
</div>

<!-- Spacer to offset fixed header -->
<div class="h-[48px]"></div>

<script>
  function initHeader() {
    const hamburgerDesktop = document.getElementById('hamburger-btn');
    const hamburgerMobile = document.getElementById('hamburger-btn-mobile');
    const mobileNav = document.getElementById('mobile-nav');
    let isOpen = false;

    function toggle() {
      isOpen = !isOpen;

      if (isOpen) {
        mobileNav.classList.remove('translate-y-[-100%]', 'opacity-0', 'pointer-events-none');
        mobileNav.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
      } else {
        mobileNav.classList.add('translate-y-[-100%]', 'opacity-0', 'pointer-events-none');
        mobileNav.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      }

      // Animate hamburger lines
      const tops = document.querySelectorAll('[id^="ham-top"]');
      const mids = document.querySelectorAll('[id^="ham-mid"]');
      const bots = document.querySelectorAll('[id^="ham-bot"]');

      tops.forEach(el => {
        el.style.transform = isOpen ? 'translateY(7px) rotate(45deg)' : '';
      });
      mids.forEach(el => {
        el.style.opacity = isOpen ? '0' : '1';
      });
      bots.forEach(el => {
        el.style.transform = isOpen ? 'translateY(-7px) rotate(-45deg)' : '';
      });

      // Update aria
      [hamburgerDesktop, hamburgerMobile].forEach(btn => {
        if (btn) btn.setAttribute('aria-expanded', String(isOpen));
      });
    }

    if (hamburgerDesktop) hamburgerDesktop.addEventListener('click', toggle);
    if (hamburgerMobile) hamburgerMobile.addEventListener('click', toggle);
  }

  // Run on initial load and on Astro page transitions
  initHeader();
  document.addEventListener('astro:after-swap', initHeader);
</script>
